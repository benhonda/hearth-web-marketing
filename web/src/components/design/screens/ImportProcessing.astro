---
/**
 * Photo · processing (Flow I · III · Photo sub-flow).
 *
 * The wait. After the cook picks a photograph from the OS picker, AI
 * vision does the slow work — reading cursive on grandma's pink paper,
 * transcribing the recipe verbatim. The cook lands here while it
 * thinks; the screen auto-advances to the transcription gate when
 * vision completes.
 *
 * Voice: a small typographic "page" illustration — five Ochre hairlines
 * at varying widths that draw left-to-right and fade in sequence,
 * suggesting the AI reading line by line down the page. Italic Lora
 * "— reading the page —" beneath. The animation is a continuous gentle
 * wave (each line offset in phase) so the screen always has motion but
 * never feels frantic. No spinner, no progress bar, no percentage —
 * those are SaaS chrome. No fake-photo graphic either: showing a
 * paper-warmth placeholder where the cook's actual photo isn't would
 * read as cosplay.
 *
 * No tap target — this screen auto-advances. The Cancel button is the
 * only out (abort transcription).
 */
interface Props { showTap?: boolean }
const { showTap } = Astro.props;
void showTap;
---

<div class="proc">
  <header class="proc-bar">
    <button class="proc-bar__cancel" type="button">Cancel</button>
    <span class="proc-bar__eyebrow">Bring in a recipe</span>
    <span class="proc-bar__spacer" aria-hidden="true"></span>
  </header>

  <div class="proc__body">
    <div class="proc__page" aria-hidden="true">
      <span class="proc__line proc__line--1"></span>
      <span class="proc__line proc__line--2"></span>
      <span class="proc__line proc__line--3"></span>
      <span class="proc__line proc__line--4"></span>
      <span class="proc__line proc__line--5"></span>
    </div>
    <p class="proc__message">— reading the page —</p>
  </div>
</div>

<style>
  .proc {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
    padding-bottom: 44px; /* home indicator clearance */
  }

  /* Top bar — same grammar as the rest of the import arc. Cancel is
     the only action available; the eyebrow is the only label; right
     side is empty (no Save, no Continue — the screen auto-advances). */
  .proc-bar {
    padding: 62px 22px 14px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(31, 27, 23, 0.08);
  }
  .proc-bar__cancel {
    justify-self: flex-start;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--c-ash);
  }
  .proc-bar__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    white-space: nowrap;
  }
  .proc-bar__spacer { display: block; }

  /* Body — centered vertically. The page illustration sits above the
     italic message; both Ochre on cream, both typographic. */
  .proc__body {
    display: grid;
    place-content: center;
    justify-items: center;
    gap: 22px;
    padding: 22px;
  }

  /* Reading illustration — five Ochre hairlines arranged at varying
     widths, suggesting text on a page. Each draws left-to-right and
     fades in sequence; with their animation-delays offset, the wave
     never empties — there's always something visible, like the AI
     reading line by line in a continuous loop.
     Sized 96×128 (3:4 portrait — card-shaped). No frame, no fill —
     just the hairlines doing the work. */
  .proc__page {
    position: relative;
    width: 96px;
    height: 128px;
  }
  .proc__line {
    position: absolute;
    left: 0;
    height: 1px;
    background: var(--c-ochre);
    transform-origin: left center;
    transform: scaleX(0);
    opacity: 0;
    animation: proc-write 4s ease-in-out infinite;
  }
  .proc__line--1 { top: 12px;  width: 68px; animation-delay: 0s; }
  .proc__line--2 { top: 36px;  width: 84px; animation-delay: 0.35s; }
  .proc__line--3 { top: 60px;  width: 56px; animation-delay: 0.70s; }
  .proc__line--4 { top: 84px;  width: 72px; animation-delay: 1.05s; }
  .proc__line--5 { top: 108px; width: 44px; animation-delay: 1.40s; }

  @keyframes proc-write {
    0%   { transform: scaleX(0); opacity: 0; }
    8%   { transform: scaleX(0); opacity: 1; }
    25%  { transform: scaleX(1); opacity: 1; }
    65%  { transform: scaleX(1); opacity: 1; }
    85%  { transform: scaleX(1); opacity: 0; }
    100% { transform: scaleX(0); opacity: 0; }
  }

  /* Reduced motion — settle the lines into their drawn state, no
     animation. Honors users who've opted out without breaking the
     visual; the page illustration still reads as "page being read." */
  @media (prefers-reduced-motion: reduce) {
    .proc__line {
      animation: none;
      transform: scaleX(1);
      opacity: 1;
    }
  }

  /* The message — italic Lora display, em-dash bookends, Ochre. Same
     vocabulary as Hearth's other italic-Ochre invitations ("— add a
     note —", "When you're ready to make these into a book —") so this
     reads as part of the system, not an exception. */
  .proc__message {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.4;
    color: var(--c-ochre);
    text-align: center;
    margin: 0;
    letter-spacing: 0.005em;
  }
</style>
