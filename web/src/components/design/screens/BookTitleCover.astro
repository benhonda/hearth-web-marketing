---
/**
 * Screen VI (Flow II) · Title & cover.
 *
 * Step iv of v. The cover PREVIEW is the interface — same craft move
 * as the dedication screen. Title, subtitle, and photo plate are all
 * tap-to-edit on the rendered cover. No separate form fields, no
 * labels in chrome. The object is the editor.
 *
 * Cover template (the single V1 cover per MVP):
 *   · Sage cloth ground
 *   · Small HEARTH PRESS eyebrow at top (letterhead, tokens.css)
 *   · Photo plate inset (4:5, ~55% of cover width) — the "tipped-in
 *     plate" treatment from mid-century cloth-bound cookbooks
 *   · Foil Lora italic title below the plate
 *   · Smaller foil italic subtitle
 *   · Marcellus HEARTH colophon at the foot
 *
 * Below the cover, a thin horizontal scroller of alternate cover
 * photos (the MVP "pick cover photo from selected recipes" spec).
 * The first thumb is the active selection (corn ragù, continuous with
 * the rest of the binder).
 */
import { sampleRecipe } from "~/lib/design/sample-recipe";
import { sampleLibraryTiles } from "~/lib/design/sample-library";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

// Six candidate covers for the alternates row. Picks a spread across
// the library so the user sees a range of photo options.
const coverCandidates = [0, 3, 10, 13, 23, 24].map((i) => sampleLibraryTiles[i]);
---

<div class="tc">
  <nav class="tc__topbar" aria-label="Back">
    <button class="tc__back" type="button" aria-label="Back">
      <span aria-hidden="true">‹</span>
    </button>
  </nav>

  <header class="tc__head">
    <span class="tc__head-eyebrow">Editing</span>
    <hr class="tc__head-rule" aria-hidden="true" />
    <h1 class="tc__head-title">The cover.</h1>
    <p class="tc__head-lede">Tap any line to edit.</p>
  </header>

  <div class="tc__stage">
    <article class="tc__cover" aria-label="Cover preview">
      <span class="tc__eyebrow">Hearth Press</span>
      <span class="tc__eyebrow-rule" aria-hidden="true"></span>

      <div class="tc__plate" aria-hidden="true" style={`background-image: url(${sampleRecipe.photo})`}></div>

      <h2 class="tc__title">For Us.</h2>
      <p class="tc__subtitle">A year at the table.</p>

      <div class="tc__colophon">HEARTH</div>
    </article>
  </div>

  <div class="tc__alts">
    <span class="tc__alts-label">Cover photo</span>
    <div class="tc__alts-row">
      {coverCandidates.map((tile, i) => {
        const isActive = i === 0; // corn ragù = currently chosen
        const photoStyle = tile.photo
          ? `background-image: url(${tile.photo})`
          : `background: radial-gradient(ellipse at 30% 30%, var(--alt-a), var(--alt-b) 55%, var(--alt-c))`;
        const tone = tile.tone ?? "corn";
        return (
          <button
            class:list={["tc__alt", isActive && "tc__alt--on", `tc__alt--${tone}`]}
            type="button"
            aria-label={tile.title}
            aria-pressed={isActive}
            style={photoStyle}
          ></button>
        );
      })}
    </div>
  </div>

  <div class="tc__foot">
    <button class={showTap ? "tc__continue tc__continue--tap" : "tc__continue"} type="button">
      Continue
    </button>
  </div>
</div>

<style>
  .tc {
    display: grid;
    grid-template-rows: auto auto 1fr auto auto;
    min-height: 100%;
    padding-bottom: 44px;
  }

  .tc__topbar { padding: 62px 12px 0; }

  /* Contextual edit-landing header. Explicit on every declaration so
     nothing depends on ancestor inheritance — every text element
     states its own font-family, text-align, margin, and line-height. */
  .tc__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 8px 22px 20px;
  }
  .tc__head-eyebrow {
    display: block;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10.5px;
    line-height: 1.3;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-align: center;
    color: var(--c-ochre);
    margin: 0;
  }
  .tc__head-rule {
    display: block;
    border: 0;
    width: var(--rule-chapter);
    height: var(--rule-weight-chapter);
    background: var(--c-ochre);
    margin: 4px 0 2px;
  }
  .tc__head-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    text-align: center;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }
  .tc__head-lede {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.4;
    text-align: center;
    color: var(--c-ash);
    margin: 2px 0 0;
  }
  .tc__back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding-bottom: 2px;
    font-family: var(--f-display);
    font-size: 26px;
    line-height: 1;
    color: var(--c-ink);
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  /* Cover stage — the rendered cover at ~70% of phone width, centered.
     Background is a quiet desk surface with paper-shadow under the
     cover so it reads as a physical object sitting on cream paper. */
  .tc__stage {
    display: grid;
    place-items: center;
    padding: 12px 28px 0;
  }

  /* The cover itself. 4:5 aspect (the book's actual proportion).
     Sage cloth with the same weave texture as PhoneFrame's sage
     variant so the cloth reads as continuous with the app's hardcover
     moments (Welcome, Invitation). */
  .tc__cover {
    position: relative;
    width: 100%;
    max-width: 260px;
    aspect-ratio: 4 / 5;
    background: var(--c-conifer);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-lift);
    padding: 22px 22px 24px;
    display: grid;
    grid-template-rows: auto auto 1fr auto auto auto;
    justify-items: center;
    gap: 10px;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent 0,
        transparent 3px,
        rgba(244, 239, 230, 0.012) 3px,
        rgba(244, 239, 230, 0.012) 4px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 3px,
        rgba(0, 0, 0, 0.03) 3px,
        rgba(0, 0, 0, 0.03) 4px
      );
  }

  .tc__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 8px;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--c-foil-light);
    text-align: center;
    margin-top: 4px;
  }

  .tc__eyebrow-rule {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--c-foil);
    opacity: 0.6;
    margin-bottom: 6px;
  }

  /* The tipped-in photo plate — the one piece of photography on an
     otherwise typographic sage cover. 2px corner like every book-page
     in the system; shadow suggests physical inset. */
  .tc__plate {
    width: 58%;
    aspect-ratio: 4 / 5;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    border-radius: var(--r-page);
    box-shadow:
      inset 0 0 0 0.5px rgba(0, 0, 0, 0.35),
      0 2px 6px rgba(0, 0, 0, 0.25);
    margin: 4px 0 12px;
  }

  .tc__title {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 26px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--c-foil);
    margin: 0;
    text-align: center;
    text-shadow: 0 1px 0 rgba(184, 147, 74, 0.08);
  }

  .tc__subtitle {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 12.5px;
    line-height: 1.3;
    color: var(--c-linen);
    margin: 0;
    text-align: center;
    max-width: 22ch;
    text-wrap: balance;
  }

  .tc__colophon {
    font-family: var(--f-wordmark);
    font-weight: 400;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-foil);
    align-self: end;
    opacity: 0.85;
  }

  /* Cover-photo alternates — horizontal row of tappable swatches.
     Active swatch has a foil hairline border to read as "chosen"
     without pulling in any saturated accent. */
  .tc__alts {
    padding: 20px 22px 0;
    display: grid;
    gap: 10px;
  }
  .tc__alts-label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ash);
  }
  .tc__alts-row {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 54px;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 2px;
    scrollbar-width: none;
  }
  .tc__alts-row::-webkit-scrollbar { display: none; }

  .tc__alt {
    width: 54px;
    aspect-ratio: 4 / 5;
    border-radius: var(--r-page);
    border: 0;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    cursor: pointer;
    padding: 0;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.15);
    transition: box-shadow var(--motion-state) var(--ease-state);
  }
  /* Placeholder gradient fallbacks match LibraryTile tones. */
  .tc__alt--corn:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .tc__alt--sage:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .tc__alt--ochre:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }

  .tc__alt--on {
    box-shadow:
      inset 0 0 0 0.5px rgba(0, 0, 0, 0.15),
      0 0 0 1.5px var(--c-ochre),
      0 0 0 3px var(--c-cream);
  }

  .tc__foot { padding: 22px 24px 0; }

  .tc__continue {
    position: relative;
    width: 100%;
    height: 48px;
    border-radius: 999px;
    background: transparent;
    color: var(--c-conifer);
    border: 1px solid var(--c-conifer);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14.5px;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background-color var(--motion-state) var(--ease-state);
  }
  .tc__continue--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
