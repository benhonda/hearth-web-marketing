---
/**
 * Screen IX · Recipe · editing step iv (inline).
 *
 * Thin composition: the full RecipeDetail with `editingIndex={3}` so
 * step iv renders as a live textarea in-place. This screen adds only
 * the edit chrome:
 *   · a quiet top strip showing "Editing · step iv" context
 *   · an iOS-style keyboard accessory bar above the keyboard with
 *     Cancel + Save — thumb-accessible while keyboard is up
 *   · the iOS keyboard docked at the bottom
 *
 * All three strips are `position: sticky` within the phone's scroll
 * viewport. An inline script scrolls the textarea into the visible
 * band on load (what iOS does when a buried input focuses).
 */
import RecipeDetail from "./RecipeDetail.astro";
import IosKeyboard from "../ui/IosKeyboard.astro";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
---

<div class="edit">
  <header class="edit-bar">
    <span class="edit-bar__eyebrow">Editing · step iv</span>
  </header>

  <RecipeDetail editingIndex={3} hideHeader />

  <div class="edit__dock">
    <div class="edit__accessory" role="toolbar" aria-label="Edit actions">
      <button class="edit__cancel" type="button">Cancel</button>
      <button class={showTap ? "edit__save edit__save--tap" : "edit__save"} type="button">Save</button>
    </div>
    <IosKeyboard suggestions={["minutes", "12", "just"] as [string, string, string]} />
  </div>
</div>

<script is:inline>
  (function () {
    function run() {
      document.querySelectorAll(".edit").forEach(function (edit) {
        var scroller = edit.closest(".phone__scroll");
        var ta = edit.querySelector(".method__textarea");
        if (!scroller || !ta) return;
        // Walk offsetParent chain for the textarea's position in the
        // scroller's own coordinate system. Immune to ancestor
        // transforms (e.g. canvas phones at scale(0.58)) unlike rects.
        var offsetTop = 0;
        var el = ta;
        while (el && el !== scroller) {
          offsetTop += el.offsetTop;
          el = el.offsetParent;
        }
        // Land the textarea just below the sticky edit-bar.
        scroller.scrollTop = Math.max(0, offsetTop - 140);
      });
    }
    if (document.readyState === "complete") run();
    else window.addEventListener("load", run);
  })();
</script>

<style>
  .edit {
    position: relative;
    min-height: 100%;
  }

  /* Top strip — quiet context label, no buttons ─────────── */

  .edit-bar {
    position: sticky;
    top: 0;
    z-index: 10;
    padding: 62px 22px 12px;
    display: grid;
    place-items: center;
    background: var(--c-cream);
    border-bottom: 1px solid rgba(31, 27, 23, 0.08);
  }
  .edit-bar__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    white-space: nowrap;
  }

  /* Bottom dock — accessory bar + keyboard, sticky as one ── */

  .edit__dock {
    position: sticky;
    bottom: 0;
    z-index: 10;
  }

  .edit__accessory {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 14px;
    background: #EFE9DC;
    border-top: 1px solid rgba(31, 27, 23, 0.1);
    border-bottom: 1px solid rgba(31, 27, 23, 0.06);
  }

  .edit__cancel,
  .edit__save {
    appearance: none;
    -webkit-appearance: none;
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 4px 10px;
    border: 0;
    border-radius: 6px;
    background: transparent;
    font-family: var(--f-body);
    font-size: 14px;
    line-height: 1;
    cursor: pointer;
  }

  .edit__cancel {
    color: var(--c-ash);
    font-weight: 400;
  }

  .edit__save {
    position: relative;
    color: var(--c-ochre);
    font-weight: 500;
  }

  .edit__save--tap::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
