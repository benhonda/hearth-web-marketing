---
/**
 * Typographic hardcover cover artifact.
 * No photography — the cover is rendered as foil-on-cloth CSS, per
 * tokens.css ("covers, chapter openers, and cookbook interiors remain
 * typographic only").
 */
---

<figure class="book" aria-hidden="true">
  <div class="book__spine"></div>
  <div class="book__cover">
    <div class="book__weave"></div>
    <div class="book__frame">
      <span class="book__pressmark">HEARTH&nbsp;·&nbsp;PRESS</span>
      <span class="book__rule"></span>
      <span class="book__mark">HEARTH</span>
      <span class="book__rule book__rule--wide"></span>
      <em class="book__subtitle">Vol. One</em>
      <span class="book__subrule"></span>
      <em class="book__dedication">
        Recipes worth keeping,<br />bound in cloth.
      </em>
    </div>
    <span class="book__colophon">MMXXVI</span>
  </div>
  <figcaption class="sr">A foil-stamped sage-cloth hardcover stamped HEARTH.</figcaption>
</figure>

<style>
  .book {
    position: relative;
    margin: 0;
    /* 8×10 hardcover aspect — 4:5 */
    aspect-ratio: 4 / 5;
    width: 100%;
    max-width: 26rem;
    isolation: isolate;
    filter: drop-shadow(0 24px 36px rgba(20, 14, 4, 0.38))
      drop-shadow(0 4px 10px rgba(20, 14, 4, 0.22));
  }

  /* A sliver of spine peeking out the left edge, suggesting thickness */
  .book__spine {
    position: absolute;
    inset: 1.5% auto 1.5% -0.5%;
    width: 1.25%;
    background: linear-gradient(
      90deg,
      #1f3328 0%,
      #26392f 50%,
      #1a2c23 100%
    );
    border-radius: 1px 0 0 1px;
    z-index: -1;
  }

  .book__cover {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      #34513f 0%,
      #2f4a3c 48%,
      #2a4335 100%
    );
    border-radius: 1px 2px 2px 1px;
    overflow: hidden;
    /* Subtle inner rim — a printed-edge effect */
    box-shadow:
      inset 0 0 0 1px rgba(244, 239, 230, 0.03),
      inset 0 0 60px 8px rgba(0, 0, 0, 0.22);
  }

  /* Cloth weave — diagonal crosshatch of near-transparent lines */
  .book__weave {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent 0,
        transparent 2px,
        rgba(244, 239, 230, 0.018) 2px,
        rgba(244, 239, 230, 0.018) 3px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 2px,
        rgba(0, 0, 0, 0.05) 2px,
        rgba(0, 0, 0, 0.05) 3px
      );
    mix-blend-mode: overlay;
    opacity: 0.9;
  }

  /* The typographic composition, inset like a foil-stamped panel */
  .book__frame {
    position: absolute;
    inset: 9% 8% 9% 8%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.35rem, 1vw, 0.75rem);
    text-align: center;
    color: var(--c-foil);
  }

  .book__pressmark {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: clamp(0.55rem, 0.8vw, 0.75rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-foil-light);
    margin-bottom: clamp(0.5rem, 1.5vw, 1.25rem);
  }

  .book__rule {
    display: block;
    width: 28px;
    height: 1px;
    background: var(--c-foil);
  }
  .book__rule--wide { width: 44px; }

  .book__subrule {
    display: block;
    width: 18px;
    height: 1px;
    background: var(--c-foil-light);
    opacity: 0.7;
    margin-top: clamp(0.25rem, 0.8vw, 0.6rem);
  }

  .book__mark {
    font-family: var(--f-wordmark);
    font-weight: 400;
    font-size: clamp(1.65rem, 5vw, 3.25rem);
    letter-spacing: 0.14em;
    line-height: 1;
    color: var(--c-foil);
    /* Subtle foil-stamp impression — soft inner highlight */
    text-shadow:
      0 1px 0 rgba(244, 239, 230, 0.18),
      0 -1px 0 rgba(0, 0, 0, 0.35);
    padding-inline: 0.3em;
  }

  .book__subtitle {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(0.85rem, 1.5vw, 1.1rem);
    color: var(--c-foil-light);
    letter-spacing: 0.02em;
    margin-top: clamp(0.25rem, 0.8vw, 0.5rem);
  }

  .book__dedication {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(0.75rem, 1vw, 0.95rem);
    line-height: 1.55;
    color: color-mix(in oklab, var(--c-foil-light) 80%, var(--c-conifer));
    margin-top: auto;
    padding-top: clamp(1rem, 3vw, 2rem);
    opacity: 0.85;
  }

  .book__colophon {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 4.5%;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: clamp(0.55rem, 0.7vw, 0.7rem);
    letter-spacing: 0.35em;
    text-align: center;
    color: var(--c-foil-light);
    opacity: 0.7;
  }

  .sr {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
