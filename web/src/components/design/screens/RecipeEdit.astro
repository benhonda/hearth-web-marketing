---
/**
 * Screen VIII · Recipe · edit.
 *
 * User has tapped Edit. The recipe is still visible, but step iv is
 * live in a textarea — the text has been updated from "8 minutes" to
 * "10–12 minutes" (the classic home-cook correction). The active step
 * gets the Input Fill background and a Warm Charcoal focus border.
 * Save becomes the primary action; Cancel discards.
 *
 * This is one of two edit conventions we're using — the other is the
 * "tap any section" pattern on import preview. Eventually this one wins
 * in-app: direct inline edit, no separate form screen.
 */
import IngredientsList from "../ui/IngredientsList.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const editingIndex = 3; // step iv
const romanForStep = "iv";

function toRoman(n: number): string {
  const map: [number, string][] = [
    [10, "x"], [9, "ix"], [5, "v"], [4, "iv"], [1, "i"],
  ];
  let result = "";
  let v = n;
  for (const [value, symbol] of map) {
    while (v >= value) { result += symbol; v -= value; }
  }
  return result;
}
---

<div class="edit">
  <header class="edit-bar">
    <button class="edit-bar__cancel" type="button">Cancel</button>
    <span class="edit-bar__eyebrow">Editing · step {romanForStep}</span>
    <button class={showTap ? "edit-bar__save edit-bar__save--tap" : "edit-bar__save"} type="button">Save</button>
  </header>

  <div class="edit__hero" aria-hidden="true" />

  <div class="edit__body">
    <span class="edit__source">From {sampleRecipe.source}</span>
    <h1 class="edit__title">{sampleRecipe.title}</h1>
    <p class="edit__meta">
      <em>Serves {sampleRecipe.serves}</em>
      <span aria-hidden="true"> · </span>
      <em>{sampleRecipe.minutes} minutes</em>
    </p>

    <hr class="edit__rule" />

    <IngredientsList items={sampleRecipe.ingredients} />

    <hr class="edit__rule" />

    <section>
      <span class="method__eyebrow">Method</span>
      <ol class="method">
        {sampleRecipe.editedMethod.map((item, i) => {
          const r = toRoman(i + 1);
          const isEditing = i === editingIndex;
          return (
            <li class={isEditing ? "method__li method__li--editing" : "method__li"}>
              <span class="method__num">{r}.</span>
              {isEditing ? (
                <label class="method__field">
                  <textarea class="method__textarea" rows={4}>{item}</textarea>
                  <span class="method__caret" aria-hidden="true" />
                </label>
              ) : (
                <span class="method__text">{item}</span>
              )}
            </li>
          );
        })}
      </ol>
    </section>

    <p class="edit__hint">
      <em>This creates a new version.</em> The original stays in history.
    </p>
  </div>
</div>

<style>
  .edit {
    display: grid;
    grid-template-rows: auto auto 1fr;
    min-height: 100%;
    padding-bottom: 44px;
  }

  /* Bar ──────────────────────────────────────────────────── */

  .edit-bar {
    padding: 62px 22px 14px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(31, 27, 23, 0.08);
  }
  .edit-bar__cancel {
    justify-self: flex-start;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--c-ash);
  }
  .edit-bar__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    white-space: nowrap;
  }
  .edit-bar__save {
    position: relative;
    justify-self: flex-end;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14px;
    color: var(--c-ochre);
    padding: 4px 8px;
  }
  .edit-bar__save--tap::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* Compact hero — visual anchor, smaller than the detail screen's */

  .edit__hero {
    width: 100%;
    aspect-ratio: 16 / 7;
    background: radial-gradient(
      ellipse at 32% 34%, #f7dd95 0%, #d6a34e 42%, #7f5219 100%
    );
    opacity: 0.92;
  }

  /* Body ─────────────────────────────────────────────────── */

  .edit__body {
    padding: 18px 22px 20px;
    display: grid;
    gap: 8px;
  }

  .edit__source {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .edit__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  .edit__meta {
    font-family: var(--f-display);
    font-size: 13px;
    color: var(--c-ash);
  }
  .edit__meta em {
    font-style: italic;
    color: var(--c-ink);
  }

  .edit__rule {
    border: 0;
    height: 1px;
    background: rgba(31, 27, 23, 0.1);
    margin: 8px 0;
  }

  .edit__hint {
    font-family: var(--f-display);
    font-size: 12.5px;
    color: var(--c-oat);
    margin-top: 10px;
    line-height: 1.5;
  }
  .edit__hint em {
    font-style: italic;
    color: var(--c-ochre);
  }

  /* Method — inline, with one step in edit mode ─────────── */

  .method__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    display: block;
    margin-bottom: 10px;
  }

  .method {
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .method__li {
    display: grid;
    grid-template-columns: 30px 1fr;
    gap: 2px;
    align-items: baseline;
  }

  .method__num {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    color: var(--c-ochre);
    line-height: 1.55;
  }

  .method__text {
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--c-ink);
  }

  /* The one step in edit mode ─────────────────────────────── */

  .method__li--editing .method__num {
    color: var(--c-ink);
  }

  .method__field {
    position: relative;
    display: block;
  }

  .method__textarea {
    width: 100%;
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--c-ink);
    background: #ffffff;
    border: 1px solid var(--c-ink);
    border-radius: 2px;
    padding: 8px 10px;
    resize: none;
    box-shadow: 0 0 0 3px rgba(122, 90, 38, 0.18);
  }
  .method__textarea:focus { outline: none; }

  /* Implied caret — visually present, purely decorative */
  .method__caret {
    position: absolute;
    right: 14px;
    bottom: 14px;
    width: 1.5px;
    height: 15px;
    background: var(--c-ink);
    animation: caret 1.1s steps(2) infinite;
  }
  @keyframes caret {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .method__caret { animation: none; opacity: 1; }
  }
</style>
