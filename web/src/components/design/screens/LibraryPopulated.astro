---
/**
 * Screen I (Flow II) · Library · populated.
 *
 * The library at depth — a real saved-recipe collection rendered in the
 * two-column photo waterfall (tokens.css §PHOTOGRAPHY). Sets the stage
 * for the commission flow: at this density, a book becomes thinkable.
 *
 * Below the waterfall, an editor's invitation — small-cap eyebrow, the
 * 1.5px chapter rule, an italic Lora line. This is the entry point to
 * the commission flow; the whole block is the tap target.
 *
 * Tile content is in the archetype's voice — farmers-market-y, Chez
 * Panisse / Ottolenghi register, mix of day-parts. The corn ragù keeps
 * its real photo so the recipe carries continuity into the rest of the
 * binder; the rest are typographic placeholders rotating through the
 * three tones (corn / sage / ochre) for visual variety.
 */
import AppHeader from "../ui/AppHeader.astro";
import LibraryGrid from "../ui/LibraryGrid.astro";
import { sampleLibraryTiles } from "~/lib/design/sample-library";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const tiles = sampleLibraryTiles;
---

<div class="lib-pop">
  <AppHeader variant="wordmark" />

  <div class="lib-pop__count">
    <span class="lib-pop__n">{tiles.length}</span>
    <span class="lib-pop__label">recipes</span>
  </div>

  <LibraryGrid tiles={tiles} />

  <div class={showTap ? "lib-pop__invite lib-pop__invite--tap" : "lib-pop__invite"}>
    <span class="lib-pop__eyebrow">Hearth Press</span>
    <hr class="lib-pop__rule" aria-hidden="true" />
    <p class="lib-pop__line">
      When you're ready to make these<br />into a book —
    </p>
    <p class="lib-pop__cta">
      <span>Begin your book</span>
      <span class="lib-pop__chev" aria-hidden="true">→</span>
    </p>
  </div>
</div>

<style>
  .lib-pop {
    display: grid;
    grid-template-rows: auto auto auto auto;
    min-height: 100%;
    padding-bottom: 44px;
  }

  /* Recipe count — same rhythm as LibraryOneRecipe so the two screens
     share a header voice across the binder. */
  .lib-pop__count {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 0 22px;
    margin: 4px 0 18px;
  }
  .lib-pop__n {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    color: var(--c-ochre);
  }
  .lib-pop__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-oat);
  }

  /* The editor's invitation. Layout follows tokens.css LAYOUT RHYTHM:
     small-cap eyebrow → chapter rule → italic line. Centered, the
     whole block is the tap target. */
  .lib-pop__invite {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 12px;
    padding: 56px 22px 28px;
    text-align: center;
  }

  .lib-pop__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .lib-pop__rule {
    border: 0;
    width: var(--rule-chapter);
    height: var(--rule-weight-chapter);
    background: var(--c-ochre);
    margin: 4px 0 6px;
  }

  .lib-pop__line {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.4;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }

  /* Tertiary T2 — the "navigational continue" pattern in tokens.css.
     Chevron is the only allowed delight in the system; here it sits
     statically because we're inside a tap halo, not a hover state. */
  .lib-pop__cta {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    margin: 4px 0 0;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 12.5px;
    letter-spacing: 0.04em;
    color: var(--c-ochre);
  }
  .lib-pop__chev {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 14px;
    line-height: 1;
  }

  .lib-pop__invite--tap::after {
    content: "";
    position: absolute;
    inset: 36px 12px 14px;
    border: 3px solid var(--annotation);
    border-radius: 4px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

</style>
