---
/**
 * BookCover — the single V1 cover rendered in one of two layouts.
 *
 * Used at FULL scale on screen VII (Title & cover) and at THUMB scale
 * (via transform: scale on a parent) on screen VI (Global settings).
 * Same component both places — no drift between the picker and the
 * rendered object.
 *
 * Natural size: 320 × 400 px (4:5, a proxy for 8×10 hardcover trim).
 *
 * Layouts:
 *   · plate — sage cloth, HEARTH PRESS eyebrow, tipped-in photo plate
 *     (~58% width), foil italic title + subtitle, Marcellus wordmark
 *     at foot. The classical cloth-bound cookbook.
 *   · bleed — recipe photo fills the cover, scrim gradient bottom-
 *     third for legibility, foil italic title overlaid on the scrim.
 *     Photo-forward alternative.
 */

export type CoverLayout = "plate" | "bleed";

interface Props {
  layout: CoverLayout;
  title: string;
  subtitle?: string;
  photo?: string;         // public-path url; omit for gradient placeholder
  photoTone?: "corn" | "sage" | "ochre";
}

const {
  layout,
  title,
  subtitle,
  photo,
  photoTone = "corn",
} = Astro.props;

const plateStyle = photo ? `background-image: url(${photo})` : "";
---

<article class:list={["cov", `cov--${layout}`, !photo && `cov--tone-${photoTone}`]}>
  {layout === "plate" && (
    <>
      <span class="cov__eyebrow">Hearth Press</span>
      <span class="cov__eyebrow-rule" aria-hidden="true"></span>

      <div class="cov__plate" style={plateStyle} aria-hidden="true"></div>

      <h2 class="cov__title">{title}</h2>
      {subtitle && <p class="cov__subtitle">{subtitle}</p>}

      <div class="cov__wordmark">HEARTH</div>
    </>
  )}

  {layout === "bleed" && (
    <>
      <div class="cov__bleed" style={plateStyle} aria-hidden="true"></div>
      <div class="cov__scrim" aria-hidden="true"></div>
      <div class="cov__bleed-title">
        <h2 class="cov__title cov__title--on-bleed">{title}</h2>
        {subtitle && <p class="cov__subtitle cov__subtitle--on-bleed">{subtitle}</p>}
      </div>
      <div class="cov__wordmark cov__wordmark--on-bleed">HEARTH</div>
    </>
  )}
</article>

<style>
  /* Natural size; parents scale via transform if needed. Aspect-ratio
     lets the cover sit inside a fixed container without distortion. */
  .cov {
    position: relative;
    width: 320px;
    aspect-ratio: 4 / 5;
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
    color: var(--c-ink-inverse);
  }

  /* ─── Plate variant ─────────────────────────────────────────── */

  .cov--plate {
    background: var(--c-conifer);
    display: grid;
    grid-template-rows: auto auto 1fr auto auto auto;
    justify-items: center;
    gap: 12px;
    padding: 28px 24px 26px;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent 0,
        transparent 3px,
        rgba(244, 239, 230, 0.012) 3px,
        rgba(244, 239, 230, 0.012) 4px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 3px,
        rgba(0, 0, 0, 0.03) 3px,
        rgba(0, 0, 0, 0.03) 4px
      );
  }

  .cov__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--c-foil-light);
    margin-top: 4px;
  }
  .cov__eyebrow-rule {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--c-foil);
    opacity: 0.65;
    margin-bottom: 8px;
  }

  .cov__plate {
    width: 58%;
    aspect-ratio: 4 / 5;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    border-radius: var(--r-page);
    box-shadow:
      inset 0 0 0 0.5px rgba(0, 0, 0, 0.35),
      0 3px 8px rgba(0, 0, 0, 0.28);
    margin-top: 4px;
  }
  .cov--tone-corn .cov__plate:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .cov--tone-sage .cov__plate:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .cov--tone-ochre .cov__plate:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }

  .cov__title {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 32px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--c-foil);
    margin: 10px 0 0;
    text-align: center;
    text-shadow: 0 1px 0 rgba(184, 147, 74, 0.08);
  }

  .cov__subtitle {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.3;
    color: var(--c-linen);
    margin: 0;
    text-align: center;
    max-width: 22ch;
    text-wrap: balance;
  }

  .cov__wordmark {
    font-family: var(--f-wordmark);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--c-foil);
    align-self: end;
    opacity: 0.9;
  }

  /* ─── Bleed variant ─────────────────────────────────────────── */

  .cov--bleed {
    background: var(--c-conifer);
  }

  .cov__bleed {
    position: absolute;
    inset: 0;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
  }
  .cov--bleed.cov--tone-corn .cov__bleed:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 40% 40%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .cov--bleed.cov--tone-sage .cov__bleed:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 40% 40%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .cov--bleed.cov--tone-ochre .cov__bleed:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 40% 40%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }

  /* Scrim — bottom-third gradient for title legibility. Not a decorative
     treatment; this is the tokens.css "scrim is hero only" rule honored. */
  .cov__scrim {
    position: absolute;
    inset: 40% 0 0 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.55) 90%
    );
  }

  .cov__bleed-title {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 44px;
    display: grid;
    justify-items: center;
    gap: 8px;
    padding: 0 24px;
  }

  .cov__title--on-bleed {
    color: var(--c-foil);
    font-size: 30px;
  }
  .cov__subtitle--on-bleed {
    color: var(--c-linen);
  }

  .cov__wordmark--on-bleed {
    position: absolute;
    bottom: 16px;
    left: 0;
    right: 0;
    text-align: center;
  }
</style>
