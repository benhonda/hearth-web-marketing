---
/**
 * Flow II · IX · On its way.
 *
 * The sage close — Flow II's back cover. Sibling of WelcomeScreen
 * and BookInvitation — same Deep Conifer cloth, same Antique Foil
 * voice, same cover-grammar. Welcome opens the app, Invitation
 * opens the book flow; this closes the book flow. No CTA; this is
 * terminal by design.
 *
 * Composition:
 *   · Hearth Press letterhead crest at the top
 *   · Foil-stamped Lora italic title centered in the plate
 *   · 44×1.5px foil chapter rule
 *   · Three-line stanza — what happens next, in the cookbook voice
 *   · Quiet "— thank you —" folio at the foot
 */
interface Props { showTap?: boolean; }
---

<div class="oiw">
  <div class="oiw__top">
    <span class="oiw__eyebrow">Hearth Press</span>
    <span class="oiw__rule oiw__rule--short" aria-hidden="true"></span>
  </div>

  <div class="oiw__plate">
    <h1 class="oiw__title">On&nbsp;its way.</h1>
    <span class="oiw__rule oiw__rule--chapter" aria-hidden="true"></span>
    <div class="oiw__stanza">
      <span>We'll email you a proof within the week.</span>
      <span>Review it, send us any changes, and we'll go to press.</span>
    </div>
  </div>

  <div class="oiw__foot">
    <p class="oiw__folio">— thank you —</p>
    <button class="oiw__return" type="button">Return to your library</button>
  </div>
</div>

<style>
  .oiw {
    position: relative;
    width: 100%;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    padding: 74px 36px 46px;
    color: var(--c-ink-inverse);
  }

  /* Letterhead crest — matches Welcome and Invitation exactly so
     the three sage moments read as one cloth. */
  .oiw__top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }
  .oiw__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--c-foil-light);
  }

  .oiw__rule {
    display: block;
    background: var(--c-foil);
    opacity: 0.7;
  }
  .oiw__rule--short {
    width: 28px;
    height: 1px;
  }
  .oiw__rule--chapter {
    width: 44px;
    height: 1.5px;
    opacity: 0.85;
  }

  /* The plate — foil title centered vertically. Shape mirrors the
     Invitation plate, but the title sits a notch smaller because the
     stanza below needs breathing room. */
  .oiw__plate {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 22px;
    text-align: center;
    margin-top: -6%;
  }
  .oiw__title {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 38px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-foil);
    text-wrap: balance;
    margin: 0;
    /* Faint foil-stamp press, same depth as Welcome / Invitation. */
    text-shadow:
      0 1px 0 rgba(184, 147, 74, 0.08),
      0 0 22px rgba(184, 147, 74, 0.08);
  }

  /* Stanza — three thoughts stacked, each its own line. Slightly
     wider measure than Invitation's lede so the last line ("We'll
     be in touch.") lands alone on its line as a closing beat. */
  .oiw__stanza {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-linen);
    max-width: 36ch;
    text-wrap: balance;
  }
  .oiw__stanza > span { display: block; }

  /* Foot — the closing mark + the exit. Folio reads as ceremonial
     sign-off; the return pill gives the user a way home. */
  .oiw__foot {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 16px;
    margin-bottom: 4px;
  }

  /* Folio — centered, bracketed, Lora italic in Foil-Light. Matches
     the folio treatment on cream screens (there it's in Oat); here
     it sits on sage so the token shifts. */
  .oiw__folio {
    margin: 0;
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 12.5px;
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--c-foil-light);
    opacity: 0.85;
  }

  /* Return — Secondary S1 outlined CTA on sage per tokens.css
     §BUTTONS: transparent fill, 1px White-Dove border, pill. Hover
     inverts to filled (White-Dove bg, Warm-Charcoal text). Same
     grammar as the "Continue with Google" pill on Welcome — the
     book-jacket outline voice, tuned to this surface. */
  .oiw__return {
    position: relative;
    display: block;
    width: 100%;
    height: 50px;
    border-radius: 999px;
    background: transparent;
    color: var(--c-ink-inverse);
    border: 1px solid rgba(244, 239, 230, 0.55);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 15px;
    line-height: 1;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background-color var(--motion-state) var(--ease-state),
                color var(--motion-state) var(--ease-state),
                border-color var(--motion-state) var(--ease-state);
  }
  .oiw__return:hover {
    background: var(--c-ink-inverse);
    color: var(--c-ink);
    border-color: var(--c-ink-inverse);
  }
</style>
