---
/**
 * Flow II · VII · Editing a page.
 *
 * Thin wrapper around `BookEdit` — the shared surface that also backs
 * VI (cover) and Flow III · IX (pick a hero). All layout / photos /
 * folio grammar lives in `BookEdit`; this file just supplies the
 * flow-specific defaults (sampleRecipe, 1-photo-a, tap the Done CTA).
 */
import BookEdit from "./BookEdit.astro";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
---

<BookEdit subject="page" showTap={showTap} />
