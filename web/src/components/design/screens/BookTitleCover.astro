---
/**
 * Flow II · VI · Editing the cover.
 *
 * Thin wrapper around `BookEdit` — the shared edit surface that also
 * backs VII (page) and Flow III · IX (pick a hero). Ben's mental
 * model: "the cover is just a page being edited." So the chrome,
 * layout picker, photos picker, and Done grammar are all shared; the
 * only difference is subject="cover" renders `BookCover` in the stage
 * and offers the two cover variants (plate · bleed) in the layout
 * picker.
 */
import BookEdit from "./BookEdit.astro";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
---

<BookEdit subject="cover" showTap={showTap} tapTarget="done" />
