---
/**
 * Throwaway preview — scale-check for the VSCO waterfall at 3 recipes.
 * Not wired into any flow. Used to decide whether the aesthetic works
 * before promoting it into tokens.css and backfilling the system.
 */
import DesignLayout from "~/layouts/DesignLayout.astro";
import ScreenStage from "~/components/design/ScreenStage.astro";
import PhoneFrame from "~/components/design/PhoneFrame.astro";
import AppHeader from "~/components/design/ui/AppHeader.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

type Tone = "corn" | "sage" | "ochre";
type Recipe = { title: string; meta: string; tone: Tone; aspect: string; photo?: string };

// Mixed aspect ratios on purpose — a waterfall only reads as a waterfall
// when tiles stagger. User photos from phones will be just as varied.
const recipes: Recipe[] = [
  { title: sampleRecipe.title, meta: `${sampleRecipe.minutes} min · Serves ${sampleRecipe.serves}`, tone: "corn", aspect: "4 / 5", photo: sampleRecipe.photo },
  { title: "Brown-Butter Gnocchi", meta: "30 min · Serves 2", tone: "sage", aspect: "3 / 4" },
  { title: "Green Curry with Spring Peas", meta: "35 min · Serves 4", tone: "ochre", aspect: "1 / 1" },
];

// Distribute into two columns. Simple alternation keeps it predictable
// at this scale; a real masonry will balance column heights.
const left: Recipe[] = [recipes[0], recipes[2]];
const right: Recipe[] = [recipes[1]];
---

<DesignLayout title="Library · three recipes (preview)">
  <ScreenStage
    eyebrow="Preview · Library at 3"
    title="A library of three."
    note="Scale-check for the waterfall. Varied aspect ratios so the stagger reads; user photos will be equally varied."
  >
    <PhoneFrame surface="cream" variant="single" label="Library preview · three recipes">
      <div class="lib">
        <AppHeader variant="wordmark" eyebrow="A private library" />

        <div class="lib__count">
          <span class="lib__n">3</span>
          <span class="lib__label">recipes</span>
        </div>

        <div class="lib__grid">
          <div class="lib__col">
            {left.map((r) => (
              <a class="tile" href="#">
                <div
                  class={`tile__photo tile__photo--${r.tone}${r.photo ? " tile__photo--image" : ""}`}
                  style={`aspect-ratio: ${r.aspect}${r.photo ? `; background-image: url(${r.photo})` : ""}`}
                  aria-hidden="true"
                ></div>
                <h3 class="tile__title">{r.title}</h3>
                <p class="tile__meta">{r.meta}</p>
              </a>
            ))}
          </div>
          <div class="lib__col">
            {right.map((r) => (
              <a class="tile" href="#">
                <div
                  class={`tile__photo tile__photo--${r.tone}${r.photo ? " tile__photo--image" : ""}`}
                  style={`aspect-ratio: ${r.aspect}${r.photo ? `; background-image: url(${r.photo})` : ""}`}
                  aria-hidden="true"
                ></div>
                <h3 class="tile__title">{r.title}</h3>
                <p class="tile__meta">{r.meta}</p>
              </a>
            ))}
          </div>
        </div>

        <p class="lib__folio">— page one —</p>
      </div>
    </PhoneFrame>
  </ScreenStage>
</DesignLayout>

<style>
  .lib {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    min-height: 100%;
    padding-bottom: 44px;
  }

  .lib__count {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 0 22px;
    margin: 4px 0 18px;
  }
  .lib__n {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    color: var(--c-ochre);
  }
  .lib__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-oat);
  }

  .lib__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding: 0 16px;
    align-self: flex-start;
    width: 100%;
  }

  .lib__col {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 22px;
    align-content: start;
  }

  .tile {
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: inherit;
    text-decoration: none;
    position: relative;
  }

  .tile__photo {
    width: 100%;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.12);
    position: relative;
  }
  .tile__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent 0,
      transparent 1px,
      rgba(0, 0, 0, 0.04) 1px,
      rgba(0, 0, 0, 0.04) 3px
    );
  }
  .tile__photo--corn {
    background: radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .tile__photo--image {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  /* When a real photo is set, suppress the diagonal-hash scrim used for
     placeholder gradients — it reads as a printing-plate texture there
     but as noise over actual photography. */
  .tile__photo--image::after { display: none; }
  .tile__photo--sage {
    background: radial-gradient(ellipse at 30% 30%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .tile__photo--ochre {
    background: radial-gradient(ellipse at 30% 30%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }

  .tile__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 13.5px;
    line-height: 1.25;
    letter-spacing: -0.003em;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }

  .tile__meta {
    font-family: var(--f-body);
    font-size: 10.5px;
    line-height: 1.3;
    color: var(--c-ash);
    letter-spacing: 0.02em;
    margin: 0;
  }

  .lib__folio {
    align-self: flex-end;
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 12.5px;
    color: var(--c-ochre);
    letter-spacing: 0.02em;
    padding-bottom: 8px;
  }
</style>
