---
/**
 * Flow III · V · Recipe · detail, carousel.
 *
 * The quiet pivot after the photos land. The hero band is the same
 * physical space as the one-photo detail — full-width, 5:4 — but now
 * it's a snap-scrollable strip. Photos paginate in full-bleed; a small
 * counter pill ('1 / 3') sits bottom-right on whichever photo is in
 * view. Realtor / Airbnb grammar — the count tells you there's more,
 * the tap opens the gallery.
 *
 * Title / lede / ingredients / method stay exactly where they were.
 * The only signal the page changed is the folio at the foot — "page 1
 * · version iii" — carrying the book-spine test forward.
 *
 * At rest in the binder we show slot 1 (the Mia Aquilina hero). A real
 * build would snap-scroll; for the mock, we just paint the first slide.
 */
import AppHeader from "../ui/AppHeader.astro";
import IngredientsList from "../ui/IngredientsList.astro";
import MethodList from "../ui/MethodList.astro";
import { sampleRecipe, recipePhotosAfter } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const totalPhotos = recipePhotosAfter.length;
---

<div class="detail">
  <AppHeader variant="title" title="" />

  <div
    class:list={["carousel", showTap && "carousel--tap"]}
    role="button"
    aria-label="Open photo gallery"
    tabindex="0"
  >
    <ol class="carousel__track" role="list">
      {recipePhotosAfter.map((src, i) => (
        <li
          class="carousel__slide"
          role="listitem"
          aria-hidden={i !== 0}
          style={`background-image: url(${src})`}
        >
          {i === 0 && (
            <span class="carousel__credit">photograph · Mia Aquilina</span>
          )}
        </li>
      ))}
    </ol>

    <span class="carousel__counter" aria-hidden="true">
      <span class="carousel__counter-num">1</span>
      <span class="carousel__counter-sep">/</span>
      <span class="carousel__counter-den">{totalPhotos}</span>
    </span>
  </div>

  <div class="detail__body">
    <span class="detail__source">From {sampleRecipe.source}</span>
    <h1 class="detail__title">{sampleRecipe.title}</h1>
    <p class="detail__lede">{sampleRecipe.lede}</p>
    <p class="detail__meta">
      <em>Serves {sampleRecipe.serves}</em>
      <span aria-hidden="true"> · </span>
      <em>{sampleRecipe.minutes} minutes</em>
      <span aria-hidden="true"> · </span>
      <em>One pan</em>
    </p>

    <hr class="detail__rule" />

    <IngredientsList items={sampleRecipe.ingredients} />

    <hr class="detail__rule" />

    <MethodList items={sampleRecipe.method} />

    <p class="detail__folio">— page 1 · version iii —</p>
  </div>
</div>

<style>
  .detail {
    display: grid;
    grid-template-rows: auto auto 1fr;
    min-height: 100%;
    padding-bottom: 44px;
  }

  /* Carousel ───────────────────────────────────────────── */

  .carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background-color: var(--c-oat);
  }

  .carousel__track {
    display: flex;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .carousel__track::-webkit-scrollbar { display: none; }

  .carousel__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    scroll-snap-align: start;
  }
  .carousel__slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 62%, rgba(0, 0, 0, 0.34) 100%);
  }

  .carousel__credit {
    position: absolute;
    bottom: 10px;
    left: 14px;
    font-family: var(--f-body);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
    z-index: 1;
  }

  /* Counter pill — visual indicator only. The whole image is the
     tap target (realtor / Airbnb grammar); the pill just signals
     "there's more." */
  .carousel__counter {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    padding: 6px 12px;
    background: rgba(20, 16, 12, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #fff;
    border-radius: 999px;
    font-family: var(--f-body);
    font-size: 11.5px;
    letter-spacing: 0.02em;
    pointer-events: none;
    z-index: 2;
  }
  .carousel__counter-num { font-weight: 500; }
  .carousel__counter-sep { opacity: 0.6; }
  .carousel__counter-den { opacity: 0.85; }

  /* Halo wraps the whole image — tapping anywhere on the carousel
     opens the gallery. Inset slightly so the halo reads as a frame
     around the photo without bleeding over its edges. */
  .carousel--tap::after {
    content: "";
    position: absolute;
    inset: 6px;
    border: 3px solid var(--annotation);
    border-radius: 2px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* Body ───────────────────────────────────────────────── */

  .detail__body {
    padding: 22px 24px 18px;
    display: grid;
    gap: 10px;
  }

  .detail__source {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .detail__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 30px;
    line-height: 1.08;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  .detail__lede {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--c-ash);
    max-width: 36ch;
    margin-top: 2px;
  }

  .detail__meta {
    font-family: var(--f-display);
    font-size: 13px;
    color: var(--c-ash);
    margin-top: 4px;
  }
  .detail__meta em {
    font-style: italic;
    color: var(--c-ink);
  }

  .detail__rule {
    border: 0;
    height: 1px;
    background: rgba(31, 27, 23, 0.1);
    margin: 12px 0;
  }

  .detail__folio {
    margin-top: 22px;
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 12px;
    color: var(--c-ochre);
    letter-spacing: 0.02em;
  }
</style>
