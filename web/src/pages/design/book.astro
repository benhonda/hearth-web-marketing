---
/**
 * /design/book — the iteration surface for the cookbook's rendered
 * object. Imports the SAME BookCover + BookPage components that the
 * flow mockups use (Preview, PageEdit, Layout picker); any change to
 * those internals shows up here at full natural 320×400 and in every
 * downstream scaled use without drift.
 *
 * Two sections: Cover (plate + bleed) and Page (the six V1 layouts).
 * Each specimen is full-scale so typography and rhythm can be judged
 * honestly; the flow pages render the same components scaled down.
 *
 * See README → "Real page & cover layouts" TODO. This page is where
 * items 1–6 of that note get worked.
 */
import DesignLayout from "~/layouts/DesignLayout.astro";
import BookCover, { type CoverLayout } from "~/components/design/ui/BookCover.astro";
import BookPage, { type PageLayout } from "~/components/design/ui/BookPage.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

const covers: { layout: CoverLayout; label: string; note: string }[] = [
  {
    layout: "plate",
    label: "plate",
    note: "Sage cloth, Antique Foil wordmark, tipped-in photo plate. The classical cloth-bound cookbook.",
  },
  {
    layout: "bleed",
    label: "bleed",
    note: "Recipe photo fills the cover; scrim gradient carries the foil title. Photo-forward.",
  },
];

const pages: { layout: PageLayout; label: string; bucket: string; note: string }[] = [
  { layout: "1-photo-a",  label: "1-photo-a",  bucket: "1 photo",   note: "Photo top (45%), text below." },
  { layout: "1-photo-b",  label: "1-photo-b",  bucket: "1 photo",   note: "Text top, photo bottom (45%)." },
  { layout: "2-photos-a", label: "2-photos-a", bucket: "2 photos",  note: "Two photos side-by-side on top (35%), text below." },
  { layout: "2-photos-b", label: "2-photos-b", bucket: "2 photos",  note: "Photo top (28%), text middle, photo bottom (24%) — bookend." },
  { layout: "3-plus-a",   label: "3-plus-a",   bucket: "3+ photos", note: "Two-by-two photo grid top, text below." },
  { layout: "3-plus-b",   label: "3-plus-b",   bucket: "3+ photos", note: "Three-photo horizontal strip on top, text below." },
];

const coverTitle = "For Us.";
const coverSubtitle = "A year at the table.";

/* ─────────────────────────────────────────────────────────────
   Exploration-only assets. Unsplash CDN URLs — not bundled, not
   production. These mockups are sketches; the real flow still
   consumes BookCover / BookPage with the two approved covers and
   six approved page layouts. Winners here get promoted later.
   ───────────────────────────────────────────────────────────── */
const U = {
  plate:    "https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=800&auto=format&fit=crop&q=80",
  pasta:    "https://images.unsplash.com/photo-1473093295043-cdd812d0e601?w=800&auto=format&fit=crop&q=80",
  bread:    "https://images.unsplash.com/photo-1509440159596-0249088772ff?w=800&auto=format&fit=crop&q=80",
  salad:    "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800&auto=format&fit=crop&q=80",
  moody:    "https://images.unsplash.com/photo-1432139555190-58524dae6a55?w=800&auto=format&fit=crop&q=80",
  kitchen:  "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&auto=format&fit=crop&q=80",
  table:    "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&auto=format&fit=crop&q=80",
  portrait: "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=800&auto=format&fit=crop&q=80",
};

/* Short essay used by the Pasta-style `spread-story` concept. Three
   short paragraphs drive the left-page density; kept inline here
   rather than in sample-recipe.ts because it's exploration-only. */
const sampleEssay = [
  "Corn in August is everything July's corn pretended to be — sweeter, heavier, almost guilty on the tongue. The trick to a ragù like this one is knowing when to walk away from the pan. Too long and the kernels collapse into porridge; too short and they bite.",
  "We make this on evenings when the farmers' market has overshot the week's intended plan. There's always a shallot knocking around somewhere. A glass of dry wine fixes the rest.",
  "The miso isn't authenticity-breaking — it finishes the stock with a quiet funk that reads as depth, not seasoning. Salt lightly, then pepper aggressively.",
];
---

<DesignLayout title="Book">
  <div class="book-ws">
    <header class="book-ws__masthead">
      <p class="eyebrow">Hearth Press · Book layouts v1</p>
      <hr class="rule" aria-hidden="true" />
      <h1 class="book-ws__title">The rendered object.</h1>
      <p class="lede">
        The two covers and six page layouts that appear throughout Flow II,
        rendered at natural 320 × 400 so typography and rhythm can be judged
        honestly. These are the same <code>BookCover</code> and <code>BookPage</code>
        components the flow mockups consume — improvements here propagate
        automatically to Preview, Page-edit, and the Layout picker.
      </p>
      <div class="book-ws__meta">
        <span>Last revised 2026-04</span>
        <span aria-hidden="true">·</span>
        <a class="link--chevron" href="/design">Back to binder</a>
      </div>
    </header>

    {/* ───────── Cover ───────── */}
    <section class="spec" id="cover">
      <div class="spec__head">
        <p class="eyebrow">Cover · 320 × 400 · 4:5</p>
        <hr class="rule" aria-hidden="true" />
        <h2 class="spec__title">Two covers — plate and bleed.</h2>
        <p class="lede">
          V1 ships two covers. Plate is the classical cloth-bound cookbook
          with a tipped-in photo; bleed is the photo-forward alternative for
          users whose hero image is the point. Everything beyond these
          (typographic-only, cloth jackets, foil/emboss) is V2 — see README
          item 6.
        </p>
      </div>

      <div class="spec__body book-ws__covers">
        {covers.map((c) => (
          <figure class="specimen">
            <div class="specimen__stage">
              <BookCover
                layout={c.layout}
                title={coverTitle}
                subtitle={coverSubtitle}
                photo={sampleRecipe.photo}
              />
            </div>
            <figcaption class="specimen__cap">
              <p class="specimen__label">
                <code>{c.label}</code>
              </p>
              <p class="specimen__note">{c.note}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    {/* ───────── Pages ───────── */}
    <section class="spec" id="page">
      <div class="spec__head">
        <p class="eyebrow">Page · 320 × 400 · 4:5</p>
        <hr class="rule" aria-hidden="true" />
        <h2 class="spec__title">Six page layouts — one per photo-count bucket, two variants each.</h2>
        <p class="lede">
          One recipe, six layouts. Text content is identical across all six —
          only photo placement varies. The global-settings picker lets the
          user choose one layout per bucket (1 / 2 / 3+); per-page overrides
          (screen VIII) swap within a bucket. Slots 1+ in the multi-photo
          layouts show gradient placeholders today; see README item 4.
        </p>
      </div>

      <div class="spec__body book-ws__pages">
        {pages.map((p) => (
          <figure class="specimen">
            <div class="specimen__stage">
              <BookPage layout={p.layout} recipe={sampleRecipe} />
            </div>
            <figcaption class="specimen__cap">
              <p class="specimen__label">
                <code>{p.label}</code>
                <span class="specimen__bucket">{p.bucket}</span>
              </p>
              <p class="specimen__note">{p.note}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    {/* ───────── Explorations ───────── */}
    <section class="spec spec--exp" id="explorations">
      <div class="spec__head">
        <p class="eyebrow">Explorations · 2026-04 · sketches</p>
        <hr class="rule" aria-hidden="true" />
        <h2 class="spec__title">Sketches — concepts to triage.</h2>
        <p class="lede">
          Inline mockups only; nothing here is wired into <code>BookCover</code>
          or <code>BookPage</code> yet. Most will get scrapped — that's the
          point of the sketchbook. Winners get promoted to real layouts.
          Photos are Unsplash placeholders.
        </p>
      </div>

      {/* ─── Cover concepts ─── */}
      <div class="exp-group">
        <header class="exp-group__head">
          <h3 class="exp-group__title">Cover concepts <span class="exp-group__count">· seven</span></h3>
          <p class="exp-group__note">All at natural 320 × 400. Reference in caption ties each back to the inspiration plate.</p>
        </header>

        <div class="exp-rows">
          {/* 1 ─ title-top */}
          <article class="exp-row exp-row--cover">
            <figure class="exp-row__insp">
              <img src="/insp/covers/magnolia-table.png" alt="Magnolia Table cover" loading="lazy" />
              <figcaption>Magnolia Table · Joanna Gaines</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <article class="xc xc--title-top">
                  <span class="xc__eyebrow">Hearth Press</span>
                  <span class="xc__eyebrow-rule" aria-hidden="true"></span>
                  <h4 class="xc__title">{coverTitle}</h4>
                  <p class="xc__subtitle">{coverSubtitle}</p>
                  <div class="xc__plate" style={`background-image:url(${U.plate})`} aria-hidden="true"></div>
                  <div class="xc__author xc__author--serif">Ben Honda</div>
                </article>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>title-top</code><span class="specimen__bucket">ref · Magnolia Table</span></p>
                <p class="specimen__note">Title lives above the plate; author at foot. Sibling of <code>plate</code>.</p>
              </figcaption>
            </figure>
          </article>

          {/* 2 ─ italian */}
          <article class="exp-row exp-row--cover">
            <figure class="exp-row__insp">
              <img src="/insp/covers/italian-summer.png" alt="Italian Summer cover" loading="lazy" />
              <figcaption>Italian Summer · Natalie Obradovich</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <article class="xc xc--italian">
                  <div class="xc__plate xc__plate--sm" style={`background-image:url(${U.table})`} aria-hidden="true"></div>
                  <h4 class="xc__bigtype">FOR<br/>US.</h4>
                  <p class="xc__tag">Ben Honda</p>
                </article>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>italian</code><span class="specimen__bucket">ref · Italian Summer</span></p>
                <p class="specimen__note">Tiny plate, enormous stacked serif caps title below.</p>
              </figcaption>
            </figure>
          </article>

          {/* 3 ─ window */}
          <article class="exp-row exp-row--cover">
            <figure class="exp-row__insp">
              <img src="/insp/covers/home-therapy.png" alt="Home Therapy cover" loading="lazy" />
              <figcaption>Home Therapy · Anita Yokota</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <article class="xc xc--window">
                  <h4 class="xc__title xc__title--left">{coverTitle}</h4>
                  <p class="xc__sub xc__sub--left">{coverSubtitle}</p>
                  <div class="xc__win" style={`background-image:url(${U.kitchen})`} aria-hidden="true"></div>
                  <div class="xc__author xc--ink">Ben Honda</div>
                </article>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>window</code><span class="specimen__bucket">ref · Home Therapy</span></p>
                <p class="specimen__note">Warm-cream ground, italic title top-left, windowed photo in the bottom ⅔.</p>
              </figcaption>
            </figure>
          </article>

          {/* 4 ─ display */}
          <article class="exp-row exp-row--cover">
            <figure class="exp-row__insp">
              <img src="/insp/covers/joie.png" alt="Joie cover" loading="lazy" />
              <figcaption>Joie · Ajiri Aki</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <article class="xc xc--display">
                  <h4 class="xc__display">For Us.</h4>
                  <div class="xc__plate xc__plate--joie" style={`background-image:url(${U.portrait})`} aria-hidden="true"></div>
                  <p class="xc__displaySub">A YEAR AT THE TABLE</p>
                  <p class="xc__displayAuthor">Ben Honda</p>
                </article>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>display</code><span class="specimen__bucket">ref · Joie</span></p>
                <p class="specimen__note">Oversized accent-color title up top, photo plate centered, tagline + author foot. Hero is the type; plate grounds it.</p>
              </figcaption>
            </figure>
          </article>

          {/* 5 ─ minimal */}
          <article class="exp-row exp-row--cover">
            <figure class="exp-row__insp">
              <img src="/insp/covers/sunday-suppers.png" alt="Sunday Suppers cover" loading="lazy" />
              <figcaption>Sunday Suppers · Karen Mordechai</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <article class="xc xc--minimal">
                  <div class="xc__plate xc__plate--40" style={`background-image:url(${U.moody})`} aria-hidden="true"></div>
                  <p class="xc__tracked">FOR · US</p>
                  <p class="xc__tracked xc__tracked--small">A YEAR · AT THE TABLE</p>
                  <div class="xc__wordmark xc--ink">HEARTH</div>
                </article>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>minimal</code><span class="specimen__bucket">ref · Sunday Suppers</span></p>
                <p class="specimen__note">Linen ground, small plate, tiny letterspaced caps title. Maximum air.</p>
              </figcaption>
            </figure>
          </article>

          {/* 6 ─ typographic */}
          <article class="exp-row exp-row--cover">
            <figure class="exp-row__insp">
              <img src="/insp/covers/surf-tribe.png" alt="Surf Tribe cover" loading="lazy" />
              <figcaption>Surf Tribe · Stephan Vanfleteren</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <article class="xc xc--typo">
                  <h4 class="xc__stack">FOR<br/>US.</h4>
                  <p class="xc__tag">Ben Honda</p>
                  <div class="xc__wordmark">HEARTH PRESS</div>
                </article>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>typographic</code><span class="specimen__bucket">ref · Surf Tribe · README V2</span></p>
                <p class="specimen__note">Pure-type cloth cover. README has this as V2 — sketching it so we can see it.</p>
              </figcaption>
            </figure>
          </article>

          {/* 7 ─ art-of-home */}
          <article class="exp-row exp-row--cover">
            <figure class="exp-row__insp">
              <img src="/insp/covers/the-art-of-home.png" alt="The Art of Home cover" loading="lazy" />
              <figcaption>The Art of Home · Shea McGee</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <article class="xc xc--art">
                  <h4 class="xc__artTitle">For <em>Us.</em></h4>
                  <div class="xc__plate xc__plate--55" style={`background-image:url(${U.portrait})`} aria-hidden="true"></div>
                  <p class="xc__sub xc--ink"><em>Written by</em> Ben Honda</p>
                </article>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>art-of-home</code><span class="specimen__bucket">ref · The Art of Home</span></p>
                <p class="specimen__note">Restrained, near-white sibling of <code>plate</code>. Italic title small at top.</p>
              </figcaption>
            </figure>
          </article>
        </div>
      </div>

      {/* ─── Spread concepts (facing pages, 640×400) ─── */}
      <div class="exp-group">
        <header class="exp-group__head">
          <h3 class="exp-group__title">Spread concepts <span class="exp-group__count">· six</span></h3>
          <p class="exp-group__note">Facing pages, 640 × 400. Gutter down the middle. These ask whether V2 should let spreads compose as pairs, not just single pages.</p>
        </header>

        <div class="exp-rows">
          {/* 1 ─ spread-photo-facing */}
          <article class="exp-row exp-row--spread">
            <figure class="exp-row__insp">
              <img src="/insp/spreads/french-laundry.png" alt="The French Laundry spread" loading="lazy" />
              <figcaption>The French Laundry · photo-facing recipe spread</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <div class="xs">
                  <div class="xs__page xs__page--L xs__bleed" style={`background-image:url(${sampleRecipe.photo})`} aria-hidden="true">
                    <span class="xs__rail">I · SUPPERS</span>
                  </div>
                  <div class="xs__gutter" aria-hidden="true"></div>
                  <div class="xs__page xs__page--R">
                    <h4 class="xs__title">{sampleRecipe.title}</h4>
                    <p class="xs__meta">{sampleRecipe.minutes} min · Serves {sampleRecipe.serves}</p>
                    <div class="xs__rbody">
                      <div>
                        <span class="xs__label">Ingredients</span>
                        <ul class="xs__ul">
                          {sampleRecipe.ingredients.slice(0, 6).map((ing) => <li>{ing}</li>)}
                        </ul>
                      </div>
                      <div>
                        <span class="xs__label">Method</span>
                        <ol class="xs__ol">
                          {sampleRecipe.method.slice(0, 4).map((step, i) => {
                            const roman = ["i", "ii", "iii", "iv"][i];
                            return (<li><span class="xs__roman">{roman}.</span><span>{step.text}</span></li>);
                          })}
                        </ol>
                      </div>
                    </div>
                    <p class="xs__folio">— 42 —</p>
                  </div>
                </div>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>spread-photo-facing</code><span class="specimen__bucket">640 × 400 · French Laundry</span></p>
                <p class="specimen__note">Photo full-bleeds the left page. Right page carries the full recipe.</p>
              </figcaption>
            </figure>
          </article>

          {/* 2 ─ spread-classic (Magnolia Truffle Butter Rolls match) */}
          <article class="exp-row exp-row--spread">
            <figure class="exp-row__insp">
              <img src="/insp/spreads/magnolia-table.png" alt="Magnolia Table Truffle Butter Rolls spread" loading="lazy" />
              <figcaption>Magnolia Table · Truffle Butter Rolls — photo-left, classical recipe-right.</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <div class="xs">
                  <div class="xs__page xs__page--L xs__bleed" style={`background-image:url(${U.bread})`} aria-hidden="true"></div>
                  <div class="xs__gutter" aria-hidden="true"></div>
                  <div class="xs__page xs__page--R xs__page--classic">
                    <header class="xs__classicHead">
                      <h4 class="xs__classicTitle">{sampleRecipe.title}</h4>
                      <p class="xs__classicMeta">SERVES {sampleRecipe.serves} · {sampleRecipe.minutes} MIN · WEEKNIGHT</p>
                    </header>
                    <p class="xs__classicLede">{sampleRecipe.lede}</p>
                    <div class="xs__classicBody">
                      <div class="xs__classicIng">
                        <span class="xs__label">Ingredients</span>
                        <ul class="xs__ul">
                          {sampleRecipe.ingredients.slice(0, 7).map((ing) => <li>{ing}</li>)}
                        </ul>
                      </div>
                      <div class="xs__classicMethod">
                        {sampleRecipe.method.slice(0, 5).map((step) => (
                          <p>{step.text}</p>
                        ))}
                      </div>
                    </div>
                    <p class="xs__folio">— 12 —</p>
                  </div>
                </div>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>spread-classic</code><span class="specimen__bucket">640 × 400 · Magnolia Truffle</span></p>
                <p class="specimen__note">Photo full-bleeds the left page. Right page runs classical recipe: centered italic title, tracked-caps meta, italic lede, narrow ingredients column + prose method.</p>
              </figcaption>
            </figure>
          </article>

          {/* 3 ─ spread-chapter-opener */}
          <article class="exp-row exp-row--spread">
            <figure class="exp-row__insp">
              <img src="/insp/spreads/magnolia-table-3.png" alt="Magnolia Table Appetizers & Starters chapter opener" loading="lazy" />
              <figcaption>Magnolia Table · Appetizers &amp; Starters (chapter opener)</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <div class="xs">
                  <div class="xs__page xs__page--L xs__bleed xs__bleed--dark" style={`background-image:url(${U.moody})`} aria-hidden="true">
                    <span class="xs__rail">CHAPTER · III</span>
                    <div class="xs__chap-wrap">
                      <p class="xs__chap-eyebrow">Chapter three</p>
                      <h4 class="xs__chap-title">Suppers</h4>
                    </div>
                  </div>
                  <div class="xs__gutter" aria-hidden="true"></div>
                  <div class="xs__page xs__page--R xs__page--epigraph">
                    <p class="xs__epi">
                      <em>"The best thing any of us can do with an evening is feed the people we love."</em>
                    </p>
                    <p class="xs__epi-attr">— Ben</p>
                  </div>
                </div>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>spread-chapter-opener</code><span class="specimen__bucket">640 × 400 · Magnolia-3</span></p>
                <p class="specimen__note">Moody full-bleed left with foil chapter title; epigraph floats centered on cream right.</p>
              </figcaption>
            </figure>
          </article>

          {/* 4 ─ spread-quote */}
          <article class="exp-row exp-row--spread">
            <figure class="exp-row__insp">
              <img src="/insp/spreads/magnolia-table-2.png" alt="Magnolia Table photo + pullquote spread" loading="lazy" />
              <figcaption>Magnolia Table · kitchen + pullquote spread</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <div class="xs">
                  <div class="xs__page xs__page--L xs__bleed" style={`background-image:url(${U.kitchen})`} aria-hidden="true"></div>
                  <div class="xs__gutter" aria-hidden="true"></div>
                  <div class="xs__page xs__page--R xs__page--quote">
                    <p class="xs__pull">
                      <em>Fine details, shifts in flavor — every meal and moment can become what we make of it.</em>
                    </p>
                    <p class="xs__pull-attr">HEARTH · I</p>
                  </div>
                </div>
              </div>
              <figcaption class="specimen__cap">
                <p class="specimen__label"><code>spread-quote</code><span class="specimen__bucket">640 × 400 · Magnolia-2</span></p>
                <p class="specimen__note">Full-bleed portrait on left; pullquote floats on the cream right page. A narrative break between recipes.</p>
              </figcaption>
            </figure>
          </article>

          {/* 5 ─ spread-story (Pasta match — story left, recipe right) */}
          <article class="exp-row exp-row--spread">
            <figure class="exp-row__insp">
              <img src="/insp/spreads/pasta.png" alt="Pasta recipe spread" loading="lazy" />
              <figcaption>Pasta spread · story-left, photo + recipe-right</figcaption>
            </figure>
            <figure class="specimen exp-row__work">
              <div class="specimen__stage">
                <div class="xs">
                  <div class="xs__page xs__page--L xs__page--storyL">
                    <h4 class="xs__storyTitle">{sampleRecipe.title}</h4>
                    {sampleEssay.map((para) => <p class="xs__storyPara">{para}</p>)}
                    <p class="xs__folio">— 88 —</p>
                  </div>
                  <div class="xs__gutter" aria-hidden="true"></div>
                  <div class="xs__page xs__page--R xs__page--storyR">
                    <div class="xs__storyHero" style={`background-image:url(${sampleRecipe.photo})`} aria-hidden="true"></div>
                    <p class="xs__storyMeta">SERVES {sampleRecipe.serves} · {sampleRecipe.minutes} MIN</p>
                    <div class="xs__storyBody">
