---
import "~/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Hearth Press — A beautiful home for your recipes.",
  description = "Save every recipe you love. When the occasion calls for it, turn your library into a premium hardcover cookbook.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2f4a3c" />

    <title>{title}</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Hearth Press" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
