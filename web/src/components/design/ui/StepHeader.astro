---
/**
 * StepHeader — the chapter-mark pattern for multi-step forms. Used on
 * Flow II screens III–VI (The occasion / The dedication / The recipes /
 * Review). Matches the canonical long-form rhythm from tokens.css:
 *   chapter-mark → rule → title → lede
 *
 * `step` is the Roman numeral caps label for the eyebrow ("I", "II",
 * "III", "IV"). The in-screen eyebrow renders it as "Step I" in small
 * caps with the wide tracking that signals cookbook-mark, not generic
 * UI label.
 */

interface Props {
  step: string;      // "I" | "II" | "III" | "IV"
  title: string;     // "The occasion"
  lede?: string;     // "What are we making this for?"
}

const { step, title, lede } = Astro.props;
---

<header class="step-header">
  <span class="step-header__eyebrow">Step {step}</span>
  <hr class="step-header__rule" aria-hidden="true" />
  <h1 class="step-header__title">{title}.</h1>
  {lede && <p class="step-header__lede">{lede}</p>}
</header>

<style>
  .step-header {
    display: grid;
    justify-items: center;
    gap: 10px;
    text-align: center;
    padding: 8px 22px 20px;
  }

  .step-header__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .step-header__rule {
    border: 0;
    width: var(--rule-chapter);
    height: var(--rule-weight-chapter);
    background: var(--c-ochre);
    margin: 4px 0 2px;
  }

  .step-header__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }

  .step-header__lede {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
    color: var(--c-ash);
    max-width: 32ch;
    text-wrap: balance;
    margin: 2px 0 0;
  }
</style>
