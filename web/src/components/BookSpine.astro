---
/**
 * Typographic hardcover spine — vertical companion to HeroBook.
 * Same cloth-weave sage surface, foil rules, and Marcellus wordmark.
 * Wordmark runs top-to-bottom (US/UK convention — reads correctly when
 * the book lies face-up with spine facing the viewer).
 */
---

<figure class="spine" aria-hidden="true">
  <div class="spine__cloth">
    <div class="spine__weave"></div>
    <span class="spine__mark">HEARTH</span>
  </div>
  <figcaption class="sr">Sage-cloth spine stamped HEARTH in Antique Foil near the foot.</figcaption>
</figure>

<style>
  .spine {
    position: relative;
    margin: 0;
    /* Hardcover spine — narrow and tall, 1:10 aspect feels right */
    aspect-ratio: 1 / 10;
    width: 100%;
    max-width: 3.75rem;
    filter: drop-shadow(0 24px 36px rgba(20, 14, 4, 0.38))
      drop-shadow(0 4px 10px rgba(20, 14, 4, 0.22));
  }

  .spine__cloth {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--c-conifer);
    border-radius: 2px;
    overflow: hidden;
    /* Inner rim echoes the cover treatment */
    box-shadow:
      inset 0 0 0 1px rgba(244, 239, 230, 0.03),
      inset 0 0 30px 6px rgba(0, 0, 0, 0.22);
    /* Mark sits at the foot — publisher's-stamp placement */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 1.25rem;
  }

  /* Cloth weave — mirrored from HeroBook */
  .spine__weave {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent 0,
        transparent 2px,
        rgba(244, 239, 230, 0.018) 2px,
        rgba(244, 239, 230, 0.018) 3px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 2px,
        rgba(0, 0, 0, 0.05) 2px,
        rgba(0, 0, 0, 0.05) 3px
      );
    mix-blend-mode: overlay;
    opacity: 0.9;
  }

  .spine__mark {
    font-family: var(--f-wordmark);
    font-weight: 400;
    font-size: clamp(1rem, 1.6vw, 1.3rem);
    letter-spacing: 0.25em;
    line-height: 1;
    color: var(--c-foil);
    /* Vertical reading — top-to-bottom */
    writing-mode: vertical-rl;
    text-orientation: mixed;
    padding-block: 0.4em;
    /* Foil-stamp impression */
    text-shadow:
      1px 0 0 rgba(244, 239, 230, 0.18),
      -1px 0 0 rgba(0, 0, 0, 0.35);
  }

  .sr {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
