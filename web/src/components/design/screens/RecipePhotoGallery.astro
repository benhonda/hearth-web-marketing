---
/**
 * Flow III · VI · Photo gallery.
 *
 * Airbnb / realtor grammar — tap the counter on the carousel, the
 * detail page dissolves to a full-screen vertical photo viewer. No
 * app chrome beyond a close button; the photos speak.
 *
 * Photos stack top-to-bottom at their natural aspect ratios on cream,
 * with a small gutter between — same "page color through a seam"
 * grammar as the mosaic had. In the binder we show the first photo
 * full + the top of the second peeking in beneath, so the storyboard
 * reads as "scroll for more" without motion.
 *
 * The close chevron top-left is the handoff. In product it returns to
 * the detail page; in the flow it hands off to the library directly
 * (two hops compressed to one).
 */
import { recipePhotosAfter } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

// Natural aspect ratios for the three photos. The commissioned hero is
// 5:4 (matching the carousel); the two phone snaps get 4:3 landscape —
// plausible iPhone crops.
const galleryPhotos = [
  { src: recipePhotosAfter[0], aspect: "5 / 4" },
  { src: recipePhotosAfter[1], aspect: "4 / 3" },
  { src: recipePhotosAfter[2], aspect: "4 / 3" },
];
---

<div class="gallery">
  <header class="gallery__chrome">
    <button
      class={showTap ? "gallery__close gallery__close--tap" : "gallery__close"}
      type="button"
      aria-label="Close"
    >
      <svg viewBox="0 0 20 20" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
        <path d="M5 5l10 10M15 5L5 15" />
      </svg>
    </button>
    <span class="gallery__count">1 of {galleryPhotos.length}</span>
    <span class="gallery__spacer" aria-hidden="true" />
  </header>

  <div class="gallery__scroll" role="list">
    {galleryPhotos.map((photo, i) => (
      <figure
        class="gallery__photo"
        role="listitem"
        style={`aspect-ratio: ${photo.aspect};`}
      >
        <div
          class="gallery__img"
          style={`background-image: url(${photo.src})`}
          aria-hidden="true"
        />
        {i === 0 && (
          <figcaption class="gallery__credit">
            photograph · Mia Aquilina
          </figcaption>
        )}
      </figure>
    ))}
  </div>
</div>

<style>
  .gallery {
    position: relative;
    width: 100%;
    min-height: 100%;
    background: var(--c-cream, #F5EFE5);
    display: grid;
    grid-template-rows: auto 1fr;
    padding-top: 62px; /* status bar */
  }

  /* Chrome — just close + count. No title, no share. */
  .gallery__chrome {
    display: grid;
    grid-template-columns: 44px 1fr 44px;
    align-items: center;
    padding: 4px 16px 12px;
  }

  .gallery__close {
    position: relative;
    justify-self: flex-start;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: rgba(31, 27, 23, 0.06);
    border: 0;
    display: grid;
    place-items: center;
    color: var(--c-ink);
    cursor: pointer;
  }
  .gallery__close--tap::after {
    content: "";
    position: absolute;
    inset: -5px;
    border: 3px solid var(--annotation);
    border-radius: 999px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  .gallery__count {
    justify-self: center;
    font-family: var(--f-body);
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-ash);
  }

  .gallery__spacer { width: 36px; height: 1px; }

  /* Photo stack — cream gutter (3px) between, reads as seam. */
  .gallery__scroll {
    display: grid;
    gap: 3px;
    padding: 2px 0 0;
    align-content: start;
  }

  .gallery__photo {
    position: relative;
    margin: 0;
    background: var(--c-oat);
    overflow: hidden;
  }

  .gallery__img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .gallery__credit {
    position: absolute;
    bottom: 10px;
    right: 14px;
    font-family: var(--f-body);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    z-index: 1;
  }
</style>
