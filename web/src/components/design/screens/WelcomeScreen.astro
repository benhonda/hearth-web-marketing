---
/**
 * Screen I · Welcome — the cover.
 * Sage surface + Antique Foil wordmark + italic Lora tagline + two auth pills.
 * Designed to read as "the front cover of a book."
 */
interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
---

<div class="welcome">
  <div class="welcome__top">
    <span class="welcome__eyebrow">Hearth Press</span>
    <span class="welcome__rule" />
  </div>

  <div class="welcome__mark">
    <div class="welcome__wordmark">HEARTH</div>
    <p class="welcome__tagline">
      A beautiful home<br />for your recipes.
    </p>
  </div>

  <div class="welcome__foot">
    <button class={showTap ? "auth-pill auth-pill--apple auth-pill--tap" : "auth-pill auth-pill--apple"} type="button">
      <svg class="auth-pill__icon" viewBox="0 0 14 17" width="14" height="17" fill="currentColor" aria-hidden="true">
        <path d="M11.04 8.95c-.02-2.05 1.67-3.04 1.75-3.09-.95-1.39-2.44-1.58-2.97-1.6-1.26-.13-2.47.74-3.11.74-.65 0-1.64-.72-2.69-.7-1.38.02-2.67.8-3.38 2.04-1.44 2.5-.37 6.2 1.04 8.23.69.99 1.5 2.1 2.56 2.06 1.03-.04 1.42-.67 2.66-.67 1.24 0 1.59.67 2.68.65 1.11-.02 1.81-1.01 2.48-2 .78-1.14 1.1-2.25 1.12-2.31-.02-.01-2.14-.82-2.16-3.26zM9.09 2.9c.56-.68.94-1.63.84-2.58-.81.03-1.8.54-2.38 1.22-.52.6-.98 1.57-.86 2.5.9.07 1.83-.46 2.4-1.14z"/>
      </svg>
      <span>Continue with Apple</span>
    </button>

    <button class="auth-pill auth-pill--google" type="button">
      <svg class="auth-pill__icon" viewBox="0 0 18 18" width="16" height="16" aria-hidden="true">
        <path fill="#EA4335" d="M9 3.48c1.69 0 3.2.58 4.4 1.72l3.29-3.29C14.67.96 12.03 0 9 0 5.48 0 2.44 2.02.96 4.96l3.82 2.96C5.54 5.44 7.1 3.48 9 3.48z"/>
        <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.49h4.84c-.21 1.12-.84 2.07-1.78 2.7l2.89 2.24c1.69-1.56 2.69-3.85 2.69-6.59z"/>
        <path fill="#FBBC05" d="M4.78 10.7c-.2-.6-.31-1.24-.31-1.9 0-.66.12-1.3.3-1.9L.96 4.96C.34 6.18 0 7.55 0 9s.34 2.82.96 4.04l3.82-3.34z"/>
        <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.89-2.24c-.81.54-1.84.86-3.07.86-2.36 0-4.36-1.59-5.07-3.74L.96 13.8C2.44 16.74 5.48 18 9 18z"/>
      </svg>
      <span>Continue with Google</span>
    </button>

    <p class="welcome__legal">
      By continuing, you agree to our <span class="welcome__legal-link">Terms</span>
      &nbsp;·&nbsp;
      <span class="welcome__legal-link">Privacy</span>
    </p>
  </div>
</div>

<style>
  .welcome {
    position: relative;
    width: 100%;
    min-height: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 74px 36px 46px; /* top leaves room for status bar; bottom for home indicator */
    color: var(--c-ink-inverse);
  }

  .welcome__top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }

  .welcome__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--c-foil-light);
  }

  .welcome__rule {
    display: block;
    width: 28px;
    height: 1px;
    background: var(--c-foil);
    opacity: 0.7;
  }

  .welcome__mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    margin-top: -8%;
  }

  .welcome__wordmark {
    font-family: var(--f-wordmark);
    font-weight: 400;
    font-size: 58px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--c-foil);
    /* Faint foil-stamp press, not a gradient or neon glow */
    text-shadow:
      0 1px 0 rgba(184, 147, 74, 0.08),
      0 0 22px rgba(184, 147, 74, 0.08);
  }

  .welcome__tagline {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.45;
    letter-spacing: 0.005em;
    text-align: center;
    color: var(--c-linen);
    max-width: 22ch;
    text-wrap: balance;
  }

  .welcome__foot {
    display: grid;
    gap: 12px;
    padding-bottom: 8px;
  }

  .auth-pill {
    width: 100%;
    height: 50px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      background-color var(--motion-state) var(--ease-state),
      border-color var(--motion-state) var(--ease-state),
      color var(--motion-state) var(--ease-state);
  }

  .auth-pill--apple {
    background: var(--c-foil-light);
    color: var(--c-ink);
    border: 0;
    box-shadow: var(--shadow-button);
  }

  .auth-pill--tap { position: relative; }
  .auth-pill--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  .auth-pill--google {
    background: transparent;
    color: var(--c-ink-inverse);
    border: 1px solid rgba(244, 239, 230, 0.55);
  }

  .auth-pill__icon { flex-shrink: 0; }

  .welcome__legal {
    margin-top: 12px;
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 12px;
    line-height: 1.5;
    color: var(--c-stone);
  }

  .welcome__legal-link {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: rgba(185, 180, 172, 0.5);
  }
</style>
