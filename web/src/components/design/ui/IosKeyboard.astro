---
/**
 * Stylised iOS software keyboard. Meant for still mockups — conveys
 * "keyboard is up" without trying to be pixel-accurate. Quiet gray keys,
 * a suggestion strip on top, a standard 4-row QWERTY silhouette with
 * space bar and return.
 *
 * Rendered inside a phone screen; positions itself absolutely at the
 * bottom, reserving space above the iOS home indicator.
 */

interface Props {
  /** Suggestions shown above the keys. Falls back to a neutral trio. */
  suggestions?: [string, string, string];
  /** Color of the primary action key (defaults to iOS blue). */
  returnTint?: string;
}

const {
  suggestions = ["minutes", "12", "just"],
  returnTint = "#0A84FF",
} = Astro.props;

const row1 = ["q","w","e","r","t","y","u","i","o","p"];
const row2 = ["a","s","d","f","g","h","j","k","l"];
const row3 = ["z","x","c","v","b","n","m"];
---

<div class="kb" role="presentation" aria-hidden="true">
  <div class="kb__suggest">
    <span class="kb__suggest-word">{suggestions[0]}</span>
    <span class="kb__suggest-sep" />
    <span class="kb__suggest-word kb__suggest-word--center">{suggestions[1]}</span>
    <span class="kb__suggest-sep" />
    <span class="kb__suggest-word">{suggestions[2]}</span>
  </div>

  <div class="kb__rows">
    <div class="kb__row">
      {row1.map((c) => <span class="kb__key">{c}</span>)}
    </div>

    <div class="kb__row kb__row--indent">
      {row2.map((c) => <span class="kb__key">{c}</span>)}
    </div>

    <div class="kb__row kb__row--three">
      <span class="kb__key kb__key--mod">
        <svg viewBox="0 0 20 20" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M10 3.2 3.5 9.6h3.4v6.2h6.2V9.6h3.4z" />
        </svg>
      </span>
      {row3.map((c) => <span class="kb__key">{c}</span>)}
      <span class="kb__key kb__key--mod">
        <svg viewBox="0 0 22 16" width="18" height="12" fill="currentColor" aria-hidden="true">
          <path d="M7 1h13a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H7L1 8z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
          <path d="M11 5.5 15.5 10M15.5 5.5 11 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
        </svg>
      </span>
    </div>

    <div class="kb__row kb__row--four">
      <span class="kb__key kb__key--wide kb__key--mod">123</span>
      <span class="kb__key kb__key--mod" aria-hidden="true">
        <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4">
          <circle cx="10" cy="10" r="7.5" />
          <circle cx="7" cy="8.5" r="0.7" fill="currentColor" stroke="none"/>
          <circle cx="13" cy="8.5" r="0.7" fill="currentColor" stroke="none"/>
          <path d="M7 12.5a4 4 0 0 0 6 0" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="kb__key kb__key--space">space</span>
      <span class="kb__key kb__key--wide kb__key--return" style={`background:${returnTint}`}>return</span>
    </div>
  </div>
</div>

<style>
  .kb {
    background: #D1D4DB; /* iOS keyboard tray gray */
    padding: 6px 3px 8px;
    display: grid;
    gap: 8px;
    user-select: none;
  }

  /* Suggestion strip ──────────────────────────────────────── */

  .kb__suggest {
    display: grid;
    grid-template-columns: 1fr 1px 1fr 1px 1fr;
    align-items: center;
    height: 38px;
    padding: 0 6px;
  }
  .kb__suggest-word {
    font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    font-size: 14px;
    color: #000;
    text-align: center;
    letter-spacing: -0.01em;
  }
  .kb__suggest-word--center {
    background: #fff;
    border-radius: 4px;
    padding: 4px 10px;
    justify-self: center;
  }
  .kb__suggest-sep {
    width: 1px;
    height: 18px;
    background: rgba(60, 60, 67, 0.3);
    justify-self: center;
  }

  /* Key rows ──────────────────────────────────────────────── */

  .kb__rows { display: grid; gap: 10px; }

  .kb__row {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
    gap: 6px;
    padding: 0 3px;
  }

  .kb__row--indent {
    padding: 0 21px; /* second row is inset on iOS */
  }

  .kb__row--three {
    grid-template-columns: 42px repeat(7, 1fr) 42px;
    padding: 0 3px;
  }

  .kb__row--four {
    grid-template-columns: 68px 42px 1fr 80px;
    padding: 0 3px;
  }

  .kb__key {
    display: grid;
    place-items: center;
    height: 42px;
    background: #FCFCFE;
    border-radius: 5px;
    font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    font-size: 20px;
    color: #000;
    letter-spacing: -0.01em;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.18);
  }

  .kb__key--mod {
    background: #ADB3BC;
    color: #000;
    font-size: 13px;
  }

  .kb__key--wide { font-size: 13px; }

  .kb__key--space {
    font-size: 13px;
    color: #000;
  }

  .kb__key--return {
    color: #fff;
    font-size: 13px;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.22);
  }
</style>
