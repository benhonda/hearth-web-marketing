---
/**
 * Screen VIII (Flow II) · Editing a spread.
 *
 * The per-spread editor reached from Preview (VI) when the user taps
 * a spread. The same spread is rendered at a slightly larger scale
 * than it appeared in preview (0.52 here vs 0.48 there), with a
 * two-option layout picker above the spread. The picker is wired —
 * click a thumbnail and the left-page layout swaps. Both layout
 * variants of the spread are pre-rendered and toggled via the
 * `hidden` attribute; the active thumb gets the ochre ring.
 *
 * For the mockup, only the LEFT page's layout swaps. The right page
 * stays fixed as a second recipe in 2-photos-b. A production version
 * would render a selector per page, but this captures the pattern.
 */
import BookSpread from "../ui/BookSpread.astro";
import BookPage, { type PageLayout } from "../ui/BookPage.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";
import type { SampleRecipe } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const recipeA: SampleRecipe = sampleRecipe;
const recipeB: SampleRecipe = {
  ...sampleRecipe,
  title: "Slow-roast tomato pasta",
  minutes: 90,
  serves: 4,
};

// Two layouts available for a 1-photo recipe. "a" is the default
// visible on mount; "b" swaps to the inverted arrangement.
const layoutOptions: { key: "a" | "b"; layout: PageLayout }[] = [
  { key: "a", layout: "1-photo-a" },
  { key: "b", layout: "1-photo-b" },
];
---

<div class="spe" data-spe-root>
  <nav class="spe__topbar" aria-label="Back">
    <button class="spe__back" type="button" aria-label="Back">
      <span aria-hidden="true">‹</span>
    </button>
  </nav>

  <header class="spe__head">
    <span class="spe__head-eyebrow">Editing</span>
    <hr class="spe__head-rule" aria-hidden="true" />
    <h1 class="spe__head-title">Editing this spread.</h1>
    <p class="spe__head-lede">Pick a layout, or tap any line on the page.</p>
  </header>

  <div class="spe__layout-row" role="radiogroup" aria-label="Page layout">
    {layoutOptions.map(({ key, layout }) => (
      <button
        class:list={["spe__thumb", key === "a" && "spe__thumb--on"]}
        type="button"
        role="radio"
        aria-checked={key === "a"}
        aria-label={`Layout ${key.toUpperCase()}`}
        data-layout={key}
      >
        <div class="spe__thumb-frame">
          <div class="spe__thumb-scale">
            <BookPage layout={layout} recipe={recipeA} />
          </div>
        </div>
      </button>
    ))}
  </div>

  <div class="spe__stage">
    {layoutOptions.map(({ key, layout }) => (
      <div class="spe__spread-wrap" data-spread={key} hidden={key !== "a"}>
        <div class="spe__spread-scale">
          <BookSpread
            left={{ recipe: recipeA, layout }}
            right={{ recipe: recipeB, layout: "2-photos-b" }}
          />
        </div>
      </div>
    ))}
  </div>

  <div class="spe__foot">
    <button class={showTap ? "spe__done spe__done--tap" : "spe__done"} type="button">
      Done
    </button>
  </div>
</div>

<script>
  // Layout picker — scoped per-root so the flow canvas and the 1×
  // stage page don't collide on the same document.
  document.querySelectorAll<HTMLElement>("[data-spe-root]").forEach((root) => {
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-layout]"));
    const spreads = Array.from(root.querySelectorAll<HTMLElement>("[data-spread]"));
    if (thumbs.length === 0 || spreads.length === 0) return;

    const activate = (key: string) => {
      thumbs.forEach((t) => {
        const on = t.dataset.layout === key;
        t.classList.toggle("spe__thumb--on", on);
        t.setAttribute("aria-checked", String(on));
      });
      spreads.forEach((s) => {
        s.hidden = s.dataset.spread !== key;
      });
    };

    thumbs.forEach((t) => {
      t.addEventListener("click", () => {
        const key = t.dataset.layout;
        if (key) activate(key);
      });
    });
  });
</script>

<style>
  .spe {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    min-height: 100%;
    padding-bottom: 44px;
  }

  .spe__topbar { padding: 62px 12px 0; }
  .spe__back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding-bottom: 2px;
    font-family: var(--f-display);
    font-size: 26px;
    line-height: 1;
    color: var(--c-ink);
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  /* Header — explicit on every property for the same reasons as
     BookTitleCover and BookPreview. */
  .spe__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 8px 22px 16px;
  }
  .spe__head-eyebrow {
    display: block;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10.5px;
    line-height: 1.3;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-align: center;
    color: var(--c-ochre);
    margin: 0;
  }
  .spe__head-rule {
    display: block;
    border: 0;
    width: var(--rule-chapter);
    height: var(--rule-weight-chapter);
    background: var(--c-ochre);
    margin: 4px 0 2px;
  }
  .spe__head-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    text-align: center;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }
  .spe__head-lede {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 13.5px;
    line-height: 1.4;
    text-align: center;
    color: var(--c-ash);
    margin: 2px 0 0;
  }

  /* Layout picker — two scaled BookPage thumbnails, same ochre-ring
     pattern as the cover alternates on VII and the thumbnails on V. */
  .spe__layout-row {
    display: flex;
    justify-content: center;
    gap: 14px;
    padding: 12px 22px 0;
  }
  .spe__thumb {
    position: relative;
    width: 88px;
    aspect-ratio: 4 / 5;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: var(--r-page);
    cursor: pointer;
    transition: box-shadow var(--motion-state) var(--ease-state);
  }
  .spe__thumb--on {
    box-shadow:
      0 0 0 1.5px var(--c-ochre),
      0 0 0 3px var(--c-cream);
  }
  .spe__thumb-frame {
    position: absolute;
    inset: 0;
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow: var(--shadow-paper);
  }
  .spe__thumb-scale {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 400px;
    transform: scale(0.275);
    transform-origin: top left;
    pointer-events: none;
  }

  /* Stage — the scaled spread at 0.52 (bigger than preview's 0.48). */
  .spe__stage {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 18px 12px 0;
    min-width: 0;
  }
  .spe__spread-wrap {
    position: relative;
    width: 333px;
    height: 208px;
    margin: 0 auto;
  }
  .spe__spread-wrap[hidden] { display: none; }
  .spe__spread-scale {
    position: absolute;
    top: 0;
    left: 0;
    width: 640px;
    height: 400px;
    transform: scale(0.52);
    transform-origin: top left;
    pointer-events: none;
  }

  /* Done — S1 outlined, consistent with the other edit landings in
     the flow (VII's Continue, VI's Review & finalize). Halo marks it
     as the tap target in the storyboard. */
  .spe__foot { padding: 22px 24px 0; }
  .spe__done {
    position: relative;
    display: block;
    width: 100%;
    height: 48px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid var(--c-conifer);
    background: transparent;
    color: var(--c-conifer);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14.5px;
    line-height: 1;
    letter-spacing: 0.01em;
    text-align: center;
    cursor: pointer;
    transition: background-color var(--motion-state) var(--ease-state),
                color var(--motion-state) var(--ease-state);
  }
  .spe__done--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
