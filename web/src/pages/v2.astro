<script>
  /* ─────────────────────────────────────────────────────────
   * Scroll-spy for the rail
   * ───────────────────────────────────────────────────────── */
  (function () {
    if (typeof window === "undefined" || !("IntersectionObserver" in window)) return;

    const sections = document.querySelectorAll<HTMLElement>(".binder__pages > section[id]");
    const links = document.querySelectorAll<HTMLAnchorElement>(".rail__link");
    if (!sections.length || !links.length) return;

    const linkById = new Map<string, HTMLAnchorElement>();
    links.forEach((a) => {
      const href = a.getAttribute("href") ?? "";
      if (href.startsWith("#")) linkById.set(href.slice(1), a);
    });

    const setActive = (id: string) => {
      links.forEach((a) => a.classList.remove("is-active"));
      const link = linkById.get(id);
      if (link) link.classList.add("is-active");
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (!visible.length) return;
        const top = visible.reduce((a, b) =>
          a.intersectionRatio >= b.intersectionRatio ? a : b
        );
        if (top.target.id) setActive(top.target.id);
      },
      { rootMargin: "-40% 0px -50% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] }
    );

    sections.forEach((s) => observer.observe(s));
  })();
</script>
