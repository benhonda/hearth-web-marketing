---
/**
 * Minimal iOS Safari chrome — used to frame a web page inside a phone
 * so the share-extension entry point reads as "the real internet."
 *
 * Bottom toolbar pattern (iOS 17+): URL pill above a row of 5 nav icons.
 * The share icon is visually prominent because that's the one the user
 * taps in screen IV.
 */

interface Props {
  url?: string;
  secure?: boolean;
  /** When true, halo the share button to mark it as the next tap. */
  showTap?: boolean;
}

const { url = "table.kitchen", secure = true, showTap = false } = Astro.props;
---

<div class="safari">
  <div class="safari__content">
    <slot />
  </div>

  <div class="safari__bar" aria-hidden="true">
    <div class="safari__urlbar">
      <span class="safari__urlbar-left">
        {secure && (
          <svg viewBox="0 0 10 12" width="9" height="11" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="1" y="5.5" width="8" height="6" rx="1" />
            <path d="M3 5.5V3.5a2 2 0 0 1 4 0v2" />
          </svg>
        )}
      </span>
      <span class="safari__url">{url}</span>
      <span class="safari__urlbar-right">
        <svg viewBox="0 0 12 12" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <circle cx="6" cy="6" r="4.8" />
          <path d="M6 3.2v5.6M3.2 6h5.6" />
        </svg>
      </span>
    </div>

    <nav class="safari__nav">
      <button type="button" aria-label="Back">
        <svg viewBox="0 0 14 14" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 3 4 7l5 4" />
        </svg>
      </button>
      <button type="button" aria-label="Forward" class="safari__nav-dim">
        <svg viewBox="0 0 14 14" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 3l5 4-5 4" />
        </svg>
      </button>
      <button type="button" aria-label="Share" class={showTap ? "safari__share safari__share--tap" : "safari__share"}>
        <svg viewBox="0 0 16 18" width="15" height="17" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 2v10" />
          <path d="M4.5 5.5 8 2l3.5 3.5" />
          <path d="M3 8v6a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V8" />
        </svg>
      </button>
      <button type="button" aria-label="Bookmarks">
        <svg viewBox="0 0 14 14" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round">
          <path d="M3.5 2h7v10l-3.5-2.2L3.5 12V2z" />
        </svg>
      </button>
      <button type="button" aria-label="Tabs">
        <svg viewBox="0 0 14 14" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.3">
          <rect x="2.5" y="3" width="7" height="7" rx="1" />
          <rect x="5" y="5" width="7" height="7" rx="1" fill="#ffffff" />
        </svg>
      </button>
    </nav>
  </div>
</div>

<style>
  .safari {
    position: relative;
    width: 100%;
    min-height: 100%;
    background: #ffffff;
    color: #111;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    display: flex;
    flex-direction: column;
  }

  .safari__content {
    flex: 1;
    padding: 60px 0 24px; /* 54 status bar + 6 breathing top */
  }

  .safari__bar {
    position: sticky;
    bottom: 0;
    padding: 10px 10px 40px; /* 10 · 10 · (6 inner + 34 home-indicator safe area) */
    background: #f5f5f7; /* opaque iOS chrome cream-gray */
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    display: grid;
    gap: 10px;
    z-index: 2;
  }

  .safari__urlbar {
    display: grid;
    grid-template-columns: 28px 1fr 28px;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    background: rgba(120, 120, 128, 0.16);
    border-radius: 13px;
    color: #111;
  }

  .safari__urlbar-left { display: inline-flex; color: #3a3a3a; }
  .safari__urlbar-right { display: inline-flex; justify-content: flex-end; color: #3a3a3a; }

  .safari__url {
    text-align: center;
    font-size: 15px;
    letter-spacing: -0.01em;
    color: #111;
    line-height: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .safari__nav {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    align-items: center;
    padding: 0 10px;
  }

  .safari__nav button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    color: #1f5fc1; /* iOS tint blue */
    cursor: pointer;
  }
  .safari__nav-dim { color: rgba(31, 95, 193, 0.35); }

  /* Halo the share icon — only shown in flow canvas context */
  .safari__share { position: relative; }
  .safari__share--tap::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 12px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
