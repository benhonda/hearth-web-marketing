  </div>
</DesignLayout>

<style>
  /* ───────── Page shell ───────── */
  .brand {
    max-width: 84rem;
    margin-inline: auto;
  }

  .brand-masthead {
    display: grid;
    gap: var(--space-md);
    max-width: 44rem;
    margin-bottom: var(--space-4xl);
  }
  .brand-masthead__title {
    font-family: var(--f-display);
    font-weight: 400; /* Lora never bold — enforced globally but stated here too */
    font-size: clamp(2.25rem, 3vw + 1rem, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.014em;
    color: var(--c-ink);
    text-wrap: balance;
  }
  .brand-masthead__meta {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-sm);
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-ash);
    margin-top: var(--space-md);
  }

  .brand-grid {
    display: grid;
    grid-template-columns: 14rem minmax(0, 1fr);
    gap: var(--space-3xl);
    align-items: start;
  }
  @media (max-width: 960px) {
    .brand-grid { grid-template-columns: 1fr; }
  }

  /* ───────── Sidebar ───────── */
  .brand-nav {
    position: sticky;
    top: 5rem;
    max-height: calc(100dvh - 6rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    display: grid;
    gap: var(--space-xl);
    padding-right: var(--space-md);
    padding-bottom: var(--space-3xl);
    border-right: var(--b-divider);
  }
  /* Hairline warm-biased scrollbar — matches the phone-scroll treatment in design.css */
  .brand-nav::-webkit-scrollbar { width: 4px; }
  .brand-nav::-webkit-scrollbar-thumb {
    background: rgba(31, 27, 23, 0.22);
    border-radius: 999px;
  }
  .brand-nav::-webkit-scrollbar-track { background: transparent; }
  @media (max-width: 960px) {
    .brand-nav {
      position: static;
      max-height: none;
      overflow: visible;
      border-right: 0;
      border-bottom: var(--b-divider);
      padding: 0 0 var(--space-xl);
    }
  }
  .brand-nav__group { display: grid; gap: var(--space-sm); }
  .brand-nav__heading { color: var(--c-ochre); }
  .brand-nav__list {
    display: grid;
    gap: 2px;
  }
  .brand-nav__list a {
    display: block;
    padding: 6px 0;
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-ash);
    transition: color var(--motion-state) var(--ease-state);
  }
  .brand-nav__list a:hover { color: var(--c-ochre); }

  /* ───────── Spec — the repeating section frame ───────── */
  .spec {
    display: grid;
    gap: var(--space-xl);
    padding-block: var(--space-3xl);
    border-bottom: var(--b-divider);
    scroll-margin-top: 5rem;
  }
  .spec:last-of-type { border-bottom: 0; }
  .spec__head { display: grid; gap: var(--space-md); max-width: 48rem; }
  .spec__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 1.5vw + 1rem, 2rem);
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  /* ───────── Mood (atmosphere) ───────── */
  .mood { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2xl); }
  @media (max-width: 640px) { .mood { grid-template-columns: 1fr; } }
  .mood__col { display: grid; gap: var(--space-md); }
  .mood__list {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--c-ink);
  }
  .mood__col--warn .mood__list { color: var(--c-ash); text-decoration: line-through; text-decoration-color: color-mix(in oklab, var(--c-rust) 45%, transparent); text-decoration-thickness: 1px; }

  /* ───────── Swatches (palette) ───────── */
  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--space-lg);
  }
  .swatch {
    display: grid;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--c-cream);
    border: var(--b-card);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-paper);
  }
  .swatch__chip {
    height: 4.5rem;
    border-radius: var(--r-page);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }
  .swatch__name { font-family: var(--f-body); font-weight: 500; font-size: var(--fs-body); color: var(--c-ink); }
  .swatch__hex code, .swatch__token code {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--c-ash);
  }
  .swatch__role { font-family: var(--f-display); font-style: italic; font-size: 13px; color: var(--c-ash); line-height: 1.4; }

  /* ───────── Typography tiers ───────── */
  .tiers { display: grid; gap: var(--space-2xl); }
  .tier {
    display: grid;
    gap: var(--space-sm);
    padding-bottom: var(--space-xl);
    border-bottom: var(--b-divider);
  }
  .tier:last-child { border-bottom: 0; padding-bottom: 0; }
  .tier__label {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-sm);
    font-family: var(--f-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .tier__num { font-family: var(--f-display); font-style: italic; font-weight: 400; letter-spacing: 0; text-transform: none; color: var(--c-ash); }
  .tier__meta {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--c-ash);
  }
  .tier__note { font-family: var(--f-display); font-style: italic; color: var(--c-ash); font-size: 14px; line-height: 1.5; }

  .tier-wordmark { font-family: var(--f-wordmark); font-size: 4rem; letter-spacing: 0.1em; line-height: 1; color: var(--c-foil); text-transform: uppercase; }
  .tier-h1 { font-family: var(--f-display); font-size: 2.25rem; line-height: 1.1; letter-spacing: -0.012em; color: var(--c-ink); }
  .tier-lede { font-family: var(--f-display); font-style: italic; font-size: 1.25rem; line-height: 1.5; color: var(--c-ash); }
  .tier-eyebrow { font-family: var(--f-body); font-weight: 500; font-size: 0.6875rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--c-ochre); }
  .tier-body { font-family: var(--f-body); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--c-ink); max-width: var(--measure-body); }

  /* ───────── Spacing ladder ───────── */
  .spacing-ladder { display: grid; gap: var(--space-sm); }
  .spacing-ladder li {
    display: grid;
    grid-template-columns: 12rem 1fr auto;
    gap: var(--space-md);
    align-items: center;
  }
  .spacing-ladder__bar {
    display: block;
    height: 8px;
    background: var(--c-ochre);
    border-radius: 2px;
    max-width: 100%;
  }
  .spacing-ladder__token {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--c-ash);
  }
  .spacing-ladder__px {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-ash);
  }

  /* ───────── Radius ───────── */
  .radius-row { display: flex; gap: var(--space-2xl); flex-wrap: wrap; align-items: flex-end; }
  .radius-row figcaption { margin-top: var(--space-sm); font-family: var(--f-display); font-style: italic; font-size: var(--fs-meta); color: var(--c-ash); line-height: 1.5; }
  .radius-row code { font-family: var(--f-mono); font-style: normal; font-size: 12px; color: var(--c-ochre); }
  .radius-demo--page {
    width: 8rem; height: 5rem;
    background: var(--c-cream);
    border: var(--b-card);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-paper);
  }
  .radius-demo--pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75em 1.5em;
    background: var(--c-foil-light);
    color: var(--c-ink);
    border-radius: var(--r-pill);
    font-family: var(--f-body);
    font-weight: 500;
    box-shadow: var(--shadow-button);
  }

  /* ───────── Shadows ───────── */
  .shadow-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr)); gap: var(--space-2xl); }
  .shadow-row figure { display: grid; gap: var(--space-md); }
  .shadow-row figcaption { font-family: var(--f-display); font-style: italic; font-size: var(--fs-meta); color: var(--c-ash); line-height: 1.5; }
  .shadow-row code { font-family: var(--f-mono); font-style: normal; font-size: 12px; color: var(--c-ochre); }
  .shadow-demo {
    height: 6rem;
    background: var(--c-cream);
    border: var(--b-card);
    border-radius: var(--r-page);
  }
  .shadow-demo--button {
    background: var(--c-foil-light);
    border-radius: var(--r-pill);
    width: 8rem;
    height: 2.75rem;
  }

  /* ───────── Motion & focus ───────── */
  .motion-row { display: inline-flex; gap: var(--space-xl); align-items: center; flex-wrap: wrap; }
  .motion-row code { font-family: var(--f-mono); color: var(--c-ochre); font-style: normal; }

  .focus-row { display: flex; gap: var(--space-lg); flex-wrap: wrap; align-items: center; }
  .focus-row__sage {
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--r-page);
  }

  /* ───────── Buttons demo ───────── */
  /* Base carries no background — every demo-card declares --cream or --sage.
   * Sage keeps the surface-sage class in markup so global.css handles text,
   * eyebrow, outlined-button, and link inversion with no duplication. */
  .demo-card {
    padding: var(--space-xl);
    border: var(--b-card);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-paper);
    margin-bottom: var(--space-lg);
  }
  .demo-card--cream { background: var(--c-cream); }
  .demo-card--sage { box-shadow: var(--shadow-lift); }
  .demo-card__label { margin-bottom: var(--space-md); }

  /* On-sage variants for the two scoped-only components (S3 soft, T1 text).
   * .surface-sage covers the rest from global.css. */
  .surface-sage .btn--soft {
    background: rgba(244, 239, 230, 0.14);
    color: var(--c-ink-inverse);
  }
  .surface-sage .btn--soft:hover:not(:disabled) { background: rgba(244, 239, 230, 0.22); }
  .surface-sage .btn-text { color: var(--c-linen); }
  .surface-sage .btn-text:hover { color: var(--c-ink-inverse); }
  .btn-row {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    align-items: center;
  }

  /* Soft-filled secondary (S3) — not in global.css yet; scoped for demo.
   * On-sage variant lives on .demo-card--sage .btn--soft above. */
  .btn--soft {
    background: #e8e1d1;
    color: var(--c-ink);
    box-shadow: none;
    padding-block: 0.875em;
    padding-inline: 1.5em;
  }
  .btn--soft:hover:not(:disabled) { background: #ddd4bf; }

  /* Tertiary T1 — plain text. On-sage variant lives on .demo-card--sage .btn-text above. */
  .btn-text {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: var(--fs-body);
    color: var(--c-ash);
    padding: 0.5em 0;
    transition: color var(--motion-state) var(--ease-state);
  }
  .btn-text:hover { color: var(--c-ink); text-decoration: underline; text-underline-offset: 3px; }

  /* ───────── Cards demo ───────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--space-lg);
  }
  /* Card base — NO background. Every card must declare .card--cream or
   * .card--sage. This removes cream-as-default and the cascade fights that
   * come with overriding it. */
  .card {
    display: grid;
    gap: var(--space-sm);
    padding: var(--space-xl);
    border: var(--b-card);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-paper);
  }
  .card--lift { box-shadow: var(--shadow-lift); }
  .card--cream { background: var(--c-cream); }
  .card--sage {
    background: var(--c-conifer);
    color: var(--c-ink-inverse);
    box-shadow: var(--shadow-lift);
  }
  .card__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.375rem;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }
  .card--sage .card__title { color: var(--c-ink-inverse); }
  .card--sage .eyebrow { color: var(--c-foil-light); }
  .card__meta {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-ash);
  }
  .card--sage .card__meta { color: var(--c-linen); }
  .card__body {
    font-family: var(--f-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--c-ash);
  }
  .card--sage .card__body { color: var(--c-linen); line-height: var(--lh-body-sage); }

  /* ───────── Inputs / form ───────── */
  .form-demo {
    display: grid;
    gap: var(--space-lg);
    max-width: 32rem;
    padding: var(--space-xl);
    background: var(--c-cream);
    border: var(--b-card);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-paper);
  }
  .field { display: grid; gap: var(--space-xs); }
  .field__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-ash);
  }
  .input {
    padding: 0.75em 0.875em;
    background: var(--c-input);
    border: var(--b-input);
    border-radius: var(--r-page);
    font-family: var(--f-body);
    font-size: var(--fs-body);
    color: var(--c-ink);
    transition:
      border-color var(--motion-state) var(--ease-state),
      background-color var(--motion-state) var(--ease-state);
  }
  .input::placeholder { color: var(--c-oat); }
  .input:focus {
    outline: none;
    background: var(--c-input-focus-bg);
    border: var(--b-input-focus);
  }
  .input--area { min-height: 5rem; resize: vertical; font-family: var(--f-body); }

  .fieldset {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding: 0;
    border: 0;
  }
  .fieldset .field__label { grid-column: 1 / -1; width: 100%; margin-bottom: var(--space-xs); }
  .radio {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--f-body);
    font-size: var(--fs-body);
    color: var(--c-ink);
    cursor: pointer;
  }
  .radio input { accent-color: var(--c-ochre); }

  .form-demo__actions {
    display: inline-flex;
    gap: var(--space-md);
    align-items: center;
    margin-top: var(--space-sm);
  }

  /* ───────── Nav demo ───────── */
  .nav-demo {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-md) var(--space-xl);
    background: color-mix(in oklab, var(--c-cream) 96%, transparent);
    border: var(--b-card);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-paper);
    backdrop-filter: saturate(140%) blur(8px);
  }
  .nav-demo__mark {
    font-family: var(--f-wordmark);
    font-size: 18px;
    letter-spacing: 0.12em;
    color: var(--c-conifer);
    text-transform: uppercase;
    text-decoration: none;
  }
  .nav-demo__links {
    display: inline-flex;
    justify-content: center;
    gap: var(--space-xl);
  }
  .nav-demo__links a {
    font-family: var(--f-body);
    font-size: 13px;
    color: var(--c-ash);
    text-decoration: none;
    transition: color var(--motion-state) var(--ease-state);
