---
/**
 * Library row — Apple Music–style. Thumbnail + Lora title + DM Sans meta.
 * The library uses this everywhere a recipe appears as a list item.
 */

interface Props {
  title: string;
  meta: string;
  source?: string; // e.g. "table.kitchen" — optional small-caps line
  thumbTone?: "corn" | "sage" | "ochre"; // placeholder thumbnail swatch
}

const { title, meta, source, thumbTone = "corn" } = Astro.props;
---

<a class="row" href="#">
  <div class={`row__thumb row__thumb--${thumbTone}`} aria-hidden="true" />
  <div class="row__body">
    {source && <span class="row__source">{source}</span>}
    <h3 class="row__title">{title}</h3>
    <p class="row__meta">{meta}</p>
  </div>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: 44px 1fr;
    align-items: center;
    gap: 14px;
    padding: 12px 22px;
    color: inherit;
    text-decoration: none;
    border-top: 1px solid rgba(31, 27, 23, 0.06);
    transition: background-color var(--motion-state) var(--ease-state);
  }
  .row:last-child { border-bottom: 1px solid rgba(31, 27, 23, 0.06); }

  .row__thumb {
    width: 44px;
    height: 44px;
    border-radius: 2px;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.12);
    position: relative;
    overflow: hidden;
  }
  .row__thumb::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent 0,
      transparent 1px,
      rgba(0, 0, 0, 0.035) 1px,
      rgba(0, 0, 0, 0.035) 3px
    );
  }
  .row__thumb--corn {
    background:
      radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .row__thumb--sage {
    background:
      radial-gradient(ellipse at 30% 30%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .row__thumb--ochre {
    background:
      radial-gradient(ellipse at 30% 30%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }

  .row__body {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .row__source {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-ochre);
    line-height: 1.2;
  }

  .row__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.22;
    letter-spacing: -0.006em;
    color: var(--c-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .row__meta {
    font-family: var(--f-body);
    font-size: 12px;
    line-height: 1.3;
    color: var(--c-ash);
    letter-spacing: 0.01em;
  }
</style>
