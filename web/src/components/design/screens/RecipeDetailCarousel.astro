---
/**
 * Flow IV · V · Recipe · detail, carousel.
 *
 * The quiet pivot after the photos land. Same recipe page, hero swapped
 * from a single full-bleed photo to a snap-scrollable strip with a
 * "1 / N" counter pill — realtor / Airbnb grammar. Tapping anywhere on
 * the carousel opens the gallery.
 *
 * Body, notes block, ingredients, method, folio — all unchanged. The
 * carousel is the only signal; everything below is the same recipe page
 * the cook was already reading.
 */
import RecipeDetail from "./RecipeDetail.astro";
import { recipePhotosAfter } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
---

<RecipeDetail
  showTap={showTap}
  heroType="carousel"
  heroPhotos={recipePhotosAfter}
/>
