---
/**
 * Screen VI · Library · one recipe.
 *
 * VSCO-style two-column waterfall — the library-of-one is the first
 * tile sitting in the left column of a grid that fills in as more
 * recipes save. Rules live in tokens.css §PHOTOGRAPHY (2).
 */
import AppHeader from "../ui/AppHeader.astro";
import LibraryGrid, { type LibraryTileData } from "../ui/LibraryGrid.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const tiles: LibraryTileData[] = [
  {
    title: sampleRecipe.title,
    meta: `${sampleRecipe.minutes} min · Serves ${sampleRecipe.serves}`,
    photo: sampleRecipe.photo,
    aspect: "4 / 5",
  },
];
---

<div class="lib-one">
  <AppHeader variant="wordmark" />

  <div class="lib-one__count">
    <span class="lib-one__n">1</span>
    <span class="lib-one__label">recipe</span>
  </div>

  <LibraryGrid tiles={tiles} showTap={showTap} tapIndex={0} />

  <p class="lib-one__folio">— page one —</p>
</div>

<style>
  .lib-one {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    min-height: 100%;
    padding-bottom: 44px;
  }

  .lib-one__count {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 0 22px;
    margin: 4px 0 18px;
  }
  .lib-one__n {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    color: var(--c-ochre);
  }
  .lib-one__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-oat);
  }

  .lib-one__folio {
    align-self: flex-end;
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 12.5px;
    color: var(--c-ochre);
    letter-spacing: 0.02em;
    padding-bottom: 8px;
  }
</style>
