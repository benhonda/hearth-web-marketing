<style>
  /* ───────── Page shell — mirrors /design/brand without the sidebar.
     Eight specimens doesn't warrant a sticky TOC. ───────── */
  .book-ws {
    max-width: 84rem;
    margin-inline: auto;
  }

  .book-ws__masthead {
    display: grid;
    gap: var(--space-md);
    max-width: 44rem;
    margin-bottom: var(--space-4xl);
  }
  .book-ws__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2.25rem, 3vw + 1rem, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.014em;
    color: var(--c-ink);
    text-wrap: balance;
  }
  .book-ws__meta {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-sm);
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-ash);
    margin-top: var(--space-md);
  }
  .book-ws__masthead code {
    font-family: var(--f-mono);
    font-size: 0.92em;
    color: var(--c-ochre);
  }

  /* ───────── Section frame ───────── */
  .spec {
    display: grid;
    gap: var(--space-2xl);
    padding-block: var(--space-3xl);
    border-bottom: var(--b-divider);
    scroll-margin-top: 5rem;
  }
  .spec:last-of-type { border-bottom: 0; }
  .spec__head {
    display: grid;
    gap: var(--space-md);
    max-width: 52rem;
  }
  .spec__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 1.5vw + 1rem, 2rem);
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  /* ───────── Specimen — the frame around each 320×400 object ───── */
  .specimen {
    display: grid;
    gap: var(--space-lg);
    margin: 0;
  }
  /* No plinth. The system has two surface colors (cream + sage) —
     the plate cover IS sage, so any dark plinth matches it. This
     mirrors how /design/brand's HeroBook and the flow storyboards
     sit on the workspace chrome: shadow + 2px radius carry the
     edge, not a contrasting container. Generous padding keeps the
     object breathing; the BookPage / BookCover components already
     carry their own --shadow-paper / --shadow-lift. */
  .specimen__stage {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: var(--space-2xl) 0;
  }
  .specimen__cap {
    display: grid;
    gap: var(--space-xs);
    max-width: 32ch;
  }
  .specimen__label {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-sm);
    font-family: var(--f-body);
    font-size: var(--fs-meta);
    color: var(--c-ash);
  }
  .specimen__label code {
    font-family: var(--f-mono);
    font-size: 12.5px;
    color: var(--c-ochre);
  }
  .specimen__bucket {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-ash);
  }
  .specimen__note {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-ash);
    line-height: 1.55;
  }

  /* ───────── Covers — two up, natural width. ───────── */
  .book-ws__covers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(22rem, max-content));
    gap: var(--space-3xl) var(--space-2xl);
    justify-content: start;
  }

  /* ───────── Pages — three up on wide screens, wraps down. Using
     max-content keeps each cell at the natural 320 + plinth padding
     instead of stretching. ───────── */
  .book-ws__pages {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(22rem, max-content));
    gap: var(--space-3xl) var(--space-2xl);
    justify-content: start;
  }

  /* ───────── Footer ───────── */
  .book-ws__foot {
    display: grid;
    gap: var(--space-md);
    padding: var(--space-3xl) 0 var(--space-2xl);
    margin-top: var(--space-3xl);
    border-top: var(--b-divider);
    text-align: center;
  }
  .book-ws__foot-meta {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ash);
    font-size: var(--fs-meta);
    max-width: 52ch;
    margin-inline: auto;
    text-wrap: balance;
  }
  .book-ws__foot-meta code {
    font-family: var(--f-mono);
    font-style: normal;
    color: var(--c-ochre);
  }

