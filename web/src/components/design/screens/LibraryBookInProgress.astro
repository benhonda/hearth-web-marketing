---
/**
 * Flow III · VII · Library · book in progress.
 *
 * The library we've seen before — same waterfall, same 27 recipes, same
 * Oat count above — but the foot invitation has changed voice. Where a
 * fresh library says "When you're ready to make these into a book —",
 * an in-progress library says "Your book in progress", with a recipe-
 * count cross-reference in the place where "Begin your book" used to
 * sit. Same halo grammar; the whole invitation block is the tap target.
 *
 * The 24 count is a content choice — the library has 27 recipes; 24 are
 * in the book. Lives in prose until the flow needs it as a real binding.
 */
import AppHeader from "../ui/AppHeader.astro";
import LibraryGrid from "../ui/LibraryGrid.astro";
import { sampleLibraryTiles } from "~/lib/design/sample-library";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const tiles = sampleLibraryTiles;
const inBook = 24;
---

<div class="lib">
  <AppHeader variant="wordmark" />

  <div class="lib__count">
    <span class="lib__n">{tiles.length}</span>
    <span class="lib__label">recipes</span>
  </div>

  <LibraryGrid tiles={tiles} />

  <div class={showTap ? "lib__invite lib__invite--tap" : "lib__invite"}>
    <span class="lib__eyebrow">Hearth Press</span>
    <hr class="lib__rule" aria-hidden="true" />
    <p class="lib__line">Your book in progress</p>
    <p class="lib__cta">
      <span>{inBook} recipes</span>
      <span class="lib__chev" aria-hidden="true">→</span>
    </p>
  </div>
</div>

<style>
  .lib {
    display: grid;
    grid-template-rows: auto auto auto auto;
    min-height: 100%;
    padding-bottom: 44px;
  }

  .lib__count {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 0 22px;
    margin: 4px 0 18px;
  }
  .lib__n {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    color: var(--c-ochre);
  }
  .lib__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-oat);
  }

  .lib__invite {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 12px;
    padding: 56px 22px 28px;
    text-align: center;
  }
  .lib__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .lib__rule {
    border: 0;
    width: var(--rule-chapter);
    height: var(--rule-weight-chapter);
    background: var(--c-ochre);
    margin: 4px 0 6px;
  }
  .lib__line {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.4;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }
  .lib__cta {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    margin: 4px 0 0;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 12.5px;
    letter-spacing: 0.04em;
    color: var(--c-ochre);
  }
  .lib__chev {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 14px;
    line-height: 1;
  }

  .lib__invite--tap::after {
    content: "";
    position: absolute;
    inset: 36px 12px 14px;
    border: 3px solid var(--annotation);
    border-radius: 4px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
