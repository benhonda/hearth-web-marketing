---
/**
 * /design/roadmap — the V1 scope-creep shield.
 *
 * A single horizontal timeline. One ochre line, twenty titles branching
 * off in alternation, phase markers as taller interruptions. Hover or
 * tap a node to reveal its scope cap in a popover. Scroll horizontally
 * to see everything left to build. The length of the scroll is the
 * whole deterrent.
 */
import DesignLayout from "~/layouts/DesignLayout.astro";

type Weight = "s" | "m" | "l";
type Item = { title: string; cap: string; weight: Weight };

type Phase = { numeral: string; label: string; items: Item[] };

const phases: Phase[] = [
  {
    numeral: "0",
    label: "Phase Zero · Before any app code",
    items: [
      {
        title: "Concierge cookbook",
        cap:
          "Figma → Blurb → wrap → give it to her. Watch her reaction, her mom's, her friends'. If the object doesn't land, no app rescues this. Strike once done.",
        weight: "m",
      },
    ],
  },
  {
    numeral: "I",
    label: "Phase One · Ship the wedge",
    items: [
      {
        title: "Design system + book template",
        cap:
          "One template. One trim (8×10 hardcover). Typography continuity app ≡ book. Must pass the book-spine test before a single feature ships on top.",
        weight: "l",
      },
      {
        title: "Auth",
        cap: "Apple + Google. No email/password. No profile, no avatar, no settings beyond sign-out.",
        weight: "s",
      },
      {
        title: "Manual recipe entry",
        cap:
          "Title, ingredients, method, photos. No categories, no tags, no ratings, no cook-time math.",
        weight: "m",
      },
      {
        title: "Library",
        cap: "Flat chronological (Apple Music model). Basic title search. No folders, no tags, no collections.",
        weight: "s",
      },
      {
        title: "Make-a-book flow",
        cap:
          "Multi-select → title + subtitle → cover photo → spread-by-spread preview. One template, one trim, no dedication page.",
        weight: "l",
      },
      {
        title: "Stripe checkout",
        cap: "Three SKUs: $99 / $119 / $139 for 40 / 60 / 80 pages. No upsells, no discounts, no multi-copy flow.",
        weight: "m",
      },
      {
        title: "Blurb fulfillment",
        cap: "Order submit → print → ship. Webhooks for status updates.",
        weight: "m",
      },
      {
        title: "Confirmation email",
        cap: "Transactional only. Noun-led copy. No marketing, no newsletter opt-in, no referral.",
        weight: "s",
      },
      {
        title: "Order tracking",
        cap: "Status + carrier tracking link. No rich timeline UI beyond what is essential.",
        weight: "s",
      },
      {
        title: "Web URL import",
        cap: "schema.org/Recipe JSON-LD parse. User can edit the extracted result before save.",
        weight: "m",
      },
      {
        title: "iOS share extension",
        cap: "Share sheet → app. Android stays shelved.",
        weight: "m",
      },
      {
        title: "TikTok / Instagram import",
        cap:
          "Caption → LLM extraction → user review step → save. The review step is non-negotiable — it catches bad extractions.",
        weight: "l",
      },
      {
        title: "Edit + version history",
        cap: "Every save writes a version. No per-change notes, no branching.",
        weight: "m",
      },
      {
        title: "Compare to original",
        cap:
          "Strikethrough old / highlight new. The emotional moment — TikTok caption → her version of the recipe. Screenshot-worthy.",
        weight: "m",
      },
    ],
  },
  {
    numeral: "II",
    label: "Phase Two · Ship-week polish",
    items: [
      { title: "Empty states", cap: "Designed objects, not to-do lists.", weight: "s" },
      { title: "Loading states", cap: "Calm. Never bouncy.", weight: "s" },
      {
        title: "Craft moments",
        cap: "Pick 2–3 small unexpected touches. Ship them. Stop.",
        weight: "m",
      },
      {
        title: "Copy pass",
        cap:
          "Every confirmation, toast, error. Noun-led: “Saved — it's in your library.” Never “Great job!”",
        weight: "m",
      },
      {
        title: "First-import hero flow",
        cap: "The one screenshot that sells the app.",
        weight: "s",
      },
    ],
  },
];

const romanLower = [
  "i", "ii", "iii", "iv", "v", "vi", "vii", "viii", "ix", "x",
  "xi", "xii", "xiii", "xiv", "xv", "xvi", "xvii", "xviii", "xix", "xx",
];

type Node =
  | { kind: "phase"; numeral: string; label: string }
  | { kind: "item"; index: number; roman: string; side: "up" | "down"; phaseLabel: string } & Item;

const nodes: Node[] = [];
let counter = 0;
for (const phase of phases) {
  nodes.push({ kind: "phase", numeral: phase.numeral, label: phase.label });
  for (const item of phase.items) {
    nodes.push({
      kind: "item",
      ...item,
      index: counter,
      roman: romanLower[counter],
      side: counter % 2 === 0 ? "up" : "down",
      phaseLabel: phase.label,
    });
    counter++;
  }
}

const totalItems = counter;
---

<DesignLayout title="Roadmap">
  <article class="surface-cream rm">

    <header class="rm__masthead">
      <div class="rm__chapter" aria-hidden="true">
        <span class="rm__chapter-rule"></span>
        <span class="rm__chapter-mark">the roadmap</span>
        <span class="rm__chapter-rule"></span>
      </div>
      <h1 class="rm__title">One line to V1.</h1>
      <p class="rm__lede">
        The full length of Hearth V1, on a single line. Hover or tap any
        node to read its scope cap. No dates. No detours. When the line
        feels long, that is the whole point.
      </p>
      <p class="rm__hint"><em>{totalItems} items · scroll right →</em></p>
    </header>

  </article>

  <section class="rm__bleed" aria-label="V1 roadmap timeline">
    <div class="rm__scroll">
      <ol class="rm__track" role="list">
        {nodes.map((node) => {
          if (node.kind === "phase") {
            return (
              <li class="rm__marker" role="listitem" aria-label={node.label}>
                <span class="rm__marker-bar" aria-hidden="true"></span>
                <span class="rm__marker-numeral" aria-hidden="true">{node.numeral}</span>
              </li>
            );
          }
          const popId = `rm-pop-${node.index}`;
          return (
            <li class="rm__node" data-side={node.side} data-weight={node.weight} role="listitem">
              <button
                type="button"
                class="rm__btn"
                aria-expanded="false"
                aria-controls={popId}
                data-rm-trigger
              >
                <span class="rm__node-title">{node.title}</span>
                <span class="rm__node-stem" aria-hidden="true"></span>
                <span class="rm__node-dot" aria-hidden="true"></span>
                <span class="rm__node-num" aria-hidden="true">{node.roman}.</span>
              </button>
              <div class="rm__pop" id={popId} role="dialog" aria-label={node.title}>
                <span class="rm__pop-eyebrow eyebrow">{node.phaseLabel} · {node.roman}.</span>
                <h3 class="rm__pop-title">{node.title}</h3>
                <p class="rm__pop-cap">{node.cap}</p>
              </div>
            </li>
          );
        })}
        <li class="rm__cap" aria-hidden="true"><span class="rm__cap-rule"></span></li>
      </ol>
    </div>
  </section>

  <article class="surface-cream rm">
    <section class="rm__protocol" aria-labelledby="protocol-title">
      <span class="eyebrow">After ship</span>
      <h2 id="protocol-title" class="rm__protocol-title">Phase Three is nothing</h2>
      <p class="rm__protocol-body">
        Nothing new builds here. The only work is the validation ladder
        in <em>MVP.md</em>. Every feature idea goes through the
        <em>Shelved</em> table first — every row there has a trigger. If
        the trigger isn't met, the answer is no.
      </p>

      <ol class="rm__rules">
        <li><span class="rm__rules-num" aria-hidden="true">i.</span><span>Already in the Shelved table? Read its trigger. Not met → no.</span></li>
        <li><span class="rm__rules-num" aria-hidden="true">ii.</span><span>Not in the table? Write it down as a Shelved row <em>with a trigger</em> before it goes anywhere else.</span></li>
        <li><span class="rm__rules-num" aria-hidden="true">iii.</span><span>Still want it in Phase One? Something above has to come out. The list does not grow.</span></li>
      </ol>

      <p class="rm__coda">— the point of this page is to be long enough to scare you —</p>
    </section>
  </article>
</DesignLayout>

<style>
  /* ───────── Shared page frame ───────── */

  .rm {
    background: var(--c-cream);
    max-width: 56rem;
    margin: 0 auto;
    padding: var(--space-3xl) 0;
  }

  /* ───────── Masthead ───────── */

  .rm__masthead {
    text-align: center;
  }
  .rm__chapter {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }
  .rm__chapter-rule {
    flex: 0 0 var(--rule-chapter);
    height: var(--rule-weight-chapter);
    background: var(--c-ochre);
  }
  .rm__chapter-mark {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: var(--fs-eyebrow);
    line-height: var(--lh-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .rm__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2.25rem, 3vw + 1.25rem, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.014em;
    color: var(--c-ink);
    margin: 0 0 var(--space-md);
  }
  .rm__lede {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-lede);
    line-height: var(--lh-lede);
    color: var(--c-ash);
    max-width: var(--measure-lede);
    margin: 0 auto var(--space-md);
  }
  .rm__hint {
    font-family: var(--f-display);
    font-size: var(--fs-meta);
    color: var(--c-oat);
    margin: 0;
  }
  .rm__hint em { font-style: italic; }

  /* ───────── Full-bleed timeline ───────── */

  .rm__bleed {
    background: var(--c-cream);
    /* cancel DesignLayout's horizontal --pad-side so the track goes wall-to-wall */
    margin-inline: calc(-1 * var(--pad-side));
    border-top: var(--b-divider);
    border-bottom: var(--b-divider);
  }
  .rm__scroll {
    overflow-x: auto;
    overflow-y: visible;
    overscroll-behavior-inline: contain;
    padding: var(--space-3xl) var(--pad-side);
    scroll-snap-type: x proximity;
  }

  /* Timeline track. Each node or phase marker is a fixed-width column.
     Grid rows (top / line / bottom) keep dots aligned regardless of
     which side the title is on. */
  .rm__track {
    display: inline-grid;
    grid-auto-flow: column;
    grid-auto-columns: max-content;
    grid-template-rows: 1fr auto 1fr;
    list-style: none;
    padding: 0;
    margin: 0;
    align-items: stretch;
    min-height: 300px;
    position: relative;
  }

  /* The line itself. Lives in the middle grid row, spans every column. */
  .rm__track::before {
    content: "";
    grid-row: 2;
    grid-column: 1 / -1;
    height: 1px;
    background: var(--c-ochre);
    opacity: 0.55;
    align-self: center;
  }

  /* ───────── Node ───────── */

  .rm__node {
    position: relative;
    grid-row: 1 / -1;
    display: grid;
    grid-template-rows: subgrid;
    width: 132px;
    scroll-snap-align: center;
  }

  .rm__btn {
    all: unset;
    cursor: pointer;
    display: grid;
    grid-row: 1 / -1;
    grid-template-rows: subgrid;
    justify-items: center;
    text-align: center;
    padding: 0 var(--space-xs);
    transition: color var(--motion-state) var(--ease-state);
  }
  .rm__btn:focus-visible {
    outline: var(--focus-ring-cream);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* Title and numeral swap sides based on data-side. Each lives in grid
     row 1 (above the line) or row 3 (below). align-self pulls them toward
     the center rule so the stems always touch the line. */
  .rm__node-title {
    font-family: var(--f-display);
    font-size: 0.875rem;
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--c-ink);
    max-width: 118px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--motion-state) var(--ease-state);
  }
  .rm__node-num {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 0.8125rem;
    color: var(--c-ochre);
    font-variant-numeric: tabular-nums;
  }
  .rm__node[data-side="up"] .rm__node-title {
    grid-row: 1;
    align-self: end;
    padding-bottom: 6px;
  }
  .rm__node[data-side="up"] .rm__node-num {
    grid-row: 3;
    align-self: start;
    padding-top: 10px;
  }
  .rm__node[data-side="down"] .rm__node-title {
    grid-row: 3;
    align-self: start;
    padding-top: 6px;
  }
  .rm__node[data-side="down"] .rm__node-num {
    grid-row: 1;
    align-self: end;
    padding-bottom: 10px;
  }

  /* Stem: a short vertical tick from the dot up or down toward the title.
     Direction depends on side. */
  .rm__node-stem {
    grid-row: 2;
    align-self: center;
    width: 1px;
    height: 14px;
    background: var(--c-ochre);
    opacity: 0.55;
    transition: opacity var(--motion-state) var(--ease-state),
                background var(--motion-state) var(--ease-state);
  }
  .rm__node[data-side="up"] .rm__node-stem {
    transform: translateY(-8px);
  }
  .rm__node[data-side="down"] .rm__node-stem {
    transform: translateY(8px);
  }

  /* Dot: on the line. Scales up on hover for a calm but readable state. */
  .rm__node-dot {
    grid-row: 2;
    align-self: center;
    justify-self: center;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-ochre);
    position: relative;
    z-index: 1;
    transition: transform var(--motion-state) var(--ease-state),
                background var(--motion-state) var(--ease-state);
  }
  .rm__node[data-weight="l"] .rm__node-dot { width: 9px; height: 9px; }
  .rm__node[data-weight="s"] .rm__node-dot { width: 6px; height: 6px; }

  .rm__btn:hover .rm__node-dot,
  .rm__node.is-open .rm__node-dot,
  .rm__btn:focus-visible .rm__node-dot {
    transform: scale(1.35);
    background: var(--c-ink);
  }
  .rm__btn:hover .rm__node-stem,
  .rm__node.is-open .rm__node-stem {
    opacity: 1;
    background: var(--c-ink);
  }
  .rm__btn:hover .rm__node-title,
  .rm__node.is-open .rm__node-title,
  .rm__btn:focus-visible .rm__node-title {
    color: var(--c-ochre);
  }

  /* ───────── Phase marker ───────── */

  .rm__marker {
    position: relative;
    grid-row: 1 / -1;
    display: grid;
    grid-template-rows: subgrid;
    justify-items: center;
    width: 72px;
    padding: 0 var(--space-md);
  }
  .rm__marker-bar {
    grid-row: 2;
    align-self: center;
    justify-self: center;
    width: 1.5px;
    height: 32px;
    background: var(--c-ochre);
    position: relative;
    z-index: 1;
  }
  .rm__marker-numeral {
    grid-row: 3;
    align-self: start;
    padding-top: 12px;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 1.75rem;
    color: var(--c-ochre);
    line-height: 1;
  }

  /* Trailing tick — a short rule after the last item so the line doesn't
     end in empty air. */
  .rm__cap {
    grid-row: 2;
    align-self: center;
    width: 32px;
    display: flex;
    align-items: center;
  }
  .rm__cap-rule {
    width: 100%;
    height: 1px;
    background: var(--c-ochre);
    opacity: 0.35;
  }

  /* ───────── Popover ───────── */

  .rm__pop {
    position: absolute;
    top: calc(50% + 26px);
    left: 50%;
    transform: translate(-50%, -4px);
    width: 240px;
    padding: var(--space-md) var(--space-lg);
    background: var(--c-input-focus-bg);
    border: var(--b-card);
    border-radius: var(--r-page);
    box-shadow: var(--shadow-lift);
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: opacity var(--motion-state) var(--ease-state),
                transform var(--motion-state) var(--ease-state),
                visibility 0s linear var(--motion-state);
    z-index: 10;
  }
  .rm__node[data-side="down"] .rm__pop {
    top: auto;
    bottom: calc(50% + 26px);
    transform: translate(-50%, 4px);
  }
  /* Arrow — small tick pointing back at the dot. */
  .rm__pop::before {
    content: "";
    position: absolute;
    left: 50%;
    width: 8px;
    height: 8px;
    background: var(--c-input-focus-bg);
    border-left: var(--b-card);
    border-top: var(--b-card);
    transform: translateX(-50%) rotate(45deg);
  }
  .rm__node[data-side="up"] .rm__pop::before {
    top: -5px;
  }
  .rm__node[data-side="down"] .rm__pop::before {
    bottom: -5px;
    border-left: none;
    border-top: none;
    border-right: var(--b-card);
    border-bottom: var(--b-card);
  }

  .rm__node:hover .rm__pop,
  .rm__node:focus-within .rm__pop,
  .rm__node.is-open .rm__pop {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translate(-50%, 0);
    transition: opacity var(--motion-state) var(--ease-state),
                transform var(--motion-state) var(--ease-state),
                visibility 0s linear 0s;
  }

  .rm__pop-eyebrow {
    display: block;
    color: var(--c-ochre);
    margin-bottom: var(--space-xs);
  }
  .rm__pop-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.3;
    color: var(--c-ink);
    margin: 0 0 var(--space-xs);
  }
  .rm__pop-cap {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--c-ash);
    margin: 0;
  }

  /* ───────── Protocol footer ───────── */

  .rm__protocol {
    padding-top: var(--space-2xl);
  }
  .rm__protocol-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: var(--fs-h1);
    line-height: var(--lh-h1);
    letter-spacing: var(--ls-h1);
    color: var(--c-ink);
    margin: var(--space-sm) 0 var(--space-lg);
  }
  .rm__protocol-body {
    font-family: var(--f-display);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--c-ink);
    max-width: var(--measure-body);
    margin: 0 0 var(--space-xl);
  }
  .rm__protocol-body em { font-style: italic; color: var(--c-ochre); }

  .rm__rules {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border-top: var(--b-divider);
    padding-top: var(--space-lg);
  }
  .rm__rules li {
    display: grid;
    grid-template-columns: 2rem 1fr;
    column-gap: var(--space-md);
    align-items: baseline;
    font-family: var(--f-display);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--c-ink);
  }
  .rm__rules em { font-style: italic; color: var(--c-ochre); }
  .rm__rules-num {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
    text-align: right;
  }

  .rm__coda {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--fs-meta);
    color: var(--c-oat);
    text-align: center;
    margin: var(--space-3xl) 0 0;
  }

  /* ───────── Reduced motion ───────── */

  @media (prefers-reduced-motion: reduce) {
    .rm__btn, .rm__node-dot, .rm__node-stem, .rm__node-title, .rm__pop {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var nodes = document.querySelectorAll(".rm__node");
    if (!nodes.length) return;

    function closeAll(except) {
      nodes.forEach(function (n) {
        if (n === except) return;
        if (n.classList.contains("is-open")) {
          n.classList.remove("is-open");
          var btn = n.querySelector("[data-rm-trigger]");
          if (btn) btn.setAttribute("aria-expanded", "false");
        }
      });
    }

    nodes.forEach(function (node) {
      var btn = node.querySelector("[data-rm-trigger]");
      if (!btn) return;
      btn.addEventListener("click", function (e) {
        e.stopPropagation();
        var open = !node.classList.contains("is-open");
        closeAll(node);
        node.classList.toggle("is-open", open);
        btn.setAttribute("aria-expanded", String(open));
      });
    });

    document.addEventListener("click", function (e) {
      var within = e.target && e.target.closest && e.target.closest(".rm__node");
      if (!within) closeAll(null);
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeAll(null);
    });
  })();
</script>
