---
/**
 * Screen X · Recipe · saved.
 *
 * After save. Visually identical to Screen VII — a beautiful cookbook
 * page — except method step iv now reads the edited wording
 * ("10–12 minutes"). No banner, no toast, no badge. The point of this
 * screen is that a save feels like nothing loud — the page just IS,
 * and the book-spine test is still intact.
 */
import AppHeader from "../ui/AppHeader.astro";
import IngredientsList from "../ui/IngredientsList.astro";
import MethodList from "../ui/MethodList.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
// Last screen in the flow — no tap target. Prop accepted for registry consistency.
void Astro.props;
---

<div class="saved">
  <AppHeader variant="title" title="" />

  <div class="saved__hero" aria-hidden="true" style={`background-image: url(${sampleRecipe.photo})`}>
    <span class="saved__hero-credit">photograph · Mia Aquilina</span>
  </div>

  <div class="saved__body">
    <span class="saved__source">From {sampleRecipe.source}</span>
    <h1 class="saved__title">{sampleRecipe.title}</h1>
    <p class="saved__lede">{sampleRecipe.lede}</p>
    <p class="saved__meta">
      <em>Serves {sampleRecipe.serves}</em>
      <span aria-hidden="true"> · </span>
      <em>{sampleRecipe.minutes} minutes</em>
    </p>

    <hr class="saved__rule" />

    <IngredientsList items={sampleRecipe.ingredients} />

    <hr class="saved__rule" />

    <MethodList items={sampleRecipe.editedMethod ?? sampleRecipe.method} highlightIndex={3} />
  </div>
</div>

<style>
  .saved {
    display: grid;
    grid-template-rows: auto auto 1fr;
    min-height: 100%;
    padding-bottom: 44px;
  }

  .saved__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .saved__hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 58%, rgba(0, 0, 0, 0.4) 100%);
  }
  .saved__hero-credit {
    position: absolute;
    bottom: 10px;
    right: 14px;
    font-family: var(--f-body);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
    z-index: 1;
  }

  .saved__body {
    padding: 22px 24px 18px;
    display: grid;
    gap: 10px;
  }

  .saved__source {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .saved__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 30px;
    line-height: 1.08;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  .saved__lede {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--c-ash);
    max-width: 36ch;
    margin-top: 2px;
  }

  .saved__meta {
    font-family: var(--f-display);
    font-size: 13px;
    color: var(--c-ash);
    margin-top: 4px;
  }
  .saved__meta em { font-style: italic; color: var(--c-ink); }

  .saved__rule {
    border: 0;
    height: 1px;
    background: rgba(31, 27, 23, 0.1);
    margin: 12px 0;
  }
</style>
