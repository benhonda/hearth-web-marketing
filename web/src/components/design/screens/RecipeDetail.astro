---
/**
 * Screen VII · Recipe · detail.
 *
 * The cookbook-page moment. Full-bleed hero with scrim, title in Lora,
 * ingredients + method on cream below. This is the screen that proves
 * "the app IS the book": typographically, the page you see here should
 * be indistinguishable in tone from a printed cookbook spread.
 *
 * No Edit button — editing is per-item via long-press → context menu.
 * On the storyboard, the ochre halo wraps step iv to mark the
 * long-press target for the next screen (VIII · context menu).
 */
import AppHeader from "../ui/AppHeader.astro";
import IngredientsList from "../ui/IngredientsList.astro";
import MethodList from "../ui/MethodList.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

interface Props {
  showTap?: boolean;
  /** When set, render this step (0-based) as a live textarea and
   *  use the post-edit wording. Drives the inline edit on screen IX. */
  editingIndex?: number;
  /** When true, skip the AppHeader. Used when an outer screen
   *  (the edit bar on IX) replaces the top chrome. */
  hideHeader?: boolean;
  /** When true and `editingIndex` is set, halo the inline Save
   *  button under the textarea as the next tap target. */
  editSaveTap?: boolean;
}
const {
  showTap = false,
  editingIndex,
  hideHeader = false,
  editSaveTap = false,
} = Astro.props;

const methodItems =
  editingIndex !== undefined ? sampleRecipe.editedMethod : sampleRecipe.method;
---

<div class="detail">
  {!hideHeader && <AppHeader variant="title" title="" />}

  <div class="detail__hero" aria-hidden="true" style={`background-image: url(${sampleRecipe.photo})`}>
    <span class="detail__hero-credit">photograph · Mia Aquilina</span>
  </div>

  <div class="detail__body">
    <span class="detail__source">From {sampleRecipe.source}</span>
    <h1 class="detail__title">{sampleRecipe.title}</h1>
    <p class="detail__lede">{sampleRecipe.lede}</p>
    <p class="detail__meta">
      <em>Serves {sampleRecipe.serves}</em>
      <span aria-hidden="true"> · </span>
      <em>{sampleRecipe.minutes} minutes</em>
      <span aria-hidden="true"> · </span>
      <em>One pan</em>
    </p>

    <hr class="detail__rule" />

    <IngredientsList items={sampleRecipe.ingredients} />

    <hr class="detail__rule" />

    <MethodList
      items={methodItems}
      tapIndex={showTap && editingIndex === undefined ? 3 : undefined}
      editIndex={editingIndex}
      saveTap={editSaveTap}
    />
  </div>
</div>

<style>
  .detail {
    display: grid;
    grid-template-rows: auto auto 1fr;
    min-height: 100%;
    padding-bottom: 44px;
  }

  /* Hero — real photograph, title scrim for credit legibility ─── */

  .detail__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .detail__hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 58%, rgba(0, 0, 0, 0.4) 100%);
  }
  .detail__hero-credit {
    position: absolute;
    bottom: 10px;
    right: 14px;
    font-family: var(--f-body);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
    z-index: 1;
  }

  /* Body ─────────────────────────────────────────────────── */

  .detail__body {
    padding: 22px 24px 18px;
    display: grid;
    gap: 10px;
  }

  .detail__source {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .detail__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 30px;
    line-height: 1.08;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  .detail__lede {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--c-ash);
    max-width: 36ch;
    margin-top: 2px;
  }

  .detail__meta {
    font-family: var(--f-display);
    font-size: 13px;
    color: var(--c-ash);
    margin-top: 4px;
  }
  .detail__meta em {
    font-style: italic;
    color: var(--c-ink);
  }

  .detail__rule {
    border: 0;
    height: 1px;
    background: rgba(31, 27, 23, 0.1);
    margin: 12px 0;
  }
</style>
