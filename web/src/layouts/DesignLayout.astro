---
/**
 * Layout for /design/* routes — internal mockup surface.
 * Wraps every design route in the warm workspace canvas (Chrome Background),
 * hides itself from search engines, strips the marketing nav/CTA, and renders
 * the shared DesignTopbar so navigation stays identical across pages.
 */
import "~/styles/global.css";
import "~/styles/design.css";
import DesignTopbar from "~/components/design/DesignTopbar.astro";

interface Props {
  title?: string;
}

const { title = "Design" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#f6f2ea" />
    <title>{title} · Hearth Design</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Apply tap-marker preference before first paint to avoid flash */}
    <script is:inline>
      try {
        if (localStorage.getItem("hearth-design-tap") === "off") {
          document.documentElement.classList.add("no-tap-halos");
        }
      } catch (_) {}
    </script>
  </head>
  <body class="design-body">
    <DesignTopbar />
    <main class="design-main">
      <slot />
    </main>
  </body>
</html>
