---
/**
 * Screen VIII (Flow II) · Editing a page.
 *
 * Reached from Preview (VI) when the user taps one of the two pages
 * in a spread. Edits ONE page at a time, not a whole spread — that
 * was the earlier, wrong framing. Pattern matches VII (The cover):
 *
 *     Display (the page, large)
 *         ↓
 *     LAYOUT row (2 thumbs for this photo count)
 *         ↓
 *     PHOTO row (swap which photo sits in the layout)
 *         ↓
 *     Done
 *
 * The layout picker is interactive — click a thumb, the main page
 * display swaps. Both variants are pre-rendered and toggled with
 * `hidden` via a scoped script.
 */
import ScreenNav from "../ui/ScreenNav.astro";
import BookPage, { type PageLayout } from "../ui/BookPage.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";
import { sampleLibraryTiles } from "~/lib/design/sample-library";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

// For the mockup we show a 1-photo recipe. Two layouts available.
const layoutOptions: { key: "a" | "b"; layout: PageLayout }[] = [
  { key: "a", layout: "1-photo-a" },
  { key: "b", layout: "1-photo-b" },
];

// Photo candidates — same pattern as the cover-photo picker on VII.
// In production these would be the recipe's own photo slots (the user
// picks which image to use in the layout's photo well); for the
// mockup we show a spread of library photos to demonstrate the row.
const photoCandidates = [0, 3, 10, 13, 23, 24].map((i) => sampleLibraryTiles[i]);
---

<div class="pe" data-pe-root>
  <ScreenNav eyebrow="Editing" />

  <div class="pe__stage">
    {layoutOptions.map(({ key, layout }) => (
      <div class="pe__page-display" data-page={key} hidden={key !== "a"}>
        <div class="pe__page-scale">
          <BookPage layout={layout} recipe={sampleRecipe} />
        </div>
      </div>
    ))}
  </div>

  <p class="pe__folio">— page 4 —</p>

  <section class="pe__row" aria-label="Page layout">
    <div class="pe__row-mark">
      <span class="pe__row-eyebrow">Layout</span>
      <hr class="pe__row-rule" aria-hidden="true" />
    </div>
    <div class="pe__layout-options" role="radiogroup">
      {layoutOptions.map(({ key, layout }) => (
        <button
          class:list={["pe__layout-option", key === "a" && "pe__layout-option--on"]}
          type="button"
          role="radio"
          aria-checked={key === "a"}
          aria-label={`Layout ${key.toUpperCase()}`}
          data-layout={key}
        >
          <div class="pe__layout-thumb">
            <div class="pe__layout-thumb-scale">
              <BookPage layout={layout} recipe={sampleRecipe} />
            </div>
          </div>
          <span class="pe__layout-mark" aria-hidden="true"></span>
        </button>
      ))}
    </div>
  </section>

  <section class="pe__row" aria-label="Photo">
    <div class="pe__row-mark">
      <span class="pe__row-eyebrow">Photo</span>
      <hr class="pe__row-rule" aria-hidden="true" />
    </div>
    <div class="pe__photo-scroll">
      {photoCandidates.map((tile, i) => {
        const isActive = i === 0;
        const photoStyle = tile.photo
          ? `background-image: url(${tile.photo})`
          : "";
        const tone = tile.tone ?? "corn";
        return (
          <button
            class:list={["pe__photo", isActive && "pe__photo--on", `pe__photo--${tone}`]}
            type="button"
            aria-label={tile.title}
            aria-pressed={isActive}
            style={photoStyle}
          ></button>
        );
      })}
    </div>
  </section>

  <div class="pe__foot">
    <button class={showTap ? "pe__done pe__done--tap" : "pe__done"} type="button">
      Done
    </button>
  </div>
</div>

<script>
  // Layout picker — swap which page variant is visible.
  document.querySelectorAll<HTMLElement>("[data-pe-root]").forEach((root) => {
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-layout]"));
    const displays = Array.from(root.querySelectorAll<HTMLElement>("[data-page]"));
    if (thumbs.length === 0 || displays.length === 0) return;

    const activate = (key: string) => {
      thumbs.forEach((t) => {
        const on = t.dataset.layout === key;
        t.classList.toggle("pe__layout-option--on", on);
        t.setAttribute("aria-checked", String(on));
      });
      displays.forEach((d) => {
        d.hidden = d.dataset.page !== key;
      });
    };

    thumbs.forEach((t) => {
      t.addEventListener("click", () => {
        const key = t.dataset.layout;
        if (key) activate(key);
      });
    });
  });
</script>

<style>
  .pe {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  /* Stage — single page at scale 0.72 (320 × 0.72 = 230 wide, 400 ×
     0.72 = 288 tall). The natural 4:5 proportion holds. */
  .pe__stage {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 18px 22px 0;
  }
  .pe__page-display {
    position: relative;
    width: 230px;
    height: 288px;
    margin: 0 auto;
  }
  .pe__page-display[hidden] { display: none; }
  .pe__page-scale {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 400px;
    transform: scale(0.72);
    transform-origin: top left;
    pointer-events: none;
  }

  /* Folio — centered Lora italic in Oat, em-dash bracketed. Shared
     voice with VI so the two edit surfaces anchor the display the
     same way. */
  .pe__folio {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--c-oat);
    text-align: center;
    margin: 12px 0 0;
    letter-spacing: 0.01em;
  }

  /* Section rows — editorial chapter marks. Small-caps eyebrow +
     36px ochre rule above each row so LAYOUT and PHOTO read as
     chapters of the cookbook's colophon. */
  .pe__row {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 24px 24px 0;
  }
  .pe__row-mark {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .pe__row-eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10.5px;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .pe__row-rule {
    display: block;
    border: 0;
    width: 36px;
    height: 1px;
    background: var(--c-ochre);
    margin: 0;
    opacity: 0.85;
  }

  /* Layout picker — mirrors VI. No caption, no ring; an Ochre
     margin-rule hairline appears beneath the active thumb. */
  .pe__layout-options {
    display: flex;
    gap: 18px;
  }
  .pe__layout-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .pe__layout-thumb {
    position: relative;
    width: 68px;
    aspect-ratio: 4 / 5;
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow: var(--shadow-paper);
  }
  .pe__layout-thumb-scale {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 400px;
    transform: scale(0.2125);
    transform-origin: top left;
    pointer-events: none;
  }
  .pe__layout-mark {
    display: block;
    width: 20px;
    height: 1.5px;
    background: transparent;
    transition: background-color var(--motion-state) var(--ease-state);
  }
  .pe__layout-option--on .pe__layout-mark {
    background: var(--c-ochre);
  }

  /* Photo picker — horizontal scroll of small tiles. Same pattern
     as the cover-photo picker on VII so both edit surfaces share
     their row treatment. */
  .pe__photo-scroll {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 54px;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 2px;
    scrollbar-width: none;
  }
  .pe__photo-scroll::-webkit-scrollbar { display: none; }

  .pe__photo {
    width: 54px;
    aspect-ratio: 4 / 5;
    padding: 0;
    border: 0;
    border-radius: var(--r-page);
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    cursor: pointer;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.15);
    transition: box-shadow var(--motion-state) var(--ease-state);
  }
  .pe__photo--corn:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .pe__photo--sage:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .pe__photo--ochre:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }
  .pe__photo--on {
    box-shadow:
      inset 0 0 0 0.5px rgba(0, 0, 0, 0.15),
      0 0 0 1.5px var(--c-ochre),
      0 0 0 3px var(--c-cream);
  }

  /* Done — S1 outlined, tap target. Pinned to the bottom. */
  .pe__foot {
    margin-top: auto;
    position: sticky;
    bottom: 0;
    padding: 14px 24px 34px;
    background: var(--c-cream);
    z-index: 5;
  }
  .pe__done {
    position: relative;
    display: block;
    width: 100%;
    height: 48px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid var(--c-conifer);
    background: transparent;
    color: var(--c-conifer);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14.5px;
    line-height: 1;
    letter-spacing: 0.01em;
    text-align: center;
    cursor: pointer;
    transition: background-color var(--motion-state) var(--ease-state),
                color var(--motion-state) var(--ease-state);
  }
  .pe__done--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
