---
/**
 * Flow IV · V — Recipe · expanded note.
 *
 * The close of the flow. The block now carries both voices in one
 * flowing paragraph — cook-note and memory-note as one continuous
 * Lora italic body ("Halved the salt — nicer balance. — Sam's 30th.
 * Doubled it. Everyone wanted seconds. —"). No chrome, no halo, no
 * separation between the two thoughts — Apple Notes grammar, one
 * block, everything the cook wanted to remember. The book-spine test
 * holds: crop it, print it, no one would know it was an app.
 */
import RecipeDetail from "./RecipeDetail.astro";
import RecipeNotes from "../ui/RecipeNotes.astro";
import { sampleNoteExpanded } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
// Last screen in the flow — no tap target. Prop accepted for registry consistency.
void Astro.props;
---

<RecipeDetail folio="page 1">
  <RecipeNotes
    slot="notes"
    text={sampleNoteExpanded}
  />
</RecipeDetail>
