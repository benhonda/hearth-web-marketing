---
/**
 * Screen VIII · Recipe · long-press menu.
 *
 * The user long-pressed step iv on the detail page (VII). iOS-style
 * context menu: the page blurs and dims, the pressed step is lifted
 * ("plucked") above the dim layer with a soft shadow, and a quiet
 * two-row menu floats beneath — Edit · Delete, nothing else. Edit is
 * halo'd as the next tap target; tapping it lands on IX (editing step iv).
 *
 * This is the discoverability answer to "how do I edit a step": there's
 * no Edit button in the chrome; long-press is the single entry point
 * and the surfaced card + menu is the visible feedback.
 */
import RecipeDetail from "./RecipeDetail.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const stepIv = sampleRecipe.method[3];
---

<div class="menu">
  <div class="menu__back" aria-hidden="true">
    <div class="menu__back-shift">
      <RecipeDetail />
    </div>
  </div>
  <div class="menu__dim" aria-hidden="true" />

  <div class="menu__stack" role="dialog" aria-label="Step actions">
    <article class="plucked">
      {stepIv.mise.length > 0 && (
        <span class="plucked__mise">{stepIv.mise.join(" · ")}</span>
      )}
      <div class="plucked__row">
        <span class="plucked__num">iv.</span>
        <span class="plucked__text">{stepIv.text}</span>
      </div>
    </article>

    <div class="ctx" role="menu">
      <button class={showTap ? "ctx__row ctx__row--edit ctx__row--tap" : "ctx__row ctx__row--edit"} type="button" role="menuitem">
        <span class="ctx__label">Edit</span>
        <span class="ctx__icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.4 3.6a1.8 1.8 0 0 1 2.5 2.5L7 16l-4 1 1-4 10.4-9.4z" />
          </svg>
        </span>
      </button>
      <button class="ctx__row ctx__row--delete" type="button" role="menuitem">
        <span class="ctx__label">Delete</span>
        <span class="ctx__icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6h12M8 6V4.5A1 1 0 0 1 9 3.5h2a1 1 0 0 1 1 1V6M6 6l.8 9.4A1.5 1.5 0 0 0 8.3 17h3.4a1.5 1.5 0 0 0 1.5-1.6L14 6" />
          </svg>
        </span>
      </button>
    </div>
  </div>
</div>

<style>
  .menu {
    position: relative;
    width: 100%;
    min-height: 100%;
    overflow: hidden;
  }

  /* Blurred, pushed-up detail page as backdrop ──────────────── */

  .menu__back {
    position: absolute;
    inset: 0;
    pointer-events: none;
    filter: blur(8px);
    /* blur bleeds past the edges; inset mask hides the halo */
    clip-path: inset(0);
  }
  .menu__back-shift {
    transform: translateY(-470px);
    will-change: transform;
  }

  .menu__dim {
    position: absolute;
    inset: 0;
    background: rgba(20, 16, 12, 0.38);
  }

  /* Plucked step + menu stack ──────────────────────────────── */

  .menu__stack {
    position: absolute;
    left: 18px;
    right: 18px;
    top: 32%;
    display: grid;
    gap: 14px;
  }

  /* Plucked step — same typography as the real list, lifted on a
     cream card with a soft shadow (the "3D lift" from iOS). */

  .plucked {
    background: var(--c-cream, #F5EFE5);
    border-radius: 14px;
    padding: 16px 18px 18px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.35) inset,
      0 10px 30px rgba(0, 0, 0, 0.22),
      0 2px 6px rgba(0, 0, 0, 0.12);
  }

  .plucked__mise {
    display: block;
    padding-left: 32px;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 11.5px;
    line-height: 1.4;
    color: var(--c-ochre);
    letter-spacing: 0.005em;
    margin-bottom: 4px;
  }

  .plucked__row {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    column-gap: 2px;
    align-items: baseline;
  }

  .plucked__num {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    color: var(--c-ochre);
    line-height: 1.55;
  }

  .plucked__text {
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--c-ink);
  }

  /* Context menu — iOS-style vibrancy card, two rows ───────── */

  .ctx {
    background: rgba(250, 246, 240, 0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 14px 40px rgba(0, 0, 0, 0.22),
      0 2px 6px rgba(0, 0, 0, 0.12);
    display: grid;
    grid-template-rows: auto auto;
  }

  .ctx__row {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: transparent;
    border: 0;
    width: 100%;
    text-align: left;
    font-family: var(--f-body);
    font-size: 15px;
    letter-spacing: -0.005em;
    color: var(--c-ink);
    cursor: pointer;
  }
  .ctx__row + .ctx__row {
    border-top: 1px solid rgba(31, 27, 23, 0.1);
  }

  .ctx__row--delete {
    color: #B94A3B; /* muted vermillion — sits inside Hearth's warm palette */
  }

  .ctx__icon {
    display: inline-flex;
    align-items: center;
    color: currentColor;
    opacity: 0.85;
  }

  /* Storyboard halo on the Edit row — where the tap happens. */
  .ctx__row--tap::after {
    content: "";
    position: absolute;
    inset: 2px;
    border: 3px solid var(--annotation);
    border-radius: 10px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
