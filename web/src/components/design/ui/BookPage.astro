---
/**
 * BookPage — a single recipe rendered on one cookbook page in one of
 * the six V1 layouts. Used at FULL scale in VIII (Spread preview) and
 * IX (Editing a spread), and at THUMB scale in VI (Global settings)
 * via a transform: scale parent. Same component, two scales, zero
 * drift between picker and rendered object.
 *
 * Natural size: 320 × 400 px (4:5 proxy for the 8×10 book page).
 *
 * Layouts differ only in photo placement. Text elements (title, meta,
 * ingredients, method) stay in a consistent voice across all six.
 *
 *   · 1-photo-a  — photo top-half, text below
 *   · 1-photo-b  — photo bottom-half, text above
 *   · 2-photos-a — two photos side-by-side on top, text below
 *   · 2-photos-b — photo top, text middle, photo bottom (bookend)
 *   · 3-plus-a   — 2×2 photo grid top, text below
 *   · 3-plus-b   — 3-photo horizontal strip top, text below
 */
import type { SampleRecipe } from "~/lib/design/sample-recipe";

export type PageLayout = "1-photo-a" | "1-photo-b" | "2-photos-a" | "2-photos-b" | "3-plus-a" | "3-plus-b";

interface Props {
  layout: PageLayout;
  recipe: SampleRecipe;
}

const { layout, recipe } = Astro.props;

const slotCount =
  layout.startsWith("1-") ? 1 :
  layout.startsWith("2-") ? 2 :
  layout === "3-plus-a" ? 4 : 3;

// Resolve each photo slot. Slot 0 always uses the real recipe photo;
// later slots fall back to gradient placeholders (corn tone).
const photos = Array.from({ length: slotCount }).map((_, i) => {
  if (i === 0) return recipe.photo;
  const extras = recipe.photos ?? [];
  return extras[i] ?? null;
});

const ingredients = recipe.ingredients.slice(0, 6);
const method = recipe.method.slice(0, 4);
---

<article class:list={["bp", `bp--${layout}`]} aria-label={recipe.title}>
  {/* Photo slots — styled by position in layout-specific CSS */}
  {photos.map((p, i) => (
    <div
      class:list={["bp__photo", `bp__photo--${i + 1}`, !p && "bp__photo--empty"]}
      style={p ? `background-image: url(${p})` : ""}
      aria-hidden="true"
    ></div>
  ))}

  {/* Text block — always the same grammar, slotted into the layout */}
  <div class="bp__text">
    <header class="bp__head">
      <h3 class="bp__title">{recipe.title}</h3>
      <p class="bp__meta">{recipe.minutes} min · Serves {recipe.serves}</p>
    </header>

    <section class="bp__body">
      <span class="bp__label">Ingredients</span>
      <ul class="bp__ing">
        {ingredients.map((ing) => <li>{ing}</li>)}
      </ul>

      <span class="bp__label">Method</span>
      <ol class="bp__method">
        {method.map((step, i) => {
          const roman = ["i", "ii", "iii", "iv"][i];
          return (
            <li>
              <span class="bp__roman">{roman}.</span>
              <span class="bp__step">{step.text}</span>
            </li>
          );
        })}
      </ol>
    </section>

    <p class="bp__folio">— page —</p>
  </div>
</article>

<style>
  /* ──────────────────────────────────────────────────────────────
     Natural-size page. Container queries would be ideal here, but
     CSS vars + grid + a fixed natural size keep it simple; the
     parent scales via transform when a thumbnail is wanted.
     ────────────────────────────────────────────────────────────── */
  .bp {
    position: relative;
    width: 320px;
    aspect-ratio: 4 / 5;
    background: var(--c-cream);
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow:
      inset 0 0 0 0.5px rgba(0, 0, 0, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.04);
    display: grid;
  }

  /* Photo styling is shared; the GRID cell position is what varies
     per layout. All photos get the same inset hairline for depth. */
  .bp__photo {
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.12);
  }
  .bp__photo--empty {
    background: radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }

  .bp__text {
    padding: 14px 16px 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bp__head { display: grid; gap: 4px; }

  .bp__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 13.5px;
    line-height: 1.15;
    letter-spacing: -0.008em;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }

  .bp__meta {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 10px;
    color: var(--c-ash);
    margin: 0;
  }

  .bp__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;
  }

  .bp__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 7px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    margin-top: 4px;
  }

  .bp__ing {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    font-family: var(--f-body);
    font-size: 8.5px;
    line-height: 1.4;
    color: var(--c-ink);
  }

  .bp__method {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
    font-family: var(--f-body);
    font-size: 8.5px;
    line-height: 1.4;
    color: var(--c-ink);
  }
  .bp__method li {
    display: flex;
    gap: 4px;
  }
  .bp__roman {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
    flex-shrink: 0;
    min-width: 12px;
  }
  .bp__step { flex: 1; }

  .bp__folio {
    margin-top: auto;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 8px;
    color: var(--c-ochre);
    text-align: center;
    padding-top: 4px;
  }

  /* ──────────────────────────────────────────────────────────────
     Layout-specific grids. Each defines where the photos and text
     block land; the text block structure stays identical.
     ────────────────────────────────────────────────────────────── */

  /* 1-photo-a — photo top (45%), text below */
  .bp--1-photo-a {
    grid-template-rows: 45% 1fr;
    grid-template-areas:
      "photo1"
      "text";
  }
  .bp--1-photo-a .bp__photo--1 { grid-area: photo1; }
  .bp--1-photo-a .bp__text { grid-area: text; }

  /* 1-photo-b — text top, photo bottom */
  .bp--1-photo-b {
    grid-template-rows: 1fr 45%;
    grid-template-areas:
      "text"
      "photo1";
  }
  .bp--1-photo-b .bp__photo--1 { grid-area: photo1; }
  .bp--1-photo-b .bp__text { grid-area: text; }

  /* 2-photos-a — two photos side-by-side on top (35%), text below */
  .bp--2-photos-a {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 35% 1fr;
    grid-template-areas:
      "photo1 photo2"
      "text text";
    gap: 2px;
  }
  .bp--2-photos-a .bp__photo--1 { grid-area: photo1; }
  .bp--2-photos-a .bp__photo--2 { grid-area: photo2; }
  .bp--2-photos-a .bp__text {
    grid-area: text;
    padding-top: 12px;
  }

  /* 2-photos-b — photo top (28%), text middle, photo bottom (24%) */
  .bp--2-photos-b {
    grid-template-rows: 28% 1fr 24%;
    grid-template-areas:
      "photo1"
      "text"
      "photo2";
  }
  .bp--2-photos-b .bp__photo--1 { grid-area: photo1; }
  .bp--2-photos-b .bp__photo--2 { grid-area: photo2; }
  .bp--2-photos-b .bp__text { grid-area: text; }

  /* 3-plus-a — 2×2 photo grid top (48%), text below */
  .bp--3-plus-a {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 48% 1fr;
    grid-template-areas:
      "photo1 photo2"
      "photo3 photo4"
      "text text";
    gap: 2px;
  }
  /* Make the 4-photo grid use two rows of 24% each. Override rows: */
  .bp--3-plus-a {
    grid-template-rows: 24% 24% 1fr;
  }
  .bp--3-plus-a .bp__photo--1 { grid-area: photo1; }
  .bp--3-plus-a .bp__photo--2 { grid-area: photo2; }
  .bp--3-plus-a .bp__photo--3 { grid-area: photo3; }
  .bp--3-plus-a .bp__photo--4 { grid-area: photo4; }
  .bp--3-plus-a .bp__text {
    grid-area: text;
    padding-top: 12px;
  }

  /* 3-plus-b — horizontal photo strip (3 thumbs) on top, text below */
  .bp--3-plus-b {
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 30% 1fr;
    grid-template-areas:
      "photo1 photo2 photo3"
      "text text text";
    gap: 2px;
  }
  .bp--3-plus-b .bp__photo--1 { grid-area: photo1; }
  .bp--3-plus-b .bp__photo--2 { grid-area: photo2; }
  .bp--3-plus-b .bp__photo--3 { grid-area: photo3; }
  .bp--3-plus-b .bp__text {
    grid-area: text;
    padding-top: 12px;
  }
</style>
