---
import DesignLayout from "~/layouts/DesignLayout.astro";
import ScreenStage from "~/components/design/ScreenStage.astro";
import PhoneFrame from "~/components/design/PhoneFrame.astro";
import MobileSafariRecipeScreen from "~/components/design/screens/MobileSafariRecipe.astro";
---

<DesignLayout title="Safari · article · Screen III" eyebrow="Flow I · Screen III">
  <ScreenStage
    eyebrow="III · Mobile Safari · recipe article"
    title="The open internet."
    note="A food-blog article. Deliberately not set in Hearth's fonts — Iowan Old Style + system sans — so the user reads it as somewhere else. The ochre halo around the share icon is the only Hearth touch, and it points to the next tap."
  >
    <PhoneFrame surface="neutral" tone="ink" variant="single" label="Mobile Safari · table.kitchen article">
      <MobileSafariRecipeScreen />
    </PhoneFrame>
  </ScreenStage>
</DesignLayout>
