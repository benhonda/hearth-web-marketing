---
/**
 * Flow II · Settings (landing).
 *
 * Reached from Preview via the right-nav Settings mark. A quiet
 * typographic TOC — four rows, each a tappable line that descends
 * into its own editor (Title, Subtitle, Layout, Recipes). No foot
 * CTA; the back chevron is the way out and edits commit as they
 * happen. Empty states are never "nothing here yet" — this page is
 * always populated from the in-progress book.
 *
 * Row rhythm mirrors a published TOC:
 *   small-cap label · value in Lora italic · right chevron
 * separated by the barely-there divider from tokens.css (§5).
 */
import ScreenNav from "../ui/ScreenNav.astro";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

type Row = {
  key: string;
  label: string;
  value: string;
  tap?: boolean;
};

const rows: Row[] = [
  { key: "title",    label: "Title",    value: "For Us.",                    tap: showTap },
  { key: "subtitle", label: "Subtitle", value: "A year at the table." },
  { key: "layout",   label: "Layout",   value: "Plate · 1-a / 2-b / 3-a" },
  { key: "recipes",  label: "Recipes",  value: "24 in the book" },
];
---

<div class="sts">
  <ScreenNav />

  <header class="sts__head">
    <h1 class="sts__head-title">Settings.</h1>
    <p class="sts__head-lede">Reshape the book.</p>
  </header>

  <ul class="sts__list" role="list">
    {rows.map((row) => (
      <li class="sts__row-wrap">
        <button class:list={["sts__row", row.tap && "sts__row--tap"]} type="button" aria-label={`Edit ${row.label}`}>
          <span class="sts__row-label">{row.label}</span>
          <span class="sts__row-value">{row.value}</span>
          <span class="sts__row-chev" aria-hidden="true">›</span>
        </button>
      </li>
    ))}
  </ul>
</div>

<style>
  .sts {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  /* Header — left-aligned; editorial chapter-opener rhythm. */
  .sts__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 14px 24px 22px;
  }
  .sts__head-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    text-align: left;
    color: var(--c-ink);
    margin: 0;
  }
  .sts__head-lede {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.4;
    text-align: left;
    color: var(--c-ash);
    margin: 2px 0 0;
  }

  /* List — TOC rhythm, not iOS grouped settings. Each row is its own
     chapter mark; the divider is the barely-there one from tokens. */
  .sts__list {
    list-style: none;
    margin: 0;
    padding: 0 22px;
    display: flex;
    flex-direction: column;
  }
  .sts__row-wrap {
    border-top: var(--b-divider);
  }
  .sts__row-wrap:last-child {
    border-bottom: var(--b-divider);
  }

  /* Row — four-column grid so label / value / chev align as a TOC
     line. Value is the star of the line; label is the small-caps
     annotation above in stacking order when wrapped. */
  .sts__row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    grid-template-areas:
      "label  chev"
      "value  chev";
    gap: 4px 12px;
    width: 100%;
    padding: 16px 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
    position: relative;
    transition: opacity var(--motion-state) var(--ease-state);
  }
  .sts__row:hover { opacity: 0.82; }

  .sts__row-label {
    grid-area: label;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .sts__row-value {
    grid-area: value;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.3;
    color: var(--c-ink);
    letter-spacing: -0.003em;
  }
  .sts__row-chev {
    grid-area: chev;
    align-self: center;
    font-family: var(--f-display);
    font-size: 20px;
    line-height: 1;
    color: var(--c-ochre);
  }

  /* Halo — matches other screens' tap markers. Bound to the row so it
     sits cleanly against the divider without overflowing. */
  .sts__row--tap::after {
    content: "";
    position: absolute;
    inset: 4px -6px;
    border: 3px solid var(--annotation);
    border-radius: 4px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
