---
/**
 * ScreenNav — the single top nav row used by screens that have a
 * back chevron plus a chapter-mark label. Lays the eyebrow + short
 * rule inline with the back button so the nav reads as one
 * compressed line: a chapter mark with a way out.
 *
 *     ‹          EYEBROW               SETTINGS
 *                  ──                     ──
 *
 * Renders at the ~62px status-bar offset so in-phone content begins
 * just below. The right slot is reserved for the Settings entry
 * point on Preview (V) — a mirrored chapter mark rather than a gear
 * icon, keeps the typographic voice.
 */

interface Props {
  eyebrow?: string;
  backLabel?: string;
  showSettings?: boolean;
}

const { eyebrow, backLabel = "Back", showSettings = false } = Astro.props;
---

<nav class="screen-nav" aria-label={backLabel}>
  <button class="screen-nav__back" type="button" aria-label={backLabel}>
    <span aria-hidden="true">‹</span>
  </button>

  {eyebrow ? (
    <div class="screen-nav__mark">
      <span class="screen-nav__eyebrow">{eyebrow}</span>
      <hr class="screen-nav__rule" aria-hidden="true" />
    </div>
  ) : (
    <span class="screen-nav__mark-placeholder" aria-hidden="true"></span>
  )}

  {showSettings ? (
    <button class="screen-nav__settings" type="button" aria-label="Settings">
      <span class="screen-nav__settings-label">settings</span>
    </button>
  ) : (
    <span class="screen-nav__spacer" aria-hidden="true"></span>
  )}
</nav>

<style>
  /* Symmetric 1fr auto 1fr so the center eyebrow is true-centered
     regardless of what's in the right slot. Back chevron pins to
     the left edge of col 1; right slot pins to the right edge of
     col 3; center column sizes to its content and sits in the
     middle by virtue of equal flex spacers on either side. */
  .screen-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 62px 12px 0;
    gap: 10px;
  }

  .screen-nav__back {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0 0 2px;
    font-family: var(--f-display);
    font-size: 26px;
    line-height: 1;
    color: var(--c-ink);
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  /* Chapter-mark unit. Eyebrow stacked over a short foil/ochre rule,
     the same rhythm as the canonical chapter opener in tokens.css —
     just compressed to nav height. */
  .screen-nav__mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .screen-nav__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .screen-nav__rule {
    display: block;
    border: 0;
    width: 32px;
    height: 1px;
    background: var(--c-ochre);
    margin: 0;
    opacity: 0.7;
  }

  /* Empty center when no eyebrow is supplied — keeps the grid
     shape stable so the back chevron sits at the same position
     regardless of whether this screen has a chapter mark. */
  .screen-nav__mark-placeholder {
    display: block;
    height: 1px;
  }

  /* Right-slot Settings — lowercase italic Lora, T1-style. A literary
     aside, not a chapter mark; no ochre rule underneath (rules are
     reserved for chapter rhythm per tokens.css §DECORATIVE RULES).
     Underline on hover, 3px offset — same voice as inline links. */
  .screen-nav__settings {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .screen-nav__settings-label {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    line-height: 1;
    color: var(--c-ochre);
    letter-spacing: 0em;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    transition: text-decoration-color var(--motion-state) var(--ease-state);
  }
  .screen-nav__settings:hover .screen-nav__settings-label {
    text-decoration-color: currentColor;
  }

  /* Empty right slot when no Settings action — the 1fr grid column
     still balances against col 1 so the center eyebrow stays
     centered; the spacer just holds the column open. */
  .screen-nav__spacer {
    justify-self: end;
    display: block;
    width: 1px;
    height: 1px;
  }
</style>
