---
/**
 * Recipe · detail. The cookbook-page moment — full-bleed hero with scrim,
 * Lora title, ingredients + method on cream. The screen that proves
 * "the app IS the book": typographically indistinguishable in tone from
 * a printed cookbook spread.
 *
 * Editing is per-item via long-press → context menu; there is no Edit
 * button in the chrome. In the binder this screen drives three
 * consecutive main-line moments in Flow I, selected via props:
 *
 *   · default (no props)         — canonical recipe, halo on step iv
 *                                  for the long-press handoff.
 *   · portionAffordance          — eyebrow reads "INGREDIENTS · serves N"
 *                                  as an inline-link cross-reference.
 *   · portionOverlay             — dreamy cream-wash overlay open atop
 *                                  the page, scale strip centered.
 *   · doubled                    — render at serves 8 with doubled
 *                                  ingredient quantities + per-step mise.
 *   · tapTarget                  — which halo to draw when showTap is on:
 *                                  "step-iv" (default) | "serves" |
 *                                  "overlay-8".
 */
import AppHeader from "../ui/AppHeader.astro";
import IngredientsList, { type IngredientComment } from "../ui/IngredientsList.astro";
import MethodList, { type StepComment } from "../ui/MethodList.astro";
import RecipeNotes from "../ui/RecipeNotes.astro";
import { cornRagu, type Recipe } from "~/lib/design/sample-recipe";

interface Props {
  /** Which recipe to render. Defaults to corn ragù — every story
   *  screen in the binder is written about it specifically. The
   *  `/design/screens/recipes/[slug]` dynamic route passes in other
   *  registry recipes so library tiles open into a real detail page. */
  recipe?: Recipe;
  showTap?: boolean;
  /** When set, render this step (0-based) as a live textarea and
   *  use the post-edit wording. Drives the inline edit on screen XI. */
  editingIndex?: number;
  /** When true, skip the AppHeader. Used when an outer screen
   *  (the edit bar on XI) replaces the top chrome. */
  hideHeader?: boolean;
  /** When true and `editingIndex` is set, halo the inline Save
   *  button under the textarea as the next tap target. */
  editSaveTap?: boolean;
  /** Render "· serves N" tappable affordance on the Ingredients eyebrow. */
  portionAffordance?: boolean;
  /** Render the dreamy portion-scale overlay open atop the page. */
  portionOverlay?: boolean;
  /** Use the doubled (serves = 8) ingredient + mise data. */
  doubled?: boolean;
  /** Which tap halo the storyboard should draw. Defaults to step-iv,
   *  which preserves the canonical long-press handoff. "hero" marks
   *  the long-press entry into Flow III's photo arc. "units-tap" /
   *  "units-grams" mark Flow VI's measure flow. */
  tapTarget?:
    | "step-iv"
    | "serves"
    | "overlay-8"
    | "hero"
    | "units-tap"
    | "units-grams";
  /** Optional folio line rendered at the foot of the body — cookbook
   *  folio grammar, e.g. "— page 1 —". */
  folio?: string;
  /** Per-step comment configs, keyed by index. Rendered beneath the
   *  matching method step as an `ItemComment`. Used by Flow V. */
  methodComments?: Record<number, StepComment>;
  /** Per-ingredient comment configs, keyed by index. */
  ingredientComments?: Record<number, IngredientComment>;
  /** Halo a single ingredient row as a long-press target. */
  ingredientTapIndex?: number;
  /** Render the right-side units affordance on the Ingredients eyebrow.
   *  Sets the current units state ("cups" | "grams" | "ounces").
   *  Drives Flow VI (Measures). */
  units?: "cups" | "grams" | "ounces";
  /** When true, the units affordance opens in place into a typographic
   *  radio strip (cups · grams · oz). */
  unitsPickerOpen?: boolean;
  /** When true, the top ingredients list and per-step mise lines render
   *  with weights instead of volumes. */
  unitsConverted?: boolean;
  /** Hero variant — single photo (default) or a multi-photo carousel.
   *  Carousel mode swaps the hero band for a snap-scrollable strip with
   *  a "1 / N" counter pill; the body is unchanged. */
  heroType?: "photo" | "carousel";
  /** Photos for the carousel hero. Required when heroType === "carousel". */
  heroPhotos?: string[];
}
const {
  recipe = cornRagu,
  showTap = false,
  editingIndex,
  hideHeader = false,
  editSaveTap = false,
  portionAffordance = false,
  portionOverlay = false,
  doubled = false,
  tapTarget = "step-iv",
  folio = "page 1",
  methodComments,
  ingredientComments,
  ingredientTapIndex,
  units = "cups",
  unitsPickerOpen = false,
  unitsConverted = false,
  heroType = "photo",
  heroPhotos = [],
} = Astro.props;

/* Variant fallbacks. Stub recipes don't carry edit / doubled / grams
 * fixtures (those are story-specific to corn ragù), so each variant
 * falls back to the base when the recipe doesn't define it — the
 * screen still renders, it just doesn't show the variant content. */
const methodItems = unitsConverted
  ? recipe.methodInGrams ?? recipe.method
  : doubled
    ? recipe.methodDoubled ?? recipe.method
    : editingIndex !== undefined
      ? recipe.editedMethod ?? recipe.method
      : recipe.method;
const ingredientItems = unitsConverted
  ? recipe.ingredientsInGrams ?? recipe.ingredients
  : doubled
    ? recipe.ingredientsDoubled ?? recipe.ingredients
    : recipe.ingredients;
const servesValue = doubled
  ? recipe.servesDoubled ?? recipe.serves
  : recipe.serves;

/* Hero variant. Real photo when the recipe has one; otherwise a
 * toned gradient using the recipe's `tone` (corn / sage / ochre) —
 * same palette LibraryTile uses, so a tile and its detail page read
 * as the same recipe. */
const heroTone = recipe.tone ?? "corn";
const hasPhoto = Boolean(recipe.photo);

/* Scale-strip presets bracket the native yield and stretch up toward a
 * dinner-party size. Honest to how people actually cook — 2 / 4 / 6 /
 * 8 / 12, no 5. */
const stripPresets = [2, 4, 6, 8, 12];

/* Halo dispatch. Only one halo renders at a time, gated by showTap. */
const haloStepIv =
  showTap && editingIndex === undefined && tapTarget === "step-iv";
const haloServes = showTap && tapTarget === "serves";
const haloOverlay8 = showTap && portionOverlay && tapTarget === "overlay-8";
const haloHero = showTap && heroType === "photo" && tapTarget === "hero";
const haloCarousel = showTap && heroType === "carousel";
const haloUnitsTap = showTap && tapTarget === "units-tap";
const haloUnitsPick: "cups" | "grams" | "ounces" | undefined =
  showTap && tapTarget === "units-grams" ? "grams" : undefined;
const carouselTotal = heroPhotos.length;
---

<div class="detail">
  {!hideHeader && <AppHeader variant="title" title="" />}

  {heroType === "photo" ? (
    <div
      class:list={[
        "detail__hero",
        !hasPhoto && `detail__hero--${heroTone}`,
        haloHero && "detail__hero--halo",
      ]}
      aria-hidden="true"
      style={hasPhoto ? `background-image: url(${recipe.photo})` : undefined}
    >
    </div>
  ) : (
    <div
      class:list={["carousel", haloCarousel && "carousel--halo"]}
      role="button"
      aria-label="Open photo gallery"
      tabindex="0"
    >
      <ol class="carousel__track" role="list">
        {heroPhotos.map((src, i) => (
          <li
            class="carousel__slide"
            role="listitem"
            aria-hidden={i !== 0}
            style={`background-image: url(${src})`}
          >
          </li>
        ))}
      </ol>

      <span class="carousel__counter" aria-hidden="true">
        <span class="carousel__counter-num">1</span>
        <span class="carousel__counter-sep">/</span>
        <span class="carousel__counter-den">{carouselTotal}</span>
      </span>
    </div>
  )}

  <div class="detail__body">
    <span class="detail__source">From {recipe.source}</span>
    <h1 class="detail__title">{recipe.title}</h1>
    <p class="detail__lede">{recipe.lede}</p>
    <p class="detail__meta">
      <em>Serves {servesValue}</em>
      <span aria-hidden="true"> · </span>
      <em>{recipe.minutes} minutes</em>
    </p>

    <hr class="detail__rule" />
    {Astro.slots.has("notes") ? <slot name="notes" /> : <RecipeNotes invitation />}

    <hr class="detail__rule" />

    <IngredientsList
      items={ingredientItems}
      servesTap={portionAffordance ? servesValue : undefined}
      haloServesTap={haloServes}
      comments={ingredientComments}
      tapIndex={ingredientTapIndex}
      units={units}
      haloUnitsTap={haloUnitsTap}
      unitsPickerOpen={unitsPickerOpen}
      haloUnitsPick={haloUnitsPick}
    />

    <hr class="detail__rule" />

    <MethodList
      items={methodItems}
      tapIndex={haloStepIv ? 3 : undefined}
      editIndex={editingIndex}
      saveTap={editSaveTap}
      comments={methodComments}
    />

    {folio && <p class="detail__folio">— {folio} —</p>}
  </div>

  {portionOverlay && (
    <div class="scale-overlay" role="dialog" aria-label="Portion scale">
      <div class="scale-overlay__stage">
        <span class="scale-overlay__label">Serves</span>
        <div class="scale-overlay__row">
          <span class="scale-overlay__dash" aria-hidden="true">—</span>
          {stripPresets.map((n, i) => (
            <>
              {i > 0 && <span class="scale-overlay__sep" aria-hidden="true">·</span>}
              <button
                type="button"
                class:list={[
                  "scale-overlay__num",
                  n === servesValue && "is-on",
                  haloOverlay8 && n === 8 && "scale-overlay__num--halo",
                ]}
                aria-pressed={n === servesValue}
              >{n}</button>
            </>
          ))}
          <span class="scale-overlay__dash" aria-hidden="true">—</span>
        </div>
      </div>
    </div>
  )}
</div>

<style>
  .detail {
    display: grid;
    grid-template-rows: auto auto 1fr;
    min-height: 100%;
    padding-bottom: 44px;
  }

  /* Hero — real photograph, title scrim for credit legibility ─── */

  .detail__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .detail__hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 58%, rgba(0, 0, 0, 0.4) 100%);
  }
  /* Toned hero — photoless variant. Same palette as LibraryTile so the
     tile and the detail page read as the same recipe; scaled and
     repositioned for the larger hero canvas (light source upper-left,
     warm darkness lower-right). Drop a real `photo` on the recipe
     and the override gives way. */
  .detail__hero--corn {
    background: radial-gradient(ellipse at 22% 18%, #f5d990 0%, #d6a34e 50%, #8a5c1f 100%);
  }
  .detail__hero--sage {
    background: radial-gradient(ellipse at 22% 18%, #7d9b8a 0%, #4a6a58 55%, #243829 100%);
  }
  .detail__hero--ochre {
    background: radial-gradient(ellipse at 22% 18%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }
  /* Storyboard halo — long-press handoff into Flow IV's photo arc. */
  .detail__hero--halo::before {
    content: "";
    position: absolute;
    inset: 6px;
    border: 3px solid var(--annotation);
    border-radius: 2px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* Carousel hero — same physical real estate as the single-photo hero
     (full-width, 5:4) but a snap-scrollable strip with a "1 / N" counter
     pill bottom-right. Realtor / Airbnb grammar. The whole image is the
     tap target — the pill is a visual indicator, not a button. */

  .carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background-color: var(--c-oat);
  }

  .carousel__track {
    display: flex;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .carousel__track::-webkit-scrollbar { display: none; }

  .carousel__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    scroll-snap-align: start;
  }
  .carousel__slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 62%, rgba(0, 0, 0, 0.34) 100%);
  }

  .carousel__counter {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    padding: 6px 12px;
    background: rgba(20, 16, 12, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #fff;
    border-radius: 999px;
    font-family: var(--f-body);
    font-size: 11.5px;
    letter-spacing: 0.02em;
    pointer-events: none;
    z-index: 2;
  }
  .carousel__counter-num { font-weight: 500; }
  .carousel__counter-sep { opacity: 0.6; }
  .carousel__counter-den { opacity: 0.85; }

  .carousel--halo::after {
    content: "";
    position: absolute;
    inset: 6px;
    border: 3px solid var(--annotation);
    border-radius: 2px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* Body ─────────────────────────────────────────────────── */

  .detail__body {
    padding: 22px 24px 18px;
    display: grid;
    gap: 10px;
  }

  .detail__source {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .detail__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 30px;
    line-height: 1.08;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  .detail__lede {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--c-ash);
    max-width: 36ch;
    margin-top: 2px;
  }

  .detail__meta {
    font-family: var(--f-display);
    font-size: 13px;
    color: var(--c-ash);
    margin-top: 4px;
  }
  .detail__meta em {
    font-style: italic;
    color: var(--c-ink);
  }

  .detail__rule {
    border: 0;
    height: 1px;
    background: rgba(31, 27, 23, 0.1);
    margin: 12px 0;
  }

  .detail__folio {
    margin: 28px 0 0;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--c-oat);
    text-align: center;
  }

  /* Portion-scale overlay ──────────────────────────────────
     Triggered by tapping "serves N" on the Ingredients eyebrow. The
     page lightens and blurs (cream wash at ~74% + backdrop blur) so
     attention lands on the centered strip. No card, no border, no
     pill — the blur IS the container. Typography-only, book-native.

     ANCHORING: position: fixed relative to the transformed phone
     ancestor (.stage__phone / .phone--canvas both carry a transform,
     which becomes the containing block for fixed descendants). The
     bezel inset + matching inner radius land the overlay exactly on
     the screen rectangle; each phone on a storyboard page anchors to
     its own transform, so multiple overlays coexist cleanly.

     NOTE ON THE MODAL BAN: tokens.css bans modals "when there is any
     better alternative." This overlay is founder-approved for this
     interaction specifically; it's intended to read as a theatrical
     dim-down moment, not a dialog with dismiss chrome. */

  .scale-overlay {
    /* Pin to the phone SCREEN, not the scroll viewport. The .phone and
       its wrappers (.stage__phone, .phone--canvas) carry a CSS transform
       which means position: fixed is contained inside the phone's
       bounding box (per spec: a transformed ancestor becomes the
       containing block for fixed descendants). Insetting by the bezel
       lands the overlay exactly on the screen rectangle, and matching
       the inner screen radius keeps the clip honest. Each phone on a
       storyboard page anchors to its own transform, so multiple
       overlays coexist cleanly. */
    position: fixed;
    top: var(--phone-bezel);
    left: var(--phone-bezel);
    right: var(--phone-bezel);
    bottom: var(--phone-bezel);
    border-radius: var(--phone-radius-inner);
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    /* Cream wash — lightens the page without going dark. Tinted warmer
       than a neutral scrim so the overlay feels like sunlight through
       linen, not a modal shade. */
    background: color-mix(in oklab, var(--c-cream) 74%, transparent);
    backdrop-filter: blur(10px) saturate(1.04);
    -webkit-backdrop-filter: blur(10px) saturate(1.04);
  }

  .scale-overlay__stage {
    display: grid;
    justify-items: center;
    gap: 18px;
    padding: 40px 28px;
  }

  .scale-overlay__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }

  .scale-overlay__row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
  }

  .scale-overlay__dash {
    font-size: 22px;
    color: var(--c-ochre);
    opacity: 0.55;
    line-height: 1;
  }
  .scale-overlay__sep {
    font-size: 18px;
    color: var(--c-ochre);
    opacity: 0.45;
    line-height: 1;
  }
  .scale-overlay__num {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 4px 6px 6px;
    margin: 0;
    font: inherit;
    font-size: 22px;
    color: var(--c-ash);
    cursor: pointer;
    position: relative;
    line-height: 1;
    transition:
      color var(--motion-state) var(--ease-state),
      font-size var(--motion-state) var(--ease-state);
  }
  .scale-overlay__num:hover { color: var(--c-ink); }
  /* Selected yield — meaningfully larger, Ink colored, with the 44×1.5px
     chapter-rule hairline narrowed to the numeral's width. Size jump is
     the hierarchy move; no bold. */
  .scale-overlay__num.is-on {
    color: var(--c-ink);
    font-size: 32px;
  }
  .scale-overlay__num.is-on::after {
    content: "";
    position: absolute;
    left: 6px;
    right: 6px;
    bottom: 0;
    height: 1.5px;
    background: var(--c-ochre);
  }
  /* Storyboard halo on the preset the user is about to tap. */
  .scale-overlay__num--halo::before {
    content: "";
    position: absolute;
    inset: -6px -4px;
    border: 3px solid var(--annotation);
    border-radius: 8px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
