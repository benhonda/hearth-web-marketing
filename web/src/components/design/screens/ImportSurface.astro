---
/**
 * Screen III · Import · surface (and its pasted sibling).
 *
 * The entry point into the import flow. A TEXTAREA — not a single-line
 * field — accepts whatever the cook hands it: a link, a recipe texted
 * from a friend, a chunk pasted from Notes. The AI auto-detects what it
 * got. Below, a co-equal "Scan a photo" doorway with an em-dash "or"
 * divider between. Both options visible at once; the cook picks by
 * acting.
 *
 * Two states share one component:
 *   pasted = false  → empty textarea, halo on the input. Photo doorway
 *                     visible below the divider.
 *   pasted = true   → recipe text filled in, photo doorway falls away
 *                     (paste path committed), full-width Foil-Light
 *                     Primary pill "Import" appears below, halo'd as
 *                     the next tap. Same Primary grammar as Flow II's
 *                     "Send to Hearth Press."
 */
interface Props {
  showTap?: boolean;
  /** False shows the empty textarea + photo doorway; true fills the
   *  textarea with sample paste content and moves the halo to Import. */
  pasted?: boolean;
}
const { showTap = false, pasted = false } = Astro.props;

// A chunk of recipe text the way a friend might text it — lowercased,
// loose punctuation, em-dash, no emoji. Demonstrates the textarea
// accepts arbitrary blobs, not just URLs.
const pastedSample =
  "corn ragu — 4 ears corn, 1 shallot diced, 1 cup white wine, 3 tbsp butter, basil. sauté shallot in olive oil, add corn + wine, reduce, finish with butter and torn basil. serves 4";
---

<div class="imp">
  <header class="imp-bar">
    <button class="imp-bar__cancel" type="button">Cancel</button>
    <span class="imp-bar__eyebrow">Bring in a recipe</span>
    <span class="imp-bar__spacer" aria-hidden="true"></span>
  </header>

  <div class="imp__body">
    <div class="opener">
      <hr class="opener__rule" aria-hidden="true" />
      <span class="opener__eyebrow">From anywhere</span>
      <p class="opener__title">Bring a recipe<br />home.</p>
    </div>

    <label
      class={showTap && !pasted ? "field field--tap" : "field"}
      for="imp-paste"
    >
      <span class="field__label">Paste a link or recipe</span>
      <div class="field__textarea" id="imp-paste">
        {pasted ? (
          <span class="field__content">{pastedSample}</span>
        ) : (
          <span class="field__placeholder">Paste a link, or a recipe from Messages or Notes</span>
        )}
        {!pasted && <span class="field__caret" aria-hidden="true"></span>}
      </div>
    </label>

    {!pasted && (
      <>
        <div class="imp__divider" aria-hidden="true">
          <span>— or —</span>
        </div>
        <button class="imp__photo" type="button">Scan a photo</button>
      </>
    )}

    {pasted && (
      <button
        class={showTap ? "imp__primary imp__primary--tap" : "imp__primary"}
        type="button"
      >Import</button>
    )}
  </div>
</div>

<style>
  .imp {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
    padding-bottom: 44px; /* home indicator clearance */
  }

  /* Top bar — same grammar as ImportPreview so the import arc reads as
     a continuous surface. */
  .imp-bar {
    padding: 62px 22px 14px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(31, 27, 23, 0.08);
  }
  .imp-bar__cancel {
    justify-self: flex-start;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--c-ash);
  }
  .imp-bar__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    white-space: nowrap;
  }
  .imp-bar__spacer { display: block; }

  /* Body — chapter-opener, paste textarea, "or" divider, photo doorway.
     Vertical rhythm tuned so the textarea sits high enough that the
     full doorway pair (textarea + photo) reads in the upper two-thirds
     of the visible area. */
  .imp__body {
    padding: 32px 22px 0;
    display: grid;
    gap: 28px;
    align-content: start;
  }

  /* Chapter-opener — eyebrow + 44×1.5px Ochre rule + italic Lora display.
     Short measure so the title balances cleanly across two lines. */
  .opener {
    display: grid;
    justify-items: center;
    gap: 12px;
    text-align: center;
    max-width: 28ch;
    justify-self: center;
  }
  .opener__rule {
    width: 44px;
    height: 1.5px;
    background: var(--c-ochre);
    border: 0;
    margin: 0;
  }
  .opener__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .opener__title {
    margin: 4px 0 0;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 30px;
    line-height: 1.12;
    letter-spacing: -0.006em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  /* Paste textarea — the new primitive. Multi-line height (~120px) so it
     reads as a "blob input" not a URL field. Square corners (--r-page
     = 2px), label small-caps Ochre. The "textarea" is mocked as a
     styled div with placeholder/content + a slim caret in the empty
     state to signal focus. */
  .field {
    position: relative;
    display: grid;
    gap: 6px;
  }
  .field__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .field__textarea {
    display: block;
    position: relative;
    padding: 14px 16px;
    border: 1px solid rgba(31, 27, 23, 0.18);
    background: var(--c-input);
    border-radius: 2px;
    min-height: 124px;
  }
  .field__placeholder {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 16px;
    line-height: 1.5;
    color: var(--c-oat);
  }
  .field__content {
    display: block;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--c-ink);
  }
  /* A slim Ochre caret — present in the empty state so the field reads
     as focused (the user has just tapped in). Sits inline at the start
     of the placeholder. */
  .field__caret {
    position: absolute;
    top: 14px;
    left: 16px;
    width: 1px;
    height: 18px;
    background: var(--c-ochre);
  }
  .field__caret + .field__placeholder,
  .field__placeholder + .field__caret {
    margin-left: 4px;
  }

  .field--tap::after {
    content: "";
    position: absolute;
    inset: 22px -4px -4px -4px;
    border: 3px solid var(--annotation);
    border-radius: 4px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* "— or —" divider — italic Lora Oat with em-dash bookends, centered.
     Matches the chapter-mark / yield-strip / measure-strip vocabulary
     already in the system. Quiet voice; this is connective tissue. */
  .imp__divider {
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 13px;
    color: var(--c-oat);
    letter-spacing: 0.04em;
  }

  /* Scan a photo — S1 outlined pill, full-width, 52px. tokens.css
     COMPONENT TREATMENTS · BUTTONS · Secondary S1: outlined,
     transparent fill, 1px Deep Conifer border, pill, hover inverts to
     filled. Co-equal doorway to the textarea above; both visible at
     once, the cook picks by acting. */
  .imp__photo {
    display: block;
    width: 100%;
    height: 52px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--c-conifer);
    color: var(--c-ink);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      background-color var(--motion-state) var(--ease-state),
      color var(--motion-state) var(--ease-state);
  }
  .imp__photo:hover {
    background: var(--c-conifer);
    color: var(--c-ink-inverse);
  }

  /* Primary "Import" CTA — only renders in the pasted state. Full-width
     Foil-Light pill, same grammar as BookReview's "Send to Hearth
     Press" Primary (tokens.css COMPONENT TREATMENTS · BUTTONS ·
     Primary). 52px tall pill, Warm Charcoal text, --shadow-button,
     halo wraps with -6px inset. */
  .imp__primary {
    position: relative;
    display: block;
    width: 100%;
    height: 52px;
    border-radius: 999px;
    background: var(--c-foil-light);
    color: var(--c-ink);
    border: 0;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.01em;
    cursor: pointer;
    box-shadow: var(--shadow-button);
    transition: background-color var(--motion-state) var(--ease-state);
  }
  .imp__primary:hover { background: var(--c-foil-hover); }
  .imp__primary--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
