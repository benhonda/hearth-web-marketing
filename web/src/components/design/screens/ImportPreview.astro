---
/**
 * Screen V · Import preview — really the structured edit.
 *
 * The shared destination for all three import doorways. An unsaved
 * import is, by definition, an editing surface — the cook is reviewing
 * AI-extracted content before committing it to the library. So the
 * page is ALWAYS in edit mode: top bar reads "Cancel · EDITING · Save"
 * and every editable field carries its affordance at all times. Save
 * commits to the library.
 *
 * Per-field editability:
 *   · Title           → Lora display, plain text, caret on tap
 *   · Serves N        → small dotted-Ochre underline on the numeral
 *                       (carried into the ingredients eyebrow's
 *                       SERVES N twin so the two stay synced)
 *   · Time            → dotted-underline minutes (URL/text only —
 *                       handwritten cards rarely carry one)
 *   · Notes           → RecipeNotes block; populated from AI
 *                       extraction on the photo path (Grandma's voice
 *                       arrives already in the margin), empty
 *                       invitation otherwise
 *   · Ingredients     → type-aware inline trio per line: qty (dotted
 *                       underline), unit (dotted underline + ▾ —
 *                       combobox grammar, accepts "knob", "small
 *                       handful", "to taste"), name (plain text)
 *   · Method steps    → MethodList grammar; each step's text is
 *                       editable in place, AI-extracted inline
 *                       comments arrive pre-populated where the
 *                       source carried marginalia
 *
 * Source variants share one layout — the only delta is the hero slot
 * and the from-card chip:
 *   · url   — food hero (extracted from the source page) with
 *             photographer credit; "From [url]" chip above
 *   · photo — empty hero placeholder ("— add a photo —"); no chip.
 *             The cook's actual photograph of the source is preserved
 *             in data, not re-rendered here. Content matches the
 *             transcription gate (Grandma's Corn Ragu, serves 4, no
 *             minutes).
 *   · text  — empty hero placeholder; no chip
 */
import RecipeNotes from "../ui/RecipeNotes.astro";
import MethodList from "../ui/MethodList.astro";
import ItemComment from "../ui/ItemComment.astro";
import type { MethodStep } from "~/lib/design/sample-recipe";
import { sampleRecipe } from "~/lib/design/sample-recipe";

interface Props {
  showTap?: boolean;
  /** Where the recipe came from. Drives the hero, the from-card, and
   *  the recipe content shown — the photo path renders Grandma's
   *  Corn Ragu (matching the transcription gate); URL/text render the
   *  canonical table.kitchen corn ragù.
   *
   *  url   → food hero + From-URL chip + sample recipe
   *  photo → paper-warmth artifact hero + photo-extracted recipe
   *  text  → food hero (fallback) + no chip + sample recipe
   */
  source?: "url" | "photo" | "text";
  /** Optional active inline editor — when set, that specific field
   *  renders in its open editing state (the rest of the page is
   *  already always editing — there's no view-mode for an unsaved
   *  import; it's an editing surface by definition).
   *
   *  unit-picker → the unit combobox on the white-wine line is open,
   *                replacing the closed [cup ▾] token with a radio
   *                strip ("— tsp · Tbsp · cup · g · other —"). Current
   *                selection (cup) larger + Ink with the chapter-rule
   *                hairline beneath. "g" carries the storyboard tap
   *                halo — the cook is converting volume to weight.
   */
  editing?: "unit-picker";
}

const { showTap = false, source = "url", editing } = Astro.props;
const isPhoto = source === "photo";
// URL path inherits the food photo extracted from the source page.
// Photo/text paths show an empty hero slot inviting an upload — the
// cook adds a dish photo after they've actually cooked it (the
// "imperfect, true-to-phone" photography rule, tokens.css).
const heroPhoto = !isPhoto && source !== "text" ? sampleRecipe.photo : null;
// Index of the white-wine line in the URL ingredient list — the
// line we open the unit picker on for the edit-demo screen. Picked
// because it sits high enough in the list to render in the visible
// phone viewport, AND its unit ("cup") is a standard volume measure
// that demonstrates the volume→weight switch the combobox supports.
const PICKER_INDEX = 3;

/* Per-source recipe content. ----------------------------------- */

type ParsedIngredient = {
  /** undefined = no quantity slot (the "to taste" case). */
  qty?: string;
  /** undefined = no unit slot (bare-count case: "1 shallot"). Any
   *  string value renders the combobox affordance — free text accepted
   *  for the long tail (knob, pinch, "small handful", "to taste"). */
  unit?: string;
  name: string;
  comment?: string;
};

const recipeTitle = isPhoto ? "Grandma's Corn Ragu" : sampleRecipe.title;
const recipeServes = isPhoto ? 4 : sampleRecipe.serves;
const recipeMinutes: number | undefined = isPhoto ? undefined : sampleRecipe.minutes;

const recipeIngredients: ParsedIngredient[] = isPhoto
  ? [
      { qty: "4", unit: "ears", name: "corn, kernels cut off the cob" },
      { qty: "1", name: "large shallot, finely diced" },
      { qty: "2", unit: "Tbsp", name: "olive oil" },
      { qty: "1", unit: "cup", name: "dry white wine" },
      { qty: "3", unit: "Tbsp", name: "unsalted butter" },
      {
        unit: "small handful",
        name: "basil, torn",
        comment: "grandma was heavier-handed",
      },
    ]
  : [
      { qty: "6", unit: "ears", name: "sweet corn, kernels scraped (cobs reserved)" },
      { qty: "1", name: "shallot, minced" },
      { qty: "3", unit: "cloves", name: "garlic, thinly sliced" },
      { qty: "1", unit: "cup", name: "dry white wine" },
      {
        qty: "1",
        unit: "Tbsp",
        name: "white miso",
        comment: "Cultured if I have it.",
      },
      { qty: "1", unit: "cup", name: "basil leaves, torn" },
      { qty: "3", unit: "Tbsp", name: "unsalted butter" },
      { name: "Olive oil, salt, black pepper" },
    ];

const recipeMethod: MethodStep[] = isPhoto
  ? [
      { text: "sauté shallot in olive oil, 2 minutes", mise: [] },
      { text: "add corn and wine, simmer until reduced", mise: [] },
      { text: "swirl in butter at the end", mise: [] },
      { text: "top with basil and a little salt", mise: [] },
    ]
  : sampleRecipe.method;

// AI-extracted inline comments — arrive pre-populated when the source
// carried embedded marginalia. URL path: a habitual variation note on
// the miso line — Flow V grammar repurposed for AI extraction. Photo
// path: a margin note on step ii of grandma's card.
const methodComments: Record<number, { text: string }> = isPhoto
  ? { 1: { text: "or until barely glossy" } }
  : { 3: { text: "10–12 minutes — thickens better." } };

const recipeNote = isPhoto ? "From Grandma Ruth's recipe box." : "";
---

<div class="ip">
  <header class="ip-bar">
    <button class="ip-bar__cancel" type="button">Cancel</button>
    <span class="ip-bar__eyebrow">Editing</span>
    <button
      class={showTap && !editing ? "ip-bar__action ip-bar__action--tap" : "ip-bar__action"}
      type="button"
    >Save</button>
  </header>

  <div class="ip__body">
    {source === "url" && (
      <div class="from-card">
        <span class="from-card__eyebrow">From</span>
        <span class="from-card__url">{sampleRecipe.source}</span>
      </div>
    )}

    {heroPhoto ? (
      <div
        class="hero"
        aria-hidden="true"
        style={`background-image: url(${heroPhoto})`}
      >
        <span class="hero__credit">photograph · Mia Aquilina</span>
      </div>
    ) : (
      <button class="hero hero--empty" type="button">
        <span class="hero__invite">— add a photo —</span>
      </button>
    )}

    <h1 class="ip__title">{recipeTitle}</h1>

    <p class="ip__meta">
      <em>Serves </em><button class="ip__num-edit" type="button">{recipeServes}</button>
      {recipeMinutes !== undefined && (
        <>
          <span class="ip__meta-sep" aria-hidden="true"> · </span>
          <button class="ip__num-edit" type="button">{recipeMinutes}</button><em> min</em>
        </>
      )}
    </p>

    <hr class="ip__rule" />

    <RecipeNotes text={recipeNote} invitation={!recipeNote} />

    <hr class="ip__rule" />

    <section class="ing">
      <span class="ing__eyebrow-row">
        <span class="ing__eyebrow">Ingredients</span>
        <span class="ing__sep" aria-hidden="true">·</span>
        <span class="ing__serves">serves <button class="ing__serves-num" type="button">{recipeServes}</button></span>
      </span>

      <ul class="ing__list">
        {recipeIngredients.map((it, i) => {
          const isPickerOpen =
            editing === "unit-picker" && !isPhoto && i === PICKER_INDEX;
          return (
            <li class="ing__li">
              {!isPickerOpen && (
                <span class="ing__row">
                  <span class="ing__inputs">
                    {it.qty !== undefined && (
                      <button class="ing__qty" type="button">{it.qty || "·"}</button>
                    )}
                    {it.unit !== undefined && (
                      <button class="ing__unit" type="button">
                        <span class="ing__unit-text">{it.unit || "—"}</span>
                        <span class="ing__unit-chev" aria-hidden="true">▾</span>
                      </button>
                    )}
                  </span>
                  <span class="ing__name">{it.name}</span>
                </span>
              )}
              {isPickerOpen && (
                <>
                  <span class="ing__row ing__row--editing">
                    <span class="ing__qty-static">{it.qty}</span>
                    <span class="ing__unit-picker" role="radiogroup" aria-label="Unit">
                      <span class="ing__unit-dash" aria-hidden="true">—</span>
                      <button type="button" class="ing__unit-opt">tsp</button>
                      <span class="ing__unit-mid" aria-hidden="true">·</span>
                      <button type="button" class="ing__unit-opt">Tbsp</button>
                      <span class="ing__unit-mid" aria-hidden="true">·</span>
                      <button type="button" class="ing__unit-opt is-on" aria-pressed="true">cup</button>
                      <span class="ing__unit-mid" aria-hidden="true">·</span>
                      <button type="button" class={showTap ? "ing__unit-opt ing__unit-opt--halo" : "ing__unit-opt"}>g</button>
                      <span class="ing__unit-mid" aria-hidden="true">·</span>
                      <button type="button" class="ing__unit-opt">other</button>
                      <span class="ing__unit-dash" aria-hidden="true">—</span>
                    </span>
                  </span>
                  <span class="ing__name ing__name--wrapped">{it.name}</span>
                </>
              )}
              {it.comment && <ItemComment text={it.comment} />}
            </li>
          );
        })}
      </ul>
    </section>

    <hr class="ip__rule" />

    <MethodList items={recipeMethod} comments={methodComments} />
  </div>
</div>

<style>
  .ip {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
    padding-bottom: 44px; /* home indicator clearance */
  }

  /* Top bar ─────────────────────────────────────────────────── */

  .ip-bar {
    padding: 62px 22px 14px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(31, 27, 23, 0.08);
  }
  .ip-bar__cancel {
    justify-self: flex-start;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--c-ash);
  }
  .ip-bar__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .ip-bar__action {
    position: relative;
    justify-self: flex-end;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14px;
    color: var(--c-ochre);
    padding: 4px 8px;
  }

  /* Save halo — sits on the top-bar Save action when the binder is
     marking it as the next tap target. */
  .ip-bar__action--tap::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  .ip__body {
    padding: 20px 22px 0;
    display: grid;
    gap: 18px;
  }

  /* From card — URL only. Photo path's hero IS the from-card
     semantically; rendering both would double-attribute. */
  .from-card {
    display: inline-flex;
    gap: 10px;
    align-items: baseline;
    padding: 10px 12px;
    background: rgba(122, 90, 38, 0.06);
    border-radius: 2px;
    justify-self: flex-start;
  }
  .from-card__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .from-card__url {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 13px;
    color: var(--c-ink);
  }

  /* Hero ────────────────────────────────────────────────────── */

  .hero {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 2px;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(0, 0, 0, 0.4) 100%);
  }
  .hero__credit {
    position: absolute;
    bottom: 8px;
    right: 10px;
    font-family: var(--f-body);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    z-index: 1;
  }

  /* Empty hero — when the recipe arrived without a dish photo (photo
     and text paths). Same 4:3 footprint as the food hero so the page
     layout doesn't shift when a photo is added. Quiet --c-input
     background (slightly lighter than the page) with an italic-Ochre
     "— add a photo —" invitation centered. Same em-dash bookend
     grammar as Hearth's other invitations ("— add a note —"). Tap
     opens the OS source sheet (Take Photo / Choose from Library). */
  .hero--empty {
    appearance: none;
    -webkit-appearance: none;
    background: var(--c-input);
    background-image: none;
    border: 1px dashed rgba(122, 90, 38, 0.22);
    cursor: pointer;
    display: grid;
    place-content: center;
    padding: 0;
  }
  .hero--empty::after { display: none; }
  .hero__invite {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    color: var(--c-ochre);
    letter-spacing: 0.005em;
  }

  /* Title ───────────────────────────────────────────────────── */

  /* Plain Lora display heading — no form-field box, no border, no
     input chrome. The cookbook-page voice is the affordance; tap-to-
     edit is implicit. */
  .ip__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.008em;
    color: var(--c-ink);
    margin: 0;
  }

  /* Meta line ──────────────────────────────────────────────── */

  .ip__meta {
    margin: -2px 0 0;
    font-family: var(--f-display);
    font-size: 14px;
    color: var(--c-ash);
  }
  .ip__meta em {
    font-style: italic;
    color: var(--c-ash);
  }
  .ip__meta-sep { color: var(--c-ash); }

  /* Inline-edit affordance for numeric values (serves, minutes). The
     only chrome that distinguishes them as editable is a 0.75px
     dotted-Ochre underline at a 2.5px offset — tight enough that on
     italic Lora it reads book-typographic, not URL-y. Hover lifts
     color to Ink. */
  .ip__num-edit {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 0 1px;
    margin: 0;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 14px;
    line-height: inherit;
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 0.75px;
    text-decoration-color: var(--c-ochre);
    text-underline-offset: 2.5px;
    cursor: pointer;
    transition: color var(--motion-state) var(--ease-state);
  }
  .ip__num-edit:hover { color: var(--c-ink); }

  /* Rule ────────────────────────────────────────────────────── */

  .ip__rule {
    border: 0;
    height: 1px;
    background: rgba(31, 27, 23, 0.08);
    margin: 4px 0;
  }

  /* Ingredients (custom inline-editable) ───────────────────── */

  .ing__eyebrow-row {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 10px;
  }
  .ing__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .ing__sep {
    font-family: var(--f-body);
    color: var(--c-ochre);
    opacity: 0.45;
    font-size: 10px;
  }
  .ing__serves {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  /* Inline serves N — same dotted-Ochre underline as meta numerics so
     the two stay grammatically synced. */
  .ing__serves-num {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    font: inherit;
    color: var(--c-ochre);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 0.75px;
    text-decoration-color: var(--c-ochre);
    text-underline-offset: 2.5px;
    cursor: pointer;
  }

  .ing__list {
    display: grid;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .ing__li {
    padding-left: 14px;
    position: relative;
  }
  .ing__li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 6px;
    height: 1px;
    background: var(--c-ochre);
    opacity: 0.85;
  }

  /* Each ingredient row sits on a baseline grid: a fixed-width inputs
     gutter (qty + unit) on the left, free-flowing name on the right.
     Lines without inputs (the "to taste" case) collapse the gutter
     and the name fills the row. */
  .ing__row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--c-ink);
  }
  .ing__inputs {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    flex-shrink: 0;
  }
  .ing__inputs:empty { display: none; }

  /* Quantity — dotted-Ochre underline. Same grammar as the meta
     numeric edit so the entire page reads as one editable surface. */
  .ing__qty {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 0 1px;
    margin: 0;
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: inherit;
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 0.75px;
    text-decoration-color: var(--c-ochre);
    text-underline-offset: 2.5px;
    cursor: pointer;
    min-width: 1ch;
  }

  /* Unit — combobox grammar. Same dotted underline, plus a small
     ▾ chevron in Ochre that signals a constrained-but-accepting-free-
     text dropdown. The unit slot accepts standard units (tsp, Tbsp,
     cup, oz, g, ml) AND the long tail (knob, pinch, dash, "small
     handful", "to taste") — which is why the chevron is paired with a
     freely editable text payload, not a hard select. */
  .ing__unit {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 0 1px;
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: inherit;
    color: var(--c-ink);
    cursor: pointer;
  }
  .ing__unit-text {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 0.75px;
    text-decoration-color: var(--c-ochre);
    text-underline-offset: 2.5px;
  }
  .ing__unit-chev {
    font-size: 9px;
    color: var(--c-ochre);
    line-height: 1;
    opacity: 0.7;
    transform: translateY(-1px);
  }

  /* Name — plain text. Tap-to-edit is implicit; no decoration. */
  .ing__name {
    flex: 1 1 auto;
    min-width: 0;
  }


  /* Edit state — the unit combobox blooms in place. The closed
     "[Tbsp ▾]" token is replaced by a typographic radio strip with
     em-dash bookends and middot separators, in the same vocabulary
     as Flow VI's measure picker (cups/grams/oz on the eyebrow row).
     Italic Lora Ochre; current selection larger and Ink with the
     chapter-rule hairline beneath, exactly like the units picker.
     The name flows beneath the strip on its own line so the picker
     gets the full row's width and the name still reads. */
  .ing__row--editing {
    flex-wrap: nowrap;
    align-items: baseline;
    gap: 6px;
  }
  .ing__qty-static {
    font-family: var(--f-body);
    font-size: 13.5px;
    color: var(--c-ink);
  }
  .ing__name--wrapped {
    display: block;
    margin-top: 4px;
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--c-ink);
  }

  .ing__unit-picker {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
    line-height: 1.2;
    flex: 1 1 auto;
    min-width: 0;
  }
  .ing__unit-dash {
    font-size: 13px;
    color: var(--c-ochre);
    opacity: 0.55;
    line-height: 1;
  }
  .ing__unit-mid {
    font-size: 12px;
    color: var(--c-ochre);
    opacity: 0.45;
    line-height: 1;
  }
  .ing__unit-opt {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 2px 1px 4px;
    margin: 0;
    font: inherit;
    font-size: 13px;
    color: var(--c-ash);
    cursor: pointer;
    position: relative;
    line-height: 1;
    transition: color var(--motion-state) var(--ease-state);
  }
  .ing__unit-opt:hover { color: var(--c-ink); }
  .ing__unit-opt.is-on {
    color: var(--c-ink);
    font-size: 16px;
  }
  .ing__unit-opt.is-on::after {
    content: "";
    position: absolute;
    left: 1px;
    right: 1px;
    bottom: 0;
    height: 1.5px;
    background: var(--c-ochre);
  }
  .ing__unit-opt--halo::before {
    content: "";
    position: absolute;
    inset: -5px -4px;
    border: 3px solid var(--annotation);
    border-radius: 6px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
