      gap: var(--space-lg);
    }
    .exp-row__insp { position: static; }
  }

  /* ──────────────────────────────────────────────────────────────
     COVERS — all 320 × 400. `.xc` is the concept-sketch equivalent
     of `.cov`; kept separate so real BookCover internals don't mix
     with exploration styles.
     ────────────────────────────────────────────────────────────── */
  .xc {
    position: relative;
    width: 320px;
    aspect-ratio: 4 / 5;
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
    color: var(--c-ink-inverse);
    display: grid;
    justify-items: center;
  }
  /* Shared cloth weave — matches .cov--plate's double-diagonal pattern */
  .xc--cloth {
    background-image:
      repeating-linear-gradient(45deg,  transparent 0, transparent 3px, rgba(244,239,230,0.012) 3px, rgba(244,239,230,0.012) 4px),
      repeating-linear-gradient(-45deg, transparent 0, transparent 3px, rgba(0,0,0,0.03) 3px, rgba(0,0,0,0.03) 4px);
  }

  .xc__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--c-foil-light);
  }
  .xc__eyebrow-rule {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--c-foil);
    opacity: 0.65;
  }
  .xc__title {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 30px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--c-foil);
    margin: 0;
    text-align: center;
    text-wrap: balance;
  }
  .xc__subtitle, .xc__sub {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 13px;
    color: var(--c-linen);
    margin: 0;
    text-align: center;
    text-wrap: balance;
  }
  .xc__author {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--c-foil);
    align-self: end;
  }
  .xc__wordmark {
    font-family: var(--f-wordmark);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--c-foil);
    align-self: end;
    opacity: 0.9;
  }
  .xc__plate {
    width: 58%;
    aspect-ratio: 4 / 5;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    border-radius: var(--r-page);
    box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.35), 0 3px 8px rgba(0,0,0,0.28);
  }
  .xc__plate--sm { width: 44%; }
  .xc__plate--40 { width: 40%; }
  .xc__plate--55 { width: 56%; }

  /* Ink-dark text for cream-ground covers (minimal, art-of-home, window) */
  .xc--ink { color: var(--c-ink) !important; }

  /* ─ 1 · title-top ─────────────────────────────────────── */
  .xc--title-top {
    background: var(--c-conifer);
    background-image:
      repeating-linear-gradient(45deg,  transparent 0, transparent 3px, rgba(244,239,230,0.012) 3px, rgba(244,239,230,0.012) 4px),
      repeating-linear-gradient(-45deg, transparent 0, transparent 3px, rgba(0,0,0,0.03) 3px, rgba(0,0,0,0.03) 4px);
    grid-template-rows: auto auto auto auto 1fr auto;
    gap: 8px;
    padding: 28px 24px 26px;
  }
  .xc--title-top .xc__title { margin-top: 2px; }
  .xc--title-top .xc__plate { width: 64%; margin-top: 8px; }

  /* ─ 2 · italian ───────────────────────────────────────── */
  .xc--italian {
    background: #f7f2e8;
    grid-template-rows: auto auto auto 1fr;
    gap: 16px;
    padding: 40px 28px 28px;
    color: var(--c-ink);
  }
  .xc__bigtype {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 64px;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--c-ink);
    margin: 0;
    text-align: center;
    text-transform: uppercase;
  }
  .xc__tag {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 11px;
    color: var(--c-ash);
    margin: 0;
    text-align: center;
  }
  .xc--italian .xc__tag { align-self: end; }

  /* ─ 3 · window ────────────────────────────────────────── */
  .xc--window {
    background: #e8d5c4; /* warm dusty tone — no token, sketch-inline */
    grid-template-rows: auto auto 1fr auto;
    justify-items: start;
    padding: 24px 24px 18px;
    gap: 4px;
  }
  .xc--window .xc__title--left {
    text-align: left;
    color: var(--c-ink);
    font-size: 34px;
    font-style: italic;
    letter-spacing: -0.015em;
  }
  .xc--window .xc__sub--left {
    text-align: left;
    color: var(--c-ochre);
    font-style: italic;
    font-size: 12px;
    max-width: 20ch;
  }
  .xc__win {
    width: 100%;
    height: 62%;
    margin-top: 10px;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    border-radius: var(--r-page);
    box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.22), 0 3px 8px rgba(0,0,0,0.18);
    align-self: end;
  }
  .xc--window .xc__author {
    position: absolute;
    left: 24px;
    bottom: 16px;
    color: var(--c-ochre);
  }

  /* ─ 4 · display ───────────────────────────────────────── */
  .xc--display {
    background: var(--c-conifer);
    background-image:
      repeating-linear-gradient(45deg,  transparent 0, transparent 3px, rgba(244,239,230,0.012) 3px, rgba(244,239,230,0.012) 4px),
      repeating-linear-gradient(-45deg, transparent 0, transparent 3px, rgba(0,0,0,0.03) 3px, rgba(0,0,0,0.03) 4px);
    grid-template-rows: auto 1fr auto auto;
    padding: 28px 24px 26px;
    gap: 8px;
  }
  .xc__display {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 76px;
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--c-foil);
    margin: 0;
    align-self: center;
    text-align: center;
  }
  .xc__tiny {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-linen);
    margin: 0;
    text-align: center;
  }

  /* ─ 5 · minimal ───────────────────────────────────────── */
  .xc--minimal {
    background: #ece6da;
    grid-template-rows: 1fr auto auto auto 1fr auto;
    padding: 44px 24px 22px;
    gap: 10px;
    color: var(--c-ink);
  }
  .xc--minimal .xc__plate {
    box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.14), 0 2px 6px rgba(0,0,0,0.12);
  }
  .xc__tracked {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    color: var(--c-ochre);
    margin: 0;
    text-align: center;
  }
  .xc--minimal .xc__sub { color: var(--c-ash); font-size: 11px; }
  .xc--minimal .xc__wordmark { color: var(--c-ochre); opacity: 0.7; }

  /* ─ 6 · typographic ───────────────────────────────────── */
  .xc--typo {
    background: var(--c-conifer);
    background-image:
      repeating-linear-gradient(45deg,  transparent 0, transparent 3px, rgba(244,239,230,0.012) 3px, rgba(244,239,230,0.012) 4px),
      repeating-linear-gradient(-45deg, transparent 0, transparent 3px, rgba(0,0,0,0.03) 3px, rgba(0,0,0,0.03) 4px);
    grid-template-rows: 1fr auto auto;
    padding: 48px 24px 24px;
    gap: 14px;
  }
  .xc__stack {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 80px;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--c-foil-light);
    margin: 0;
    text-align: center;
    text-transform: uppercase;
    align-self: center;
  }
  .xc--typo .xc__tag { color: var(--c-linen); font-size: 12px; }
  .xc--typo .xc__wordmark { font-size: 9px; align-self: end; }

  /* ─ 7 · art-of-home ───────────────────────────────────── */
  .xc--art {
    background: #f5efe6;
    grid-template-rows: auto 1fr auto;
    padding: 36px 28px 28px;
    gap: 14px;
    color: var(--c-ink);
  }
  .xc__artTitle {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 26px;
    line-height: 1.1;
    letter-spacing: -0.008em;
    color: var(--c-ink);
    margin: 0;
    text-align: center;
  }
  .xc__artTitle em { font-style: italic; color: var(--c-ochre); }
  .xc--art .xc__plate { align-self: center; }
  .xc--art .xc__sub { color: var(--c-ash); font-size: 12px; }

  /* ══════════════════════════════════════════════════════════════
     PAGES — single-page concepts (320 × 400).
     ══════════════════════════════════════════════════════════════ */
  .xp {
    position: relative;
    width: 320px;
    aspect-ratio: 4 / 5;
    background: var(--c-cream);
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow:
      inset 0 0 0 0.5px rgba(0, 0, 0, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.04);
  }

  /* ─ hero-bleed ────────────────────────────────────────── */
  .xp--hero { color: var(--c-ink-inverse); }
  .xp__bleed {
    position: absolute;
    inset: 0;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
  }
  .xp__scrim {
    position: absolute;
    inset: 35% 0 0 0;
    background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.72) 95%);
  }
  .xp__rail {
    position: absolute;
    top: 50%;
    left: 10px;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 8px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--c-foil);
  }
  .xp__hero-title {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 46px;
    display: grid;
    gap: 6px;
  }
  .xp__ht {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-foil);
    margin: 0;
    text-wrap: balance;
  }
  .xp__hm {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 11px;
    color: var(--c-linen);
    margin: 0;
  }
  .xp__continues {
    position: absolute;
    right: 18px;
    bottom: 16px;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 9px;
    color: var(--c-linen);
    opacity: 0.85;
    margin: 0;
  }

  /* ─ asymmetric (Pasta spread, compressed) ─────────────── */
  .xp--asym {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto 1fr auto auto;
    grid-template-areas:
      "head  photo"
      "head  ing"
      "meth  ing"
      "meth  photo2"
      "folio folio";
    gap: 6px 10px;
    padding: 14px 14px 8px;
  }
  .xp__ahead { grid-area: head; display: grid; gap: 3px; align-content: start; }
  .xp__atitle {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }
  .xp__ameta {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 9px;
    color: var(--c-ash);
    margin: 0;
  }
  .xp__aphoto {
    grid-area: photo;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    min-height: 75px;
    box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.12);
  }
  .xp__amethod { grid-area: meth; display: grid; gap: 3px; align-content: start; }
  .xp__aing    { grid-area: ing;  display: grid; gap: 3px; align-content: start; }
  .xp__aphoto2 {
    grid-area: photo2;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    min-height: 40px;
    box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.12);
  }
  .xp__alabel {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 7px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .xp__aol, .xp__aul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--f-body);
    font-size: 7.5px;
    line-height: 1.35;
    color: var(--c-ink);
  }
  .xp__aol li { display: flex; gap: 3px; }
  .xp__aroman {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
    flex-shrink: 0;
    min-width: 10px;
  }
  .xp__afolio {
    grid-area: folio;
    margin: 0;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 8px;
    color: var(--c-ochre);
    text-align: center;
  }

  /* ─ inset (Sunday Suppers) ────────────────────────────── */
  .xp--inset {
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 16px 16px 10px;
    gap: 10px;
  }
  .xp__ihead { display: grid; gap: 3px; }
  .xp__ititle {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.1;
    color: var(--c-ink);
    margin: 0;
  }
  .xp__imeta {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 9.5px;
    color: var(--c-ash);
    margin: 0;
  }
  .xp__ibody {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 12px;
    overflow: hidden;
  }
  .xp__ileft, .xp__iright {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .xp__ilabel {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 7px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .xp__iul, .xp__iol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--f-body);
    font-size: 8px;
    line-height: 1.4;
    color: var(--c-ink);
  }
  .xp__iol li { display: flex; gap: 3px; }
  .xp__iroman {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
    flex-shrink: 0;
    min-width: 10px;
  }
  .xp__iinset {
    width: 100%;
    height: 70px;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    margin-bottom: 2px;
    box-shadow: inset 0 0 0 0.5px rgba(0,0,0,0.12);
  }
  .xp__ifolio {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 8px;
    color: var(--c-ochre);
    text-align: center;
    margin: 0;
  }

  /* ══════════════════════════════════════════════════════════════
     SPREADS — two facing pages, 640 × 400. Gutter shadow between.
     ══════════════════════════════════════════════════════════════ */
  .xs {
    position: relative;
    width: 640px;
    height: 400px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--c-cream);
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
  }
  .xs__page {
    position: relative;
    padding: 18px 20px 12px;
    overflow: hidden;
  }
  .xs__page--L { padding-right: 26px; }
  .xs__page--R { padding-left: 26px; }
  .xs__gutter {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 16px;
    transform: translateX(-50%);
    pointer-events: none;
    background: linear-gradient(to right,
      transparent 0%,
      rgba(0,0,0,0.08) 48%,
      rgba(0,0,0,0.18) 50%,
      rgba(0,0,0,0.08) 52%,
      transparent 100%
    );
  }
  .xs__bleed {
    padding: 0 !important;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
  }
  .xs__bleed--dark::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.65) 100%),
      rgba(0,0,0,0.15);
  }
  .xs__rail {
    position: absolute;
    top: 50%;
    left: 8px;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 7px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--c-foil);
    z-index: 2;
  }

  .xs__title {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.1;
    color: var(--c-ink);
    margin: 0 0 2px;
    text-wrap: balance;
  }
  .xs__meta {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 10px;
    color: var(--c-ash);
    margin: 0 0 12px;
  }
  .xs__rbody {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 14px;
  }
  .xs__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 7px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    display: block;
    margin-bottom: 4px;
  }
  .xs__ul, .xs__ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--f-body);
    font-size: 8.5px;
    line-height: 1.45;
    color: var(--c-ink);
  }
  .xs__ol li { display: flex; gap: 4px; }
  .xs__roman {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
    flex-shrink: 0;
    min-width: 12px;
  }
  .xs__folio {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 8px;
    color: var(--c-ochre);
    margin: 0;
  }
  .xs__page--L .xs__folio { right: 26px; left: 20px; }
  .xs__page--R .xs__folio { left: 26px; right: 20px; }

  /* ─ text-only ─────────────────────────────────────────── */
  .xs__page--text { padding: 26px 24px 20px; }
  .xs__tLitle {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    line-height: 1.05;
    color: var(--c-ink);
    margin: 0 0 8px;
    text-wrap: balance;
  }
  .xs__tLede {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 11px;
    line-height: 1.5;
    color: var(--c-ash);
    margin: 0 0 16px;
    max-width: 30ch;
  }
  .xs__ul--wide, .xs__ol--wide { font-size: 9.5px; gap: 4px; }

  /* ─ chapter-opener ────────────────────────────────────── */
  .xs__chap-wrap {
    position: absolute;
    left: 30px;
    right: 30px;
    bottom: 34px;
    z-index: 2;
    display: grid;
    gap: 4px;
  }
  .xs__chap-eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--c-foil-light);
    margin: 0;
  }
  .xs__chap-title {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--c-foil);
    margin: 0;
  }
  .xs__page--epigraph {
    display: grid;
    place-items: center;
    padding: 40px;
  }
  .xs__epi {
    font-family: var(--f-display);
    font-size: 14px;
    line-height: 1.55;
    color: var(--c-ink);
    margin: 0 0 14px;
    text-align: center;
    max-width: 26ch;
    text-wrap: balance;
  }
  .xs__epi-attr {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 8px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--c-ochre);
    margin: 0;
    text-align: center;
  }

  /* ─ quote ─────────────────────────────────────────────── */
  .xs__page--quote {
    display: grid;
    place-items: center;
    padding: 48px 36px;
  }
  .xs__pull {
    font-family: var(--f-display);
    font-size: 15px;
