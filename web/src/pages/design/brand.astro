---
/**
 * /design/brand — Hearth Press Brand Guidelines.
 *
 * A single-page book-jacket showcase: foundations, components, patterns, voice.
 * Structured in shadcn-docs spirit (sidebar + live specimens) but every example
 * is hand-rolled Hearth — same language as the rest of /design/*.
 *
 * Demo-only styles live scoped to this page. Canonical primitives are consumed
 * from global.css (.btn, .eyebrow, .rule, .title, .lede, .link, .surface-*).
 */
import DesignLayout from "~/layouts/DesignLayout.astro";

const palette = [
  { name: "Deep Conifer", hex: "#2F4A3C", token: "--c-conifer", role: "Sage hardcover · dark surface · brand deep" },
  { name: "Antique Foil", hex: "#B8934A", token: "--c-foil", role: "Display foil on sage (wordmark, covers)" },
  { name: "Foil Light", hex: "#D4B062", token: "--c-foil-light", role: "Small-caps on sage · Primary CTA background" },
  { name: "White Dove", hex: "#F4EFE6", token: "--c-cream", role: "Cream page interior · light surface" },
  { name: "Chrome", hex: "#F6F2EA", token: "--c-chrome", role: "Workspace canvas behind cream artifacts" },
  { name: "Deep Ochre", hex: "#7A5A26", token: "--c-ochre", role: "Cookbook ink on cream · chapter marks" },
  { name: "Warm Charcoal", hex: "#1F1B17", token: "--c-ink", role: "Primary body ink on cream · 14.94:1 AAA" },
  { name: "Ash", hex: "#6C6457", token: "--c-ash", role: "Secondary ink on cream · 5.10:1 AA" },
  { name: "Oat", hex: "#7C7465", token: "--c-oat", role: "Tertiary ink · AA-large only" },
  { name: "Linen", hex: "#DAD5CD", token: "--c-linen", role: "Secondary on sage · 6.64:1 AA" },
  { name: "Stone", hex: "#B9B4AC", token: "--c-stone", role: "Tertiary on sage · 4.70:1 AA" },
  { name: "Alert Rust", hex: "#A55C2B", token: "--c-rust", role: "Destructive only · reserved" },
];

const sections = [
  {
    heading: "Foundations",
    items: [
      { id: "atmosphere", label: "Atmosphere" },
      { id: "palette", label: "Palette" },
      { id: "typography", label: "Typography" },
      { id: "spacing", label: "Spacing" },
      { id: "radius", label: "Radius" },
      { id: "shadows", label: "Shadows" },
      { id: "motion", label: "Motion" },
      { id: "focus", label: "Focus" },
    ],
  },
  {
    heading: "Components",
    items: [
      { id: "buttons", label: "Buttons" },
      { id: "cards", label: "Cards" },
      { id: "inputs", label: "Inputs" },
      { id: "nav", label: "Navigation" },
      { id: "sidebar", label: "Sidebar" },
      { id: "tags", label: "Tags" },
      { id: "alerts", label: "Alerts" },
      { id: "photography", label: "Photography" },
    ],
  },
  {
    heading: "Patterns",
    items: [
      { id: "rhythm", label: "Chapter rhythm" },
      { id: "hero-split", label: "Recipe hero" },
      { id: "folio", label: "Folio" },
      { id: "thumbs", label: "Library thumbs" },
    ],
  },
  {
    heading: "Voice",
    items: [{ id: "voice", label: "Voice & tone" }],
  },
];

const typeTiers = [
  {
    tier: "1",
    name: "Display · Wordmark",
    sample: "HEARTH",
    className: "tier-wordmark",
    meta: "Marcellus 400 · 48–72px · tracking 0.08–0.10em · line-height 1 · Antique Foil",
    note: "Reserved exclusively for the wordmark. Never used elsewhere.",
  },
  {
    tier: "2",
    name: "H1 · Recipe & Chapter",
    sample: "Slow-braised shoulder with preserved lemon",
    className: "tier-h1",
    meta: "Lora 400 · 28–42px · tracking −0.012em · line-height 1.08–1.15",
    note: "Hierarchy is size + color, never bold — Lora never goes bold.",
  },
  {
    tier: "3",
    name: "Italic · Lede",
    sample: "A winter bowl that keeps giving long after the oven cools.",
    className: "tier-lede",
    meta: "Lora italic 400 · 16–24px · line-height 1.4–1.6",
    note: "All italic jobs live here — meta, ledes, folios, Roman numerals.",
  },
  {
    tier: "4",
    name: "Eyebrow · Small-cap",
    sample: "INGREDIENTS",
    className: "tier-eyebrow",
    meta: "DM Sans 500 · 11px · uppercase · tracking 0.28em · Deep Ochre",
    note: "Wide tracking is non-negotiable — it's what signals \"chapter mark.\"",
  },
  {
    tier: "5",
    name: "Body · UI",
    sample: "Remove the lid, baste, and return to the oven uncovered for a final thirty minutes. The sauce should coat the back of a spoon.",
    className: "tier-body",
    meta: "DM Sans 400 · 13–15px · line-height 1.55–1.75",
    note: "Neutral, quiet, lets the serifs do the emotional work.",
  },
];

const spacing = [
  { token: "--space-2xs", px: 4 },
  { token: "--space-xs", px: 8 },
  { token: "--space-sm", px: 12 },
  { token: "--space-md", px: 16 },
  { token: "--space-lg", px: 24 },
  { token: "--space-xl", px: 32 },
  { token: "--space-2xl", px: 48 },
  { token: "--space-3xl", px: 64 },
  { token: "--space-4xl", px: 96 },
];
---

<DesignLayout title="Brand">
  <div class="brand">
    {/* ───────── Masthead ───────── */}
    <header class="brand-masthead">
      <p class="eyebrow">Hearth Press · Brand Book v1</p>
      <hr class="rule" aria-hidden="true" />
      <h1 class="brand-masthead__title">The book is the app made physical.</h1>
      <p class="lede">
        A literary, candlelit system — <em>warm, unhurried, foil-stamped</em> — with three
        typefaces, twelve colors, and the discipline of a hardcover. This page is the
        canonical reference for every surface we ship.
      </p>
      <div class="brand-masthead__meta">
        <span>Last revised 2026-04</span>
        <span aria-hidden="true">·</span>
        <a class="link--chevron" href="/design">Back to binder</a>
      </div>
    </header>

    <div class="brand-grid">
      {/* ───────── Sidebar ───────── */}
      <aside class="brand-nav" aria-label="On this page">
        {sections.map((group) => (
          <div class="brand-nav__group">
            <p class="eyebrow brand-nav__heading">{group.heading}</p>
            <ul class="brand-nav__list">
              {group.items.map((item) => (
                <li><a href={`#${item.id}`}>{item.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      {/* ───────── Body ───────── */}
      <article class="brand-body">
        {/* ──────────── FOUNDATIONS ──────────── */}
        <section id="atmosphere" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Atmosphere</p>
            <hr class="rule" />
            <h2 class="spec__title">Editorial, not farmhouse.</h2>
            <p class="lede">
              Closer to a Chez Panisse monograph than a SaaS dashboard. Every surface
              should feel like a page from a thoughtfully art-directed cookbook.
            </p>
          </div>
          <div class="spec__body mood">
            <div class="mood__col">
              <p class="eyebrow">Moods</p>
              <ul class="mood__list">
                <li>Literary</li><li>Calm</li><li>Hand-made</li>
                <li>Foil-stamped</li><li>Candlelit</li><li>Confident</li>
                <li>Considered</li>
              </ul>
            </div>
            <div class="mood__col mood__col--warn">
              <p class="eyebrow">Anti-moods</p>
              <ul class="mood__list">
                <li>Tech-y</li><li>Neon</li><li>Glossy</li>
                <li>Bouncy</li><li>Exclamatory</li><li>Emoji-forward</li>
              </ul>
            </div>
          </div>
        </section>

        <section id="palette" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Palette</p>
            <hr class="rule" />
            <h2 class="spec__title">Ink, paper, gold leaf — nothing else.</h2>
            <p class="lede">
              Zero saturated accent colors. The only chromatic range is sage ↔ cream ↔
              gold/ochre ↔ charcoal. Every swatch must feel mixable from those four.
            </p>
          </div>
          <div class="spec__body">
            <div class="swatches">
              {palette.map((c) => (
                <figure class="swatch">
                  <div class="swatch__chip" style={`background:${c.hex}`} aria-hidden="true" />
                  <figcaption>
                    <p class="swatch__name">{c.name}</p>
                    <p class="swatch__hex"><code>{c.hex}</code></p>
                    <p class="swatch__token"><code>{c.token}</code></p>
                    <p class="swatch__role">{c.role}</p>
                  </figcaption>
                </figure>
              ))}
            </div>
          </div>
        </section>

        <section id="typography" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Typography</p>
            <hr class="rule" />
            <h2 class="spec__title">Three faces, five tiers.</h2>
            <p class="lede">
              Marcellus for the wordmark. Lora for anything literary. DM Sans for
              everything that isn't. Hierarchy is scale and color — never bold.
            </p>
          </div>
          <div class="spec__body">
            <ol class="tiers">
              {typeTiers.map((t) => (
                <li class="tier">
                  <div class="tier__label">
                    <span class="tier__num">{t.tier}</span>
                    <span class="tier__name">{t.name}</span>
                  </div>
                  <p class={`tier__sample ${t.className}`}>{t.sample}</p>
                  <p class="tier__meta">{t.meta}</p>
                  <p class="tier__note">{t.note}</p>
                </li>
              ))}
            </ol>
          </div>
        </section>

        <section id="spacing" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Spacing</p>
            <hr class="rule" />
            <h2 class="spec__title">A 4pt scale, named for the job.</h2>
            <p class="lede">
              Section rhythm: 96px between major sections, 40–56px between subsections,
              24–28px heading-to-body. Line measure holds at 52–58ch.
            </p>
          </div>
          <div class="spec__body">
            <ul class="spacing-ladder">
              {spacing.map((s) => (
                <li>
                  <span class="spacing-ladder__bar" style={`width:${s.px}px`} />
                  <code class="spacing-ladder__token">{s.token}</code>
                  <span class="spacing-ladder__px">{s.px}px</span>
                </li>
              ))}
            </ul>
          </div>
        </section>

        <section id="radius" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Radius</p>
            <hr class="rule" />
            <h2 class="spec__title">2px for paper, pills for taps.</h2>
            <p class="lede">
              The whole system lives at 2px — the radius of a well-cut book page.
              Pills are the one intentional exception, and they mean <em>tappable.</em>
            </p>
          </div>
          <div class="spec__body radius-row">
            <figure>
              <div class="radius-demo radius-demo--page" />
              <figcaption><code>--r-page · 2px</code><br/>cards, inputs, thumbnails</figcaption>
            </figure>
            <figure>
              <div class="radius-demo radius-demo--pill">Button</div>
              <figcaption><code>--r-pill · 9999px</code><br/>buttons only</figcaption>
            </figure>
          </div>
        </section>

        <section id="shadows" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Shadows</p>
            <hr class="rule" />
            <h2 class="spec__title">Warm, brown-biased, whisper-soft.</h2>
            <p class="lede">
              Shadows are always warm and brown-biased — never blue. Treat them as
              paper lift, not UI chrome.
            </p>
          </div>
          <div class="spec__body shadow-row">
            <figure>
              <div class="shadow-demo" style="box-shadow: var(--shadow-paper)" />
              <figcaption><code>--shadow-paper</code><br/>lifted-paper default</figcaption>
            </figure>
            <figure>
              <div class="shadow-demo" style="box-shadow: var(--shadow-lift)" />
              <figcaption><code>--shadow-lift</code><br/>deep lift, hero cards</figcaption>
            </figure>
            <figure>
              <div class="shadow-demo shadow-demo--button" style="box-shadow: var(--shadow-button)" />
              <figcaption><code>--shadow-button</code><br/>pill button only</figcaption>
            </figure>
          </div>
        </section>

        <section id="motion" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Motion</p>
            <hr class="rule" />
            <h2 class="spec__title">280ms ease. That's it.</h2>
            <p class="lede">
              Every state change is a 280ms ease fade — background, color, shadow.
              No springs, no bounces. The 3px chevron nudge on T2 links is the
              entire scope of delight.
            </p>
          </div>
          <div class="spec__body motion-row">
            <button class="btn" type="button">Hover me · 280ms</button>
            <a href="#motion" class="link--chevron">Continue reading</a>
            <p class="tier__meta">
              <code>--motion-state</code> · <code>--ease-state</code>
            </p>
          </div>
        </section>

        <section id="focus" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Foundations · Focus</p>
            <hr class="rule" />
            <h2 class="spec__title">Keyboard-only, surface-aware.</h2>
            <p class="lede">
              Tab through the demos. Rings use Deep Ochre on cream, Foil Light on sage.
              Mouse clicks never show a ring.
            </p>
          </div>
          <div class="spec__body focus-row">
            <button class="btn btn--outlined" type="button">Focus on cream</button>
            <div class="surface-sage focus-row__sage">
              <button class="btn btn--outlined" type="button">Focus on sage</button>
            </div>
          </div>
        </section>

        {/* ──────────── COMPONENTS ──────────── */}
        <section id="buttons" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Buttons</p>
            <hr class="rule" />
            <h2 class="spec__title">Six tokens, one pill.</h2>
            <p class="lede">
              One primary per screen, maximum. Secondary and tertiary cover everything
              that isn't the hero action. Pills are reserved for buttons.
            </p>
          </div>
          <div class="spec__body">
            <div class="demo-card demo-card--cream">
              <p class="eyebrow demo-card__label">On cream</p>
              <div class="btn-row">
                <button class="btn" type="button">Primary · Save recipe</button>
                <button class="btn btn--outlined" type="button">S1 · Continue reading</button>
                <button class="btn btn--soft" type="button">S3 · Filter</button>
                <button class="btn-text" type="button">T1 · Delete recipe</button>
                <a href="#buttons" class="link--chevron">T2 · Continue reading</a>
                <a href="#buttons" class="link">Inline link</a>
              </div>
            </div>
            <div class="demo-card demo-card--sage surface-sage">
              <p class="eyebrow demo-card__label">On sage</p>
              <div class="btn-row">
                <button class="btn" type="button">Primary · Start cooking</button>
                <button class="btn btn--outlined" type="button">S1 · Book jacket</button>
                <button class="btn btn--soft" type="button">S3 · Save</button>
                <button class="btn-text" type="button">T1 · Dismiss</button>
                <a href="#buttons" class="link--chevron">T2 · See more</a>
                <a href="#buttons" class="link">Inline link</a>
              </div>
            </div>
          </div>
        </section>

        <section id="cards" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Cards</p>
            <hr class="rule" />
            <h2 class="spec__title">Subtly squared, barely bordered.</h2>
            <p class="lede">
              2px radius, 1px whisper border, brown-biased shadow. Book-layout,
              not card-UI.
            </p>
          </div>
          <div class="spec__body card-grid">
            <article class="card card--cream">
              <p class="eyebrow">Saved · 2 days ago</p>
              <h3 class="card__title">Preserved-lemon shoulder</h3>
              <p class="card__meta"><em>50 min · Serves 4</em></p>
              <p class="card__body">
                Slow oven, shallow bath of stock and citrus, lid on for the first
                hour. The sauce reduces to glaze.
              </p>
            </article>
            <article class="card card--cream card--lift">
              <p class="eyebrow">Chapter 3</p>
              <h3 class="card__title">Braises & slow things</h3>
              <p class="card__meta"><em>Twelve recipes</em></p>
              <p class="card__body">
                The chapter for winter afternoons. Patience does most of the work.
              </p>
              <a href="#cards" class="link--chevron">Open chapter</a>
            </article>
            <article class="card card--sage">
              <p class="eyebrow">Cover treatment</p>
              <h3 class="card__title">On the sage side</h3>
              <p class="card__meta"><em>Hardcover surface</em></p>
              <p class="card__body">
                Same card grammar, dark interior. Text shifts to White Dove and Linen;
                the eyebrow lifts to Foil Light.
              </p>
            </article>
          </div>
        </section>

        <section id="inputs" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Inputs</p>
            <hr class="rule" />
            <h2 class="spec__title">Printed-form discipline.</h2>
            <p class="lede">
              2px corners, off-cream fill, barely-there border until focus deepens it
              to charcoal. Inputs and pills sit side-by-side and <em>should</em> feel
              different.
            </p>
          </div>
          <div class="spec__body">
            <form class="form-demo" onsubmit="return false">
              <label class="field">
                <span class="field__label">Recipe title</span>
                <input class="input" type="text" placeholder="e.g. Shoulder with preserved lemon" />
              </label>
              <label class="field">
                <span class="field__label">Search library</span>
                <input class="input" type="search" placeholder="Search 147 recipes" />
              </label>
              <label class="field">
                <span class="field__label">Notes</span>
                <textarea class="input input--area" rows="3" placeholder="What worked, what didn't"></textarea>
              </label>
              <fieldset class="fieldset">
                <legend class="field__label">Course</legend>
                <label class="radio"><input type="radio" name="course" /><span>Main</span></label>
                <label class="radio"><input type="radio" name="course" /><span>Side</span></label>
                <label class="radio"><input type="radio" name="course" /><span>Dessert</span></label>
              </fieldset>
              <div class="form-demo__actions">
                <button class="btn" type="submit">Save recipe</button>
                <button class="btn-text" type="button">Cancel</button>
              </div>
            </form>
          </div>
        </section>

        <section id="nav" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Navigation</p>
            <hr class="rule" />
            <h2 class="spec__title">Marketing nav, cream surface.</h2>
            <p class="lede">
              Wordmark left, DM Sans links centered, 2px search field, pill CTA right.
              Sticky, subtle backdrop blur.
            </p>
          </div>
          <div class="spec__body">
            <nav class="nav-demo" aria-label="Marketing nav demo">
              <a class="nav-demo__mark" href="#nav">HEARTH</a>
              <ul class="nav-demo__links">
                <li><a href="#nav" class="is-active">The book</a></li>
                <li><a href="#nav">The app</a></li>
                <li><a href="#nav">Kitchen journal</a></li>
                <li><a href="#nav">About</a></li>
              </ul>
              <div class="nav-demo__search">
                <input class="input" type="search" placeholder="Search" />
              </div>
              <a href="#nav" class="btn nav-demo__cta">Join waitlist</a>
            </nav>
          </div>
        </section>

        <section id="sidebar" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Sidebar</p>
            <hr class="rule" />
            <h2 class="spec__title">Library side-rail.</h2>
            <p class="lede">
              Chapter-mark eyebrows open each group; list items read like a table of
              contents, not like nav chrome. 1px whisper between items.
            </p>
          </div>
          <div class="spec__body">
            <div class="sidebar-demo">
              <aside class="sidebar-demo__rail" aria-label="Library">
                <div class="sidebar-demo__group">
                  <p class="eyebrow">Library</p>
                  <ul>
                    <li><a href="#sidebar" class="is-active">All recipes <span>147</span></a></li>
                    <li><a href="#sidebar">Saved <span>34</span></a></li>
                    <li><a href="#sidebar">Cooked <span>62</span></a></li>
                  </ul>
                </div>
                <div class="sidebar-demo__group">
                  <p class="eyebrow">Chapters</p>
                  <ul>
                    <li><a href="#sidebar">Mornings</a></li>
                    <li><a href="#sidebar">Weeknight</a></li>
                    <li><a href="#sidebar">Braises & slow things</a></li>
                    <li><a href="#sidebar">Preserves</a></li>
                    <li><a href="#sidebar">Sundays</a></li>
                  </ul>
                </div>
                <div class="sidebar-demo__group">
                  <p class="eyebrow">Settings</p>
                  <ul>
                    <li><a href="#sidebar">Account</a></li>
                    <li><a href="#sidebar">Printing</a></li>
                  </ul>
                </div>
              </aside>
              <div class="sidebar-demo__stage">
                <p class="eyebrow">Chapter 3</p>
                <hr class="rule" />
                <h3 class="spec__title">Braises & slow things</h3>
                <p class="lede">Twelve recipes for winter afternoons.</p>
              </div>
            </div>
          </div>
        </section>

        <section id="tags" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Tags</p>
            <hr class="rule" />
            <h2 class="spec__title">Small-cap text tags, soft pill chips.</h2>
            <p class="lede">
              Tags read as metadata, not decoration. Text tags for structure,
              soft pills for filters.
            </p>
          </div>
          <div class="spec__body tag-row">
            <span class="tag">VEGETARIAN</span>
            <span class="tag">UNDER 30 MIN</span>
            <span class="tag">SUNDAY</span>
            <span class="chip">Filter · Seasonal</span>
            <span class="chip">Filter · Saved</span>
            <span class="chip chip--sage">On sage surface</span>
          </div>
        </section>

        <section id="alerts" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Alerts</p>
            <hr class="rule" />
            <h2 class="spec__title">Quiet margins, Rust for destruction only.</h2>
            <p class="lede">
              Alerts sit in the margin of the page — a vertical Deep-Ochre rule, a
              small-cap label, Lora italic copy. Alert Rust is reserved for destructive.
            </p>
          </div>
          <div class="spec__body alert-col">
            <aside class="alert">
              <p class="eyebrow">Note</p>
              <hr class="rule rule--short" />
              <p class="alert__body">
                <em>Preserved lemons take three weeks to cure. Start yours before
                you need them.</em>
              </p>
            </aside>
            <aside class="alert alert--warn">
              <p class="eyebrow">Destructive</p>
              <hr class="rule rule--short" />
              <p class="alert__body">
                <em>Deleting this recipe also removes the six variations saved from it.
                This cannot be undone.</em>
              </p>
            </aside>
          </div>
        </section>

        <section id="photography" class="spec">
          <div class="spec__head">
            <p class="eyebrow">Components · Photography</p>
            <hr class="rule" />
            <h2 class="spec__title">Two places, imperfect & true-to-phone.</h2>
            <p class="lede">
              Photography lives in the recipe-detail hero and in square library
              thumbs. No filters, no AI enhancement. Covers and chapter openers
              remain typographic.
            </p>
          </div>
          <div class="spec__body photo-row">
