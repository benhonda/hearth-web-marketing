---
/**
 * Library — the home of the app.
 *
 * One screen, two data-driven states (matches how the actual app would
 * render this surface):
 *
 *   empty      — no recipes yet. Chapter-opener centered, italic-Ochre
 *                "— import a recipe →" foot invitation. Used in Flow I · II.
 *   populated  — saved recipes. Always carries the options list
 *                (Collections · Friends · Cookbooks) above the waterfall —
 *                it's part of the layout, not a toggle. No foot. The
 *                book-creation entry point lives as the Cookbooks row;
 *                the social-layer entry as Friends. Used in Flow I · VI,
 *                Flow III · I, Flow IV · branch, Flow V · I/V.
 *
 * Halo target on the populated state is set via `optionsTapTarget` —
 * defaults to none (no halo). The render keys point at thin wrappers
 * that pass state + halo target in. Editing this file is the single
 * point for every Library tweak.
 */
import AppHeader from "../ui/AppHeader.astro";
import LibraryGrid, { type LibraryTileData } from "../ui/LibraryGrid.astro";
import { sampleLibraryTiles } from "~/lib/design/sample-library";

export type LibraryState = "empty" | "populated";

interface Props {
  state: LibraryState;
  showTap?: boolean;
  /** Optional tiles override — when set, replaces sampleLibraryTiles for
   *  the populated state. Used by Flow V · V to surface the just-saved
   *  corn ragù at the head of the waterfall with a "via Sarah Chen"
   *  credit; used by Flow I · VI to render a library of one. */
  tilesOverride?: LibraryTileData[];
  /** When set + `showTap`, halos the matching row in the options list.
   *  Used by Flow III · I (cookbooks), Flow IV · branch (cookbooks),
   *  Flow V · I (friends). */
  optionsTapTarget?: "collections" | "friends" | "cookbooks";
}
const {
  state,
  showTap = false,
  tilesOverride,
  optionsTapTarget,
} = Astro.props;

const tapCollections = showTap && optionsTapTarget === "collections";
const tapFriends = showTap && optionsTapTarget === "friends";
const tapCookbooks = showTap && optionsTapTarget === "cookbooks";

const tiles =
  state === "empty"
    ? []
    : tilesOverride ?? sampleLibraryTiles;
const countLabel = tiles.length === 1 ? "recipe" : "recipes";
---

<div class:list={["lib", `lib--${state}`]}>
  <AppHeader variant="wordmark" />

  {state !== "empty" && (
    <ul class="lib__options" role="list">
      <li class="lib__opt-wrap">
        <button
          class:list={["lib__opt", tapCollections && "lib__opt--tap"]}
          type="button"
          aria-label="Collections"
        >
          <span class="lib__opt-label">Collections</span>
          <span class="lib__opt-chev" aria-hidden="true">›</span>
        </button>
      </li>
      <li class="lib__opt-wrap">
        <button
          class:list={["lib__opt", tapFriends && "lib__opt--tap"]}
          type="button"
          aria-label="Friends"
        >
          <span class="lib__opt-label">Friends</span>
          <span class="lib__opt-chev" aria-hidden="true">›</span>
        </button>
      </li>
      <li class="lib__opt-wrap">
        <button
          class:list={["lib__opt", tapCookbooks && "lib__opt--tap"]}
          type="button"
          aria-label="Cookbooks"
        >
          <span class="lib__opt-label">Cookbooks</span>
          <span class="lib__opt-chev" aria-hidden="true">›</span>
        </button>
      </li>
    </ul>
  )}

  {state === "empty" && (
    <div class="lib__body">
      <div class="opener">
        <hr class="opener__rule" aria-hidden="true" />
        <span class="opener__eyebrow">I · Beginning</span>
        <p class="opener__title">The beginning<br />of a library.</p>
      </div>
    </div>
  )}

  {state !== "empty" && (
    <Fragment>
      <div class="lib__count">
        <span class="lib__n">{tiles.length}</span>
        <span class="lib__label">{countLabel}</span>
      </div>

      <LibraryGrid tiles={tiles} />
    </Fragment>
  )}

  {state === "empty" && (
    <div class={showTap ? "lib__invite-min lib__invite-min--tap" : "lib__invite-min"}>
      <p class="lib__invite-min-line">
        <span aria-hidden="true">—&nbsp;</span>import a recipe<span class="lib__invite-min-chev" aria-hidden="true">&nbsp;→</span>
      </p>
    </div>
  )}
</div>

<style>
  /* Base — three-region grid (header, body, foot). The middle row is
     1fr in the empty state so the chapter-opener centers; auto in the
     populated state so the waterfall sits at its natural height. */
  .lib {
    position: relative;
    display: grid;
    min-height: 100%;
    padding-bottom: 44px; /* clear home indicator */
  }
  .lib--empty {
    grid-template-rows: auto 1fr auto;
  }
  .lib--populated {
    /* header → options list → count → waterfall. align-content: start
       so that with a short waterfall (e.g. library-of-one) the auto
       rows pack at the top instead of stretching to fill min-height —
       default `align-content: normal` resolves to `stretch` for grid
       containers, which would distribute the extra phone-height space
       across every row and bloat the gap above the count. */
    grid-template-rows: repeat(4, auto);
    align-content: start;
  }

  /* Top-of-library options list — Apple-Music-Library-tab grammar.
     Drill-down rows (Collections, Friends, Cookbooks) sit above the
     recipe waterfall as siblings of the implicit "all recipes" view.
     The waterfall below is the default; the rows above are siblings
     you can navigate into. Hairline dividers above and below each row;
     italic Lora labels in the TOC voice; ochre chevron right. */
  .lib__options {
    list-style: none;
    margin: 0 0 18px;
    padding: 0 22px;
    display: flex;
    flex-direction: column;
  }
  .lib__opt-wrap {
    border-top: var(--b-divider);
  }
  .lib__opt-wrap:last-child {
    border-bottom: var(--b-divider);
  }
  .lib__opt {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    width: 100%;
    padding: 16px 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
    transition: opacity var(--motion-state) var(--ease-state);
  }
  .lib__opt:hover { opacity: 0.82; }
  .lib__opt-label {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.2;
    color: var(--c-ink);
    letter-spacing: -0.005em;
  }
  .lib__opt-chev {
    justify-self: end;
    font-family: var(--f-display);
    font-size: 20px;
    line-height: 1;
    color: var(--c-ochre);
  }
  .lib__opt--tap::after {
    content: "";
    position: absolute;
    inset: 4px -6px;
    border: 3px solid var(--annotation);
    border-radius: 4px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* Empty state — chapter-opener centered in the 1fr middle row. */
  .lib__body {
    display: grid;
    place-items: center;
    padding: 0 32px;
  }
  .opener {
    display: grid;
    justify-items: center;
    gap: 14px;
    text-align: center;
    max-width: 30ch;
  }
  .opener__rule {
    width: 44px;
    height: 1.5px;
    background: var(--c-ochre);
    border: 0;
    margin: 0;
  }
  .opener__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .opener__title {
    margin-top: 6px;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 30px;
    line-height: 1.15;
    letter-spacing: -0.006em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  /* Populated state — count line above the waterfall. */
  .lib__count {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 0 22px;
    margin: 4px 0 18px;
  }
  .lib__n {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    color: var(--c-ochre);
  }
  .lib__label {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-oat);
  }

  /* Empty-state foot invitation — italic-Lora line in Ochre. Quieter
     than a Hearth Press grammar would be because the chapter-opener
     above already carries the editorial weight. */
  .lib__invite-min {
    position: relative;
    display: grid;
    justify-items: center;
    padding: 28px 22px 22px;
  }
  .lib__invite-min-line {
    margin: 0;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: var(--c-ochre);
  }
  .lib__invite-min-chev {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 16px;
  }
  .lib__invite-min--tap::after {
    content: "";
    position: absolute;
    inset: 12px 36px 8px;
    border: 3px solid var(--annotation);
    border-radius: 4px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
