---
/**
 * A single library tile — photo above, caption below. Used inside
 * LibraryGrid. Aspect ratio is per-tile so the waterfall staggers.
 *
 * Rules live in tokens.css §PHOTOGRAPHY (2):
 *   · no scrims / overlays on tiles (scrim is hero only)
 *   · no source small-caps at tile scale (lives on detail)
 *   · caption sits below the tile, left-aligned
 */

interface Props {
  title: string;
  meta: string;
  photo?: string;            // public path; omit for the gradient placeholder
  aspect?: "4 / 5" | "3 / 4" | "1 / 1"; // portrait or square only
  tone?: "corn" | "sage" | "ochre";      // placeholder gradient when no photo
  href?: string;
  showTap?: boolean;         // flow-binder halo
  dimmed?: boolean;          // selection-out state on selection screens
}

const {
  title,
  meta,
  photo,
  aspect = "4 / 5",
  tone = "corn",
  href = "#",
  showTap = false,
  dimmed = false,
} = Astro.props;

const photoStyle = photo
  ? `aspect-ratio: ${aspect}; background-image: url(${photo})`
  : `aspect-ratio: ${aspect}`;
---

<a class:list={["tile", showTap && "tile--tap", dimmed && "tile--dim"]} href={href}>
  <div
    class={photo ? "tile__photo tile__photo--image" : `tile__photo tile__photo--${tone}`}
    style={photoStyle}
    aria-hidden="true"
  ></div>
  <h3 class="tile__title">{title}</h3>
  <p class="tile__meta">{meta}</p>
</a>

<style>
  .tile {
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: inherit;
    text-decoration: none;
    position: relative;
    transition: opacity var(--motion-state) var(--ease-state);
  }
  /* Selection-out state — not in the book. 40% is the floor where the
     tile still reads as "present in the library" but unmistakably
     "not selected." No additional chrome, no checkmark — opacity
     carries the whole thing. */
  .tile--dim { opacity: 0.38; }

  .tile__photo {
    width: 100%;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.12);
    position: relative;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  /* Placeholder gradients — only used when no real photo is set. */
  .tile__photo--corn {
    background: radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .tile__photo--sage {
    background: radial-gradient(ellipse at 30% 30%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .tile__photo--ochre {
    background: radial-gradient(ellipse at 30% 30%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }

  .tile__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 13.5px;
    line-height: 1.25;
    letter-spacing: -0.003em;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }

  .tile__meta {
    font-family: var(--f-body);
    font-size: 10.5px;
    line-height: 1.3;
    color: var(--c-ash);
    letter-spacing: 0.02em;
    margin: 0;
  }

  .tile--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border: 3px solid var(--annotation);
    border-radius: 4px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
