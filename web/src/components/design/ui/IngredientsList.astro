---
/**
 * Ingredients list — small-caps eyebrow + DM Sans body with thin
 * ochre dash markers. Used inside import preview, recipe detail, edit.
 *
 * Optional `servesTap` renders a tappable "· SERVES N" appended to the
 * eyebrow. Shares the eyebrow's DNA exactly — DM Sans 500 small-caps,
 * 10px, 0.3em tracking, Ochre — so it reads as a sub-chapter of the
 * eyebrow, not a foreign link. The only thing distinguishing it as
 * interactive is a 1px ochre underline at 3px offset. Drives the
 * portion-scale overlay on Flow I.
 *
 * Optional `haloServesTap` wraps that affordance in the storyboard tap
 * halo so the binder marks it as the next tap target.
 */

/**
 * Optional per-item comments. Each entry maps an item index to a
 * comment config; an `ItemComment` renders beneath that item, sized
 * for line-item context. Indices are 0-based; missing indices render
 * with no comment. Used by Flow V to annotate specific ingredients.
 */
export type IngredientComment = {
  text?: string;
  editing?: boolean;
  blockTap?: boolean;
  saveTap?: boolean;
};

interface Props {
  items: string[];
  label?: string;
  servesTap?: number;
  haloServesTap?: boolean;
  comments?: Record<number, IngredientComment>;
  /** Halo a single ingredient line as a long-press tap target. */
  tapIndex?: number;
  /** When set, render the right-side "IN ___" units affordance — the
   *  twin to servesTap. Same DM Sans 500 small-caps 10px Ochre voice as
   *  the eyebrow itself, with the affordance underline used by serves N.
   *  Drives Flow VI (Measures). */
  units?: "cups" | "grams" | "ounces";
  /** Halo the closed units token as the next tap target (screen I). */
  haloUnitsTap?: boolean;
  /** When true, the right slot opens in place into a typographic radio
   *  strip — "— cups · grams · oz —" — Lora italic, em-dash bookends,
   *  current selection (the value of `units`) larger and Ink with the
   *  hairline ochre underbar borrowed from the portion overlay. */
  unitsPickerOpen?: boolean;
  /** Which picker option carries the halo when the picker is open
   *  (screen II). */
  haloUnitsPick?: "cups" | "grams" | "ounces";
}

const {
  items,
  label = "Ingredients",
  servesTap,
  haloServesTap = false,
  comments = {},
  tapIndex,
  units,
  haloUnitsTap = false,
  unitsPickerOpen = false,
  haloUnitsPick,
} = Astro.props;

const unitsLabel: Record<"cups" | "grams" | "ounces", string> = {
  cups: "in cups",
  grams: "in grams",
  ounces: "in oz",
};

const pickerOptions: Array<"cups" | "grams" | "ounces"> = [
  "cups",
  "grams",
  "ounces",
];

const pickerShort: Record<"cups" | "grams" | "ounces", string> = {
  cups: "cups",
  grams: "grams",
  ounces: "oz",
};

import ItemComment from "./ItemComment.astro";
---

<section class="ing">
  <div class="ing__head">
    <span class="ing__eyebrow-row">
      <span class="ing__eyebrow">{label}</span>
      {servesTap !== undefined && (
        <>
          <span class="ing__sep" aria-hidden="true">·</span>
          <button
            type="button"
            class:list={["ing__serves-tap", haloServesTap && "ing__serves-tap--halo"]}
            aria-label={`Change portion size, currently serves ${servesTap}`}
          >serves {servesTap}</button>
        </>
      )}
    </span>
    {units !== undefined && !unitsPickerOpen && (
      <button
        type="button"
        class:list={["ing__units-tap", haloUnitsTap && "ing__units-tap--halo"]}
        aria-label={`Change measure, currently ${unitsLabel[units]}`}
      >{unitsLabel[units]}</button>
    )}
    {units !== undefined && unitsPickerOpen && (
      <span class="ing__units-picker" role="radiogroup" aria-label="Measure">
        <span class="ing__units-dash" aria-hidden="true">—</span>
        {pickerOptions.map((opt, i) => (
          <>
            {i > 0 && <span class="ing__units-sep" aria-hidden="true">·</span>}
            <button
              type="button"
              class:list={[
                "ing__units-opt",
                opt === units && "is-on",
                haloUnitsPick === opt && "ing__units-opt--halo",
              ]}
              aria-pressed={opt === units}
            >{pickerShort[opt]}</button>
          </>
        ))}
        <span class="ing__units-dash" aria-hidden="true">—</span>
      </span>
    )}
  </div>
  <ul class="ing__list">
    {items.map((item, i) => {
      const comment = comments[i];
      const hasTap = tapIndex === i;
      return (
        <li class={hasTap ? "ing__li ing__li--tap" : "ing__li"}>
          <span class="ing__text">{item}</span>
          {comment && (
            <ItemComment
              text={comment.text}
              editing={comment.editing}
              blockTap={comment.blockTap}
              saveTap={comment.saveTap}
            />
          )}
        </li>
      );
    })}
  </ul>
</section>

<style>
  .ing__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }
  .ing__eyebrow-row {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .ing__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    display: inline-block;
  }
  .ing__sep {
    font-family: var(--f-body);
    color: var(--c-ochre);
    opacity: 0.45;
    font-size: 10px;
    line-height: 1;
  }

  /* Inline "SERVES N" — shares the eyebrow's exact typographic DNA
     (DM Sans 500 small-caps 10px 0.3em tracking Ochre) so it reads as
     a sub-chapter, not a foreign link. Only the underline distinguishes
     it as interactive; hover lifts color to Ink. The underline is kept
     thin (0.75px) and set at a slightly tighter offset so on wide-
     tracked caps it reads as book-typographic, not URL-y. */
  .ing__serves-tap {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    font-family: var(--f-body);
    font-weight: 500;
    font-style: normal;
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    text-decoration: underline;
    text-decoration-thickness: 0.75px;
    text-underline-offset: 2.5px;
    cursor: pointer;
    position: relative;
    transition: color var(--motion-state) var(--ease-state);
  }
  .ing__serves-tap:hover { color: var(--c-ink); }

  /* Storyboard tap halo — marks this affordance as the next tap target.
     Tighter inset than the prior Lora variant since the small-caps
     voice has less optical volume. */
  .ing__serves-tap--halo::after {
    content: "";
    position: absolute;
    inset: -4px -6px;
    border: 3px solid var(--annotation);
    border-radius: 5px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* Right-side units affordance — twin to serves N, opposite end of the
     eyebrow row. Same DM Sans 500 small-caps 10px Ochre 0.3em-tracked
     voice as the eyebrow itself; only the 0.75px ochre underline marks
     it as interactive. Separates concerns: left tells the cook what +
     how much, right tells them in what measure. Drives Flow VI. */
  .ing__units-tap {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    font-family: var(--f-body);
    font-weight: 500;
    font-style: normal;
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    text-decoration: underline;
    text-decoration-thickness: 0.75px;
    text-underline-offset: 2.5px;
    cursor: pointer;
    position: relative;
    transition: color var(--motion-state) var(--ease-state);
  }
  .ing__units-tap:hover { color: var(--c-ink); }

  .ing__units-tap--halo::after {
    content: "";
    position: absolute;
    inset: -4px -6px;
    border: 3px solid var(--annotation);
    border-radius: 5px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  /* Open units picker — replaces the closed token in place. Same
     typographic vocabulary as the portion overlay's scale strip
     (em-dash bookends, middot separators, italic Lora Ochre, current
     selection larger and Ink with the chapter-rule hairline beneath),
     but on-page — no dim, no overlay. The quiet cousin to portion-
     scale's theatrical moment. */
  .ing__units-picker {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ochre);
    line-height: 1;
  }
  .ing__units-dash {
    font-size: 13px;
    color: var(--c-ochre);
    opacity: 0.55;
    line-height: 1;
  }
  .ing__units-sep {
    font-size: 12px;
    color: var(--c-ochre);
    opacity: 0.45;
    line-height: 1;
  }
  .ing__units-opt {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    padding: 2px 2px 4px;
    margin: 0;
    font: inherit;
    font-size: 13px;
    color: var(--c-ash);
    cursor: pointer;
    position: relative;
    line-height: 1;
    transition: color var(--motion-state) var(--ease-state);
  }
  .ing__units-opt:hover { color: var(--c-ink); }
  .ing__units-opt.is-on {
    color: var(--c-ink);
    font-size: 16px;
  }
  .ing__units-opt.is-on::after {
    content: "";
    position: absolute;
    left: 2px;
    right: 2px;
    bottom: 0;
    height: 1.5px;
    background: var(--c-ochre);
  }
  .ing__units-opt--halo::before {
    content: "";
    position: absolute;
    inset: -5px -4px;
    border: 3px solid var(--annotation);
    border-radius: 6px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  .ing__list {
    display: grid;
    gap: 6px;
    padding: 0;
    margin: 0;
    list-style: none;
    font-family: var(--f-body);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--c-ink);
  }
  .ing__li {
    padding-left: 14px;
    position: relative;
  }
  .ing__li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 6px;
    height: 1px;
    background: var(--c-ochre);
    opacity: 0.85;
  }
  .ing__text {
    display: block;
  }

  /* Storyboard halo on a single ingredient line — long-press entry
     into the ingredient comment menu (Flow V). */
  .ing__li--tap::after {
    content: "";
    position: absolute;
    inset: -6px -10px;
    border: 3px solid var(--annotation);
    border-radius: 8px;
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
