---
/**
 * Flow I · VI — Library, of one.
 *
 * Same Library layout as Flow III · I — wordmark header, options list
 * (Collections · Friends), count line, photo waterfall, Hearth Press
 * foot — with a single tile in the waterfall. The emotional payoff
 * sits in the count rhythm, not in a different chrome.
 */
import Library from "./Library.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";
import type { LibraryTileData } from "../ui/LibraryGrid.astro";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
void showTap; // terminal screen — no halo.

const tiles: LibraryTileData[] = [
  {
    title: sampleRecipe.title,
    meta: `${sampleRecipe.minutes} min · Serves ${sampleRecipe.serves}`,
    photo: sampleRecipe.photo,
    aspect: "4 / 5",
  },
];
---

<Library state="populated" showTap={false} tilesOverride={tiles} />
