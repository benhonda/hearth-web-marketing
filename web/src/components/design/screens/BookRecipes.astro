---
/**
 * Flow II · IV · The recipes.
 *
 * The list-style selection surface. Earlier drafts used the Library
 * photo waterfall — but the waterfall is strictly an in-app browsing
 * voice (tokens.css §PHOTOGRAPHY), not a book-composition voice.
 * The book is assembled in manuscript TOC rhythm: a stacked list of
 * rows, each with a small thumbnail and an ochre toggle on the right.
 *
 * Toggles carry the binary — filled Ochre = in the book, outlined
 * Ochre = not in the book. No checkmarks (palette guardrail).
 *
 * The meta line below is the running colophon — recipe count, page
 * estimate, indicative price — in Lora italic, with em-middot
 * separators.
 */
import ScreenNav from "../ui/ScreenNav.astro";
import BookRecipeList, { type RecipeRow } from "../ui/BookRecipeList.astro";
import { sampleLibraryTiles } from "~/lib/design/sample-library";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

// Same 27 library tiles; three are marked out-of-book as a demo of
// the toggle. Indices span the visible range so the mechanic is
// legible without scrolling.
const outIndices = new Set([2, 5, 14]);
const rows: RecipeRow[] = sampleLibraryTiles.map((t, i) => ({
  title: t.title,
  meta: t.meta,
  photo: t.photo,
  tone: t.tone,
  inBook: !outIndices.has(i),
}));
const selectedCount = rows.filter((r) => r.inBook).length;
---

<div class="rec">
  <ScreenNav />

  <header class="rec__head">
    <h1 class="rec__head-title">The recipes.</h1>
    <p class="rec__head-lede">What goes in the book — you can re-order them later in Settings.</p>
  </header>

  <BookRecipeList rows={rows} mode="select" tapRowIndex={5} showTap={showTap} />

  <p class="rec__meta">
    <span>{selectedCount} in the book</span>
    <span class="rec__dot" aria-hidden="true">·</span>
    <span>about 80 pages</span>
    <span class="rec__dot" aria-hidden="true">·</span>
    <span>around $139</span>
  </p>

  <div class="rec__foot">
    <button class={showTap ? "rec__continue rec__continue--tap" : "rec__continue"} type="button">
      Continue
    </button>
  </div>
</div>

<style>
  .rec {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  /* Header — left-aligned chapter opener. */
  .rec__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 14px 24px 18px;
  }
  .rec__head-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.012em;
    text-align: left;
    color: var(--c-ink);
    margin: 0;
    text-wrap: balance;
  }
  .rec__head-lede {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.45;
    text-align: left;
    color: var(--c-ash);
    margin: 2px 0 0;
    text-wrap: pretty;
  }

  /* Meta line — the running colophon. Italic Lora, em-middot
     separators per tokens.css voice rules. */
  .rec__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
    padding: 20px 22px 0;
    margin: 0;
    text-align: center;
    font-family: var(--f-display);
    font-style: italic;
    font-size: 13.5px;
    line-height: 1.4;
    color: var(--c-ash);
  }
  .rec__dot {
    color: var(--c-oat);
    font-style: normal;
  }

  .rec__foot {
    margin-top: auto;
    position: sticky;
    bottom: 0;
    padding: 14px 24px 34px;
    background: var(--c-cream);
    z-index: 5;
  }

  .rec__continue {
    position: relative;
    width: 100%;
    height: 48px;
    border-radius: 999px;
    background: transparent;
    color: var(--c-conifer);
    border: 1px solid var(--c-conifer);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14.5px;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background-color var(--motion-state) var(--ease-state);
  }

  .rec__continue--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
