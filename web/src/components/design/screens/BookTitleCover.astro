---
/**
 * Screen VII (Flow II) · The cover.
 *
 * Reached from Preview (VI) when the user taps the cover. Shares its
 * structure with the page-edit surface (VIII):
 *
 *     Display (the cover, large)
 *         ↓
 *     LAYOUT row (2 cover thumbs — plate or full-bleed)
 *         ↓
 *     PHOTO row (swap which photo sits in the cover layout)
 *         ↓
 *     Done
 *
 * The layout picker is interactive: both cover variants are pre-
 * rendered inside the stage, click a thumb to swap them. Same
 * mechanic as VIII. One source of truth for cover rendering — the
 * display and the thumbnails both use <BookCover>.
 */
import ScreenNav from "../ui/ScreenNav.astro";
import BookCover, { type CoverLayout } from "../ui/BookCover.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";
import { sampleLibraryTiles } from "~/lib/design/sample-library";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;

const coverLayouts: { key: CoverLayout }[] = [
  { key: "plate" },
  { key: "bleed" },
];

// Cover-photo alternates — the same candidate set we had before.
const photoCandidates = [0, 3, 10, 13, 23, 24].map((i) => sampleLibraryTiles[i]);

const coverTitle = "For Us.";
const coverSubtitle = "A year at the table.";
const coverPhoto = sampleRecipe.photo;
---

<div class="tc" data-tc-root>
  <ScreenNav eyebrow="Editing" />

  <div class="tc__stage">
    {coverLayouts.map(({ key }) => (
      <div class="tc__cover-display" data-cover={key} hidden={key !== "plate"}>
        <div class="tc__cover-scale">
          <BookCover layout={key} title={coverTitle} subtitle={coverSubtitle} photo={coverPhoto} />
        </div>
      </div>
    ))}
  </div>

  <p class="tc__folio">— the cover —</p>

  <section class="tc__row" aria-label="Cover layout">
    <div class="tc__row-mark">
      <span class="tc__row-eyebrow">Layout</span>
      <hr class="tc__row-rule" aria-hidden="true" />
    </div>
    <div class="tc__layout-options" role="radiogroup">
      {coverLayouts.map(({ key }) => (
        <button
          class:list={["tc__layout-option", key === "plate" && "tc__layout-option--on"]}
          type="button"
          role="radio"
          aria-checked={key === "plate"}
          aria-label={`Cover layout: ${key}`}
          data-layout={key}
        >
          <div class="tc__layout-thumb">
            <div class="tc__layout-thumb-scale">
              <BookCover layout={key} title={coverTitle} subtitle={coverSubtitle} photo={coverPhoto} />
            </div>
          </div>
          <span class="tc__layout-mark" aria-hidden="true"></span>
        </button>
      ))}
    </div>
  </section>

  <section class="tc__row" aria-label="Cover photo">
    <div class="tc__row-mark">
      <span class="tc__row-eyebrow">Photo</span>
      <hr class="tc__row-rule" aria-hidden="true" />
    </div>
    <div class="tc__photo-scroll">
      {photoCandidates.map((tile, i) => {
        const isActive = i === 0;
        const photoStyle = tile.photo ? `background-image: url(${tile.photo})` : "";
        const tone = tile.tone ?? "corn";
        return (
          <button
            class:list={["tc__photo", isActive && "tc__photo--on", `tc__photo--${tone}`]}
            type="button"
            aria-label={tile.title}
            aria-pressed={isActive}
            style={photoStyle}
          ></button>
        );
      })}
    </div>
  </section>

  <div class="tc__foot">
    <button class={showTap ? "tc__done tc__done--tap" : "tc__done"} type="button">
      Done
    </button>
  </div>
</div>

<script>
  // Layout picker — swap which cover variant is visible.
  document.querySelectorAll<HTMLElement>("[data-tc-root]").forEach((root) => {
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-layout]"));
    const displays = Array.from(root.querySelectorAll<HTMLElement>("[data-cover]"));
    if (thumbs.length === 0 || displays.length === 0) return;

    const activate = (key: string) => {
      thumbs.forEach((t) => {
        const on = t.dataset.layout === key;
        t.classList.toggle("tc__layout-option--on", on);
        t.setAttribute("aria-checked", String(on));
      });
      displays.forEach((d) => {
        d.hidden = d.dataset.cover !== key;
      });
    };

    thumbs.forEach((t) => {
      t.addEventListener("click", () => {
        const key = t.dataset.layout;
        if (key) activate(key);
      });
    });
  });
</script>

<style>
  .tc {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  /* Cover display — natural 320×400, scaled 0.72 → 230×288. Two
     variants pre-rendered, one visible. */
  .tc__stage {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 18px 22px 0;
  }
  .tc__cover-display {
    position: relative;
    width: 230px;
    height: 288px;
    margin: 0 auto;
  }
  .tc__cover-display[hidden] { display: none; }
  .tc__cover-scale {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 400px;
    transform: scale(0.72);
    transform-origin: top left;
    pointer-events: none;
  }

  /* Folio — centered Lora italic in Oat, em-dash bracketed per
     tokens.css §TYPOGRAPHIC CHARACTER RULES. Anchors the display to
     the book (not floating chrome). */
  .tc__folio {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 400;
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--c-oat);
    text-align: center;
    margin: 12px 0 0;
    letter-spacing: 0.01em;
  }

  /* Section rows — editorial chapter marks, not picker chrome. A
     small-caps eyebrow + 36px ochre rule sits above each row so
     LAYOUT and PHOTO read as sections of the cookbook's colophon. */
  .tc__row {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 24px 24px 0;
  }
  .tc__row-mark {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .tc__row-eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10.5px;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .tc__row-rule {
    display: block;
    border: 0;
    width: 36px;
    height: 1px;
    background: var(--c-ochre);
    margin: 0;
    opacity: 0.85;
  }

  /* Layout picker — two thumbs side-by-side. Active state is a
     small Ochre hairline that appears beneath the active thumb, like
     a reader's margin-rule marking the chosen entry. No ring, no
     caption — the thumbnails speak for themselves. */
  .tc__layout-options {
    display: flex;
    gap: 18px;
  }
  .tc__layout-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .tc__layout-thumb {
    position: relative;
    width: 68px;
    aspect-ratio: 4 / 5;
    border-radius: var(--r-page);
    overflow: hidden;
    box-shadow: var(--shadow-paper);
  }
  .tc__layout-thumb-scale {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 400px;
    transform: scale(0.2125);
    transform-origin: top left;
    pointer-events: none;
  }
  /* The margin-rule mark. Always reserves space so the layout
     doesn't jump when selection changes; becomes visible via
     background on --on. */
  .tc__layout-mark {
    display: block;
    width: 20px;
    height: 1.5px;
    background: transparent;
    transition: background-color var(--motion-state) var(--ease-state);
  }
  .tc__layout-option--on .tc__layout-mark {
    background: var(--c-ochre);
  }

  /* Photo picker — horizontal scrolling row of candidates. */
  .tc__photo-scroll {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 54px;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 2px;
    scrollbar-width: none;
  }
  .tc__photo-scroll::-webkit-scrollbar { display: none; }
  .tc__photo {
    width: 54px;
    aspect-ratio: 4 / 5;
    padding: 0;
    border: 0;
    border-radius: var(--r-page);
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    cursor: pointer;
    box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.15);
    transition: box-shadow var(--motion-state) var(--ease-state);
  }
  .tc__photo--corn:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #f5d990 0%, #d6a34e 45%, #8a5c1f 100%);
  }
  .tc__photo--sage:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #6a8878 0%, #3f5a4a 55%, #223528 100%);
  }
  .tc__photo--ochre:not([style*="background-image"]) {
    background: radial-gradient(ellipse at 30% 30%, #d4b062 0%, #7a5a26 55%, #3b2910 100%);
  }
  .tc__photo--on {
    box-shadow:
      inset 0 0 0 0.5px rgba(0, 0, 0, 0.15),
      0 0 0 1.5px var(--c-ochre),
      0 0 0 3px var(--c-cream);
  }

  /* Done — S1 outlined, matches VIII. Pinned to the bottom. */
  .tc__foot {
    margin-top: auto;
    position: sticky;
    bottom: 0;
    padding: 14px 24px 34px;
    background: var(--c-cream);
    z-index: 5;
  }
  .tc__done {
    position: relative;
    display: block;
    width: 100%;
    height: 48px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid var(--c-conifer);
    background: transparent;
    color: var(--c-conifer);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14.5px;
    line-height: 1;
    letter-spacing: 0.01em;
    text-align: center;
    cursor: pointer;
    transition: background-color var(--motion-state) var(--ease-state),
                color var(--motion-state) var(--ease-state);
  }
  .tc__done--tap::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }
</style>
