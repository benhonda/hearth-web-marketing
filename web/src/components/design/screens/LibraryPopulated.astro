---
/**
 * Flow III · I — Library, populated.
 * Thin wrapper around Library.astro; halos the Cookbooks row as the
 * book-creation entry point.
 */
import Library from "./Library.astro";

interface Props { showTap?: boolean; }
const { showTap } = Astro.props;
---

<Library state="populated" showTap={showTap} optionsTapTarget="cookbooks" />
