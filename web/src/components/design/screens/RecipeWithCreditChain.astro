---
/**
 * Flow VII · IV — Recipe with credit chain.
 *
 * The cookbook page Sarah's been cooking from, opened from her shared
 * collection. Mirrors ImportPreview's "preview before save" grammar —
 * top bar (Cancel · eyebrow · Save) over a cream cookbook page —
 * because that's Hearth's existing save-shaped pattern. The semantic
 * difference: the source isn't a URL the cook just pasted, it's a
 * recipe Sarah saved from a URL and the cook is now saving from
 * Sarah's library.
 *
 * The from-card carries TWO attributions, in order of authority:
 *   FROM table.kitchen     — the original cookbook
 *   VIA Sarah Chen         — the friend who put it in your hands
 *
 * Single inline row, em-middot separated, same small-caps eyebrow
 * + italic Lora value rhythm as ImportPreview's from-card. That's
 * the church-cookbook attribution grammar (publication credit +
 * contributing-cook byline) ported into a screen.
 *
 * Title is static (Lora display, not an input) — Sarah's recipe is
 * already finalized; the cook isn't editing it on save. Halo on the
 * Save button in the top bar.
 */
import IngredientsList from "../ui/IngredientsList.astro";
import MethodList from "../ui/MethodList.astro";
import { sampleRecipe } from "~/lib/design/sample-recipe";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
---

<div class="rcc">
  <header class="rcc-bar">
    <button class="rcc-bar__cancel" type="button">Cancel</button>
    <span class="rcc-bar__eyebrow">From Sarah</span>
    <button class={showTap ? "rcc-bar__save rcc-bar__save--tap" : "rcc-bar__save"} type="button">Save</button>
  </header>

  <div class="rcc__body">
    <div class="rcc__from">
      <span class="rcc__from-eyebrow">From</span>
      <span class="rcc__from-value">{sampleRecipe.source}</span>
      <span class="rcc__from-sep" aria-hidden="true">·</span>
      <span class="rcc__from-eyebrow">Via</span>
      <span class="rcc__from-value">Sarah Chen</span>
    </div>

    <div class="rcc__hero" aria-hidden="true" style={`background-image: url(${sampleRecipe.photo})`}>
      <span class="rcc__hero-credit">photograph · Mia Aquilina</span>
    </div>

    <h1 class="rcc__title">{sampleRecipe.title}</h1>

    <p class="rcc__meta">
      <em>Serves {sampleRecipe.serves}</em>
      <span aria-hidden="true"> · </span>
      <em>{sampleRecipe.minutes} min</em>
    </p>

    <hr class="rcc__rule" />

    <IngredientsList items={sampleRecipe.ingredients} />

    <hr class="rcc__rule" />

    <MethodList items={sampleRecipe.method} />
  </div>
</div>

<style>
  .rcc {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
    padding-bottom: 44px; /* home indicator clearance */
  }

  /* Top bar — same grammar as ImportPreview's import-bar. Three-column
     grid (Cancel · eyebrow · Save), hairline divider beneath. The
     eyebrow here names the doorway — "FROM SARAH" — instead of the
     action ("IMPORT RECIPE"), because the user is browsing-to-save,
     not extracting. */
  .rcc-bar {
    padding: 62px 22px 14px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(31, 27, 23, 0.08);
  }
  .rcc-bar__cancel {
    justify-self: flex-start;
    background: transparent;
    border: 0;
    cursor: pointer;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--c-ash);
  }
  .rcc-bar__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .rcc-bar__save {
    position: relative;
    justify-self: flex-end;
    background: transparent;
    border: 0;
    cursor: pointer;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 14px;
    color: var(--c-ochre);
    padding: 4px 8px;
  }
  .rcc-bar__save--tap::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 3px solid var(--annotation);
    box-shadow: var(--annotation-glow);
    pointer-events: none;
    opacity: var(--halo-opacity);
    transition: opacity 180ms ease;
    z-index: 50;
  }

  .rcc__body {
    padding: 20px 22px 0;
    display: grid;
    gap: 18px;
  }

  /* From card — extended to two attributions on one inline row.
     Keeps ImportPreview's pill-card grammar (light ochre wash, 2px
     radius, eyebrow + italic value) but threads the curator credit
     through with a middot separator. The first FROM is the
     publication; the second VIA is the contributing cook. Same
     church-cookbook attribution rhythm as the printed page footer. */
  .rcc__from {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 10px;
    padding: 10px 12px;
    background: rgba(122, 90, 38, 0.06);
    border-radius: 2px;
    justify-self: flex-start;
  }
  .rcc__from-eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 9.5px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-ochre);
  }
  .rcc__from-value {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 13px;
    color: var(--c-ink);
  }
  .rcc__from-sep {
    font-family: var(--f-display);
    font-size: 13px;
    color: var(--c-ochre);
    opacity: 0.55;
  }

  /* Hero — same proportions as ImportPreview (4:3, 2px radius,
     scrim + photographer credit). The cookbook page within the
     preview frame. */
  .rcc__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 2px;
    background-color: var(--c-oat);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }
  .rcc__hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(0, 0, 0, 0.4) 100%);
  }
  .rcc__hero-credit {
    position: absolute;
    bottom: 8px;
    right: 10px;
    font-family: var(--f-body);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    z-index: 1;
  }

  /* Title — Lora display, static. Not an input: the cook isn't
     editing Sarah's recipe on save. Reads as the cookbook page
     it is. */
  .rcc__title {
    margin: 4px 0 0;
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: var(--c-ink);
    text-wrap: balance;
  }

  .rcc__meta {
    margin: 0;
    font-family: var(--f-display);
    font-size: 14px;
    color: var(--c-ash);
  }
  .rcc__meta em {
    font-style: italic;
    color: var(--c-ink);
  }

  .rcc__rule {
    border: 0;
    height: 1px;
    background: rgba(31, 27, 23, 0.08);
    margin: 4px 0;
  }
</style>
