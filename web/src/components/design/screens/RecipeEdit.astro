---
/**
 * Screen IX · Recipe · editing step iv (inline).
 *
 * Thin composition: the full RecipeDetail with `editingIndex={3}` so
 * step iv renders as a live textarea in-place. Cancel + Save live
 * directly under the textarea (inside MethodList) — attached to what's
 * being edited, not floating chrome.
 *
 * This screen owns only:
 *   · a quiet top strip showing "Editing · step iv" context
 *   · the iOS keyboard docked at the bottom
 *
 * Both strips are `position: sticky` in the phone's scroll viewport;
 * an inline script scrolls the textarea into the visible band on load
 * so the step iv edit + its Cancel/Save sit clear of the keyboard.
 */
import RecipeDetail from "./RecipeDetail.astro";
import IosKeyboard from "../ui/IosKeyboard.astro";

interface Props { showTap?: boolean; }
const { showTap = false } = Astro.props;
---

<div class="edit">
  <header class="edit-bar">
    <span class="edit-bar__eyebrow">Editing · step iv</span>
  </header>

  <RecipeDetail editingIndex={3} hideHeader editSaveTap={showTap} />

  <div class="edit__keyboard-dock">
    <IosKeyboard suggestions={["minutes", "12", "just"] as [string, string, string]} />
  </div>
</div>

<script is:inline>
  (function () {
    function run() {
      document.querySelectorAll(".edit").forEach(function (edit) {
        var scroller = edit.closest(".phone__scroll");
        var ta = edit.querySelector(".method__textarea");
        if (!scroller || !ta) return;
        // Walk offsetParent chain for the textarea's position in the
        // scroller's own coordinate system. Immune to ancestor
        // transforms (e.g. canvas phones at scale(0.58)) unlike rects.
        var offsetTop = 0;
        var el = ta;
        while (el && el !== scroller) {
          offsetTop += el.offsetTop;
          el = el.offsetParent;
        }
        // Land the textarea just below the sticky top strip; leaves
        // room for Cancel/Save underneath, still clear of the keyboard.
        scroller.scrollTop = Math.max(0, offsetTop - 120);
      });
    }
    if (document.readyState === "complete") run();
    else window.addEventListener("load", run);
  })();
</script>

<style>
  .edit {
    position: relative;
    min-height: 100%;
  }

  /* Top strip — quiet context label ──────────────────────── */

  .edit-bar {
    position: sticky;
    top: 0;
    z-index: 10;
    padding: 62px 22px 12px;
    display: grid;
    place-items: center;
    background: var(--c-cream);
    border-bottom: 1px solid rgba(31, 27, 23, 0.08);
  }
  .edit-bar__eyebrow {
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--c-ochre);
    white-space: nowrap;
  }

  /* Keyboard dock ─────────────────────────────────────────── */

  .edit__keyboard-dock {
    position: sticky;
    bottom: 0;
    z-index: 10;
  }
</style>
